@model IEnumerable<ITPRO_CRM.Models.KhoaHoc>

@{
    ViewData["Title"] = "Danh sách Khóa học";
}

<h1>Danh sách Khóa học</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">➕ Tạo khóa học mới</a>
</p>
<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.TenKhoaHoc)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.HocPhi)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SoBuoi)
            </th>
            <th>
                Ảnh minh họa
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TrangThai)
            </th>
            <th>Hành động</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="fw-bold">
                    @Html.DisplayFor(modelItem => item.TenKhoaHoc)
                </td>
                <td>
                    @string.Format("{0:#,##0} VNĐ", item.HocPhi)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.SoBuoi)
                </td>

                <td>
                    @if (!string.IsNullOrEmpty(item.HinhAnh))
                    {
                        <img src="~/images/@item.HinhAnh" width="80" height="60" style="object-fit:cover; border-radius:5px;" />
                    }
                    else
                    {
                        <span class="text-muted small">Running...</span>
                    }
                </td>

                <td>
                    @if (item.TrangThai)
                    {
                        <span class="badge bg-success">Đang tuyển sinh</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Ngừng tuyển</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Chi tiết</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>