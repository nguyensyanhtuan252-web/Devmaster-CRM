@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập hệ thống CRM</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            height: 100vh;
            overflow: hidden;
            background-color: #fff;
        }

        .login-container {
            height: 100vh;
            display: flex;
            flex-wrap: wrap;
        }

        /* PHẦN BÊN TRÁI: HÌNH ẢNH & THƯƠNG HIỆU */
        .login-sidebar {
            background-color: #0f172a; /* Màu xanh than thương hiệu */
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 50px;
            position: relative;
            overflow: hidden;
        }

            /* Họa tiết trang trí mờ phía sau */
            .login-sidebar::before {
                content: '';
                position: absolute;
                width: 150%;
                height: 150%;
                background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, rgba(0,0,0,0) 60%);
                top: -25%;
                left: -25%;
            }

        .brand-content {
            position: relative;
            z-index: 2;
            max-width: 450px;
        }

        /* PHẦN BÊN PHẢI: FORM ĐĂNG NHẬP */
        .login-form-wrapper {
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #ffffff;
        }

        .login-card {
            width: 100%;
            max-width: 400px;
            padding: 20px;
        }

        .form-control {
            height: 48px;
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            font-size: 14px;
            border-radius: 8px;
            transition: all 0.2s;
        }

            .form-control:focus {
                background-color: #fff;
                border-color: #3b82f6;
                box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
            }

        .btn-primary {
            height: 48px;
            background-color: #2563eb;
            border: none;
            font-weight: 600;
            border-radius: 8px;
            font-size: 14px;
            letter-spacing: 0.5px;
        }

            .btn-primary:hover {
                background-color: #1d4ed8;
            }

        /* Responsive: Trên điện thoại thì ẩn bên trái đi */
        @@media (max-width: 768px) {
            .login-sidebar {
                display: none;
            }
        }
    </style>
</head>
<body>

    <div class="container-fluid p-0">
        <div class="row g-0 login-container">

            <div class="col-md-6 col-lg-7 login-sidebar">
                <div class="brand-content">
                    <h1 class="display-4 fw-bold mb-4">Quản lý trung tâm<br>Hiệu quả & Dễ dàng.</h1>
                    <p class="lead opacity-75 mb-5">Hệ thống CRM giúp tối ưu hóa quy trình tuyển sinh, chăm sóc học viên và quản lý doanh thu tập trung.</p>

                    <div class="d-flex align-items-center gap-4 opacity-75 small">
                        <div><i class="fa-solid fa-check-circle text-success me-2"></i> Quản lý Lead</div>
                        <div><i class="fa-solid fa-check-circle text-success me-2"></i> Báo cáo Realtime</div>
                        <div><i class="fa-solid fa-check-circle text-success me-2"></i> Bảo mật cao</div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-5 login-form-wrapper">
                <div class="login-card">
                    <div class="mb-4">
                        <i class="fa-solid fa-cube fa-2x text-primary"></i>
                    </div>

                    <h3 class="fw-bold text-dark mb-1">Xin chào,</h3>
                    <p class="text-muted mb-4">Vui lòng đăng nhập để tiếp tục làm việc.</p>

                    <form asp-action="Login" method="post">

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger py-2 small border-0 bg-danger bg-opacity-10 text-danger">
                                <i class="fa-solid fa-circle-exclamation me-1"></i> @ViewBag.Error
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-secondary">Email hoặc Tên đăng nhập</label>
                            <input type="text" name="user" class="form-control" placeholder="admin@gmail.com" value="@ViewBag.User" required autofocus>
                        </div>

                        <div class="mb-4">
                            <div class="d-flex justify-content-between">
                                <label class="form-label small fw-bold text-secondary">Mật khẩu</label>
                                <a href="#" class="small text-decoration-none text-primary">Quên mật khẩu?</a>
                            </div>
                            <input type="password" name="pass" class="form-control" placeholder="••••••" required>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mb-3">
                            ĐĂNG NHẬP
                        </button>

                        <div class="text-center small text-muted">
                            Bạn gặp sự cố? <a href="#" class="text-decoration-none fw-bold text-dark">Liên hệ kỹ thuật</a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>

</body>
</html>