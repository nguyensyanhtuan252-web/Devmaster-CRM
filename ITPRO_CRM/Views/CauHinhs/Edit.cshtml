@model ITPRO_CRM.Models.CauHinh

@{
    ViewData["Title"] = "Cấu hình hệ thống";
}

<style>
    /* Card cài đặt sang trọng */
    .settings-card {
        background: #fff;
        border: 1px solid rgba(226, 232, 240, 0.8);
        border-radius: 16px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
        overflow: hidden;
    }

    /* Tab điều hướng đẹp */
    .nav-settings {
        background-color: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        padding: 0 1rem;
    }

        .nav-settings .nav-link {
            color: #64748b;
            font-weight: 600;
            border: none;
            border-bottom: 3px solid transparent;
            padding: 1rem 1.5rem;
            background: transparent !important;
            margin-bottom: -1px;
        }

            .nav-settings .nav-link:hover {
                color: #3b82f6;
            }

            .nav-settings .nav-link.active {
                color: #3b82f6;
                border-bottom-color: #3b82f6;
                background-color: #fff;
            }

    /* Input Style */
    .form-label-custom {
        font-weight: 600;
        font-size: 0.85rem;
        color: #334155;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-control-custom {
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        padding: 0.7rem 1rem;
        background-color: #fff;
        color: #1e293b;
        font-weight: 500;
        transition: all 0.2s;
    }

        .form-control-custom:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
            outline: none;
        }
</style>

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h4 class="fw-bold text-dark mb-1">Thiết lập Hệ thống</h4>
                    <p class="text-muted small mb-0">Cập nhật thông tin trung tâm & cấu hình gửi Email</p>
                </div>
            </div>

            <div class="settings-card">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <ul class="nav nav-settings" id="settingTabs" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link active" id="general-tab" data-bs-toggle="tab" data-bs-target="#general" type="button">
                                <i class="fa-solid fa-building me-2"></i> Thông tin chung
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link" id="email-tab" data-bs-toggle="tab" data-bs-target="#email" type="button">
                                <i class="fa-solid fa-envelope me-2"></i> Cấu hình Email
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content p-4 p-md-5">

                        <div class="tab-pane fade show active" id="general">
                            <div class="row g-4">
                                <div class="col-md-12">
                                    <label asp-for="TenTrungTam" class="form-label-custom">Tên Trung tâm / Đơn vị</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0 text-muted"><i class="fa-solid fa-landmark"></i></span>
                                        <input asp-for="TenTrungTam" class="form-control form-control-custom border-start-0 ps-0" placeholder="Nhập tên trung tâm..." />
                                    </div>
                                    <span asp-validation-for="TenTrungTam" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="SoDienThoai" class="form-label-custom">Hotline liên hệ</label>
                                    <input asp-for="SoDienThoai" class="form-control form-control-custom" placeholder="09xxxxxxxx" />
                                    <span asp-validation-for="SoDienThoai" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="EmailHeThong" class="form-label-custom">Email liên hệ (Hiển thị)</label>
                                    <input asp-for="EmailHeThong" class="form-control form-control-custom" placeholder="admin@example.com" />
                                    <span asp-validation-for="EmailHeThong" class="text-danger small"></span>
                                </div>

                                <div class="col-12">
                                    <label asp-for="DiaChi" class="form-label-custom">Địa chỉ trụ sở</label>
                                    <input asp-for="DiaChi" class="form-control form-control-custom" />
                                    <span asp-validation-for="DiaChi" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="email">
                            <div class="alert alert-primary bg-opacity-10 border-0 text-primary mb-4 d-flex align-items-center">
                                <i class="fa-solid fa-circle-info fs-4 me-3"></i>
                                <div>
                                    <strong>Lưu ý quan trọng:</strong><br />
                                    Cấu hình này dùng để gửi Email Marketing tự động. Vui lòng nhập chính xác Mật khẩu ứng dụng (App Password).
                                </div>
                            </div>

                            <div class="row g-4">
                                <div class="col-md-6">
                                    <label class="form-label-custom">Email Gửi (SMTP User)</label>
                                    <input asp-for="EmailGui" class="form-control form-control-custom" placeholder="marketing@gmail.com" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label-custom">Mật khẩu ứng dụng (SMTP Pass)</label>
                                    <div class="input-group">
                                        <input asp-for="MatKhauEmail" type="password" class="form-control form-control-custom" placeholder="••••••••••••" />
                                        <button class="btn btn-light border" type="button"><i class="fa-solid fa-eye"></i></button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="p-4 bg-light border-top d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-white border px-4 fw-bold text-muted">Hủy bỏ</a>
                        <button type="submit" class="btn btn-primary px-5 fw-bold shadow-sm">
                            <i class="fa-solid fa-floppy-disk me-2"></i> LƯU CẤU HÌNH
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}