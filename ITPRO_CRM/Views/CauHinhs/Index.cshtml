@{
    ViewData["Title"] = "Báo cáo chiến lược";
}

<style>
    .kpi-card {
        background: #ffffff;
        border: none;
        border-radius: 1.5rem;
        transition: all 0.3s ease;
        border-left: 5px solid #3b82f6;
    }

        .kpi-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important;
        }

    .icon-shape {
        width: 48px;
        height: 48px;
        background: rgba(59, 130, 246, 0.1);
        color: #3b82f6;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .chart-container {
        background: #fff;
        border-radius: 1.5rem;
        padding: 25px;
        height: 100%;
    }
</style>

<div class="container-fluid py-4 bg-light">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0"><i class="bi bi-speedometer2 me-2 text-primary"></i>Dashboard Tổng Quan</h2>
        <button class="btn btn-white shadow-sm border rounded-pill px-4 fw-bold">
            <i class="bi bi-download me-1"></i> Xuất Báo Cáo PDF
        </button>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="kpi-card shadow-sm p-4 border-primary">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small fw-bold text-uppercase">Tổng doanh thu</span>
                        <h3 class="fw-bold mb-0">@(ViewBag.TongDoanhThu?.ToString("N0") ?? "0")đ</h3>
                    </div>
                    <div class="icon-shape bg-primary bg-opacity-10 text-primary"><i class="bi bi-currency-dollar fs-4"></i></div>
                </div>
                <div class="mt-3 small text-success fw-bold"><i class="bi bi-arrow-up"></i> 12% <span class="text-muted fw-normal">so với tháng trước</span></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card shadow-sm p-4 border-success">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small fw-bold text-uppercase">Học viên mới</span>
                        <h3 class="fw-bold mb-0">@ViewBag.HocVienMoi</h3>
                    </div>
                    <div class="icon-shape bg-success bg-opacity-10 text-success"><i class="bi bi-people fs-4"></i></div>
                </div>
                <div class="mt-3 small text-success fw-bold"><i class="bi bi-arrow-up"></i> 5% <span class="text-muted fw-normal">tháng này</span></div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card shadow-sm p-4 border-warning">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small fw-bold text-uppercase">Tỷ lệ chốt</span>
                        <h3 class="fw-bold mb-0">@ViewBag.TiLeChot%</h3>
                    </div>
                    <div class="icon-shape bg-warning bg-opacity-10 text-warning"><i class="bi bi-funnel fs-4"></i></div>
                </div>
                <div class="mt-3 progress" style="height: 6px;">
                    <div class="progress-bar bg-warning" style="width: @ViewBag.TiLeChot%"></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card shadow-sm p-4 border-danger">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small fw-bold text-uppercase">Chi phí Marketing</span>
                        <h3 class="fw-bold mb-0">15.4M</h3>
                    </div>
                    <div class="icon-shape bg-danger bg-opacity-10 text-danger"><i class="bi bi-megaphone fs-4"></i></div>
                </div>
                <div class="mt-3 small text-danger fw-bold"><i class="bi bi-dash-circle"></i> Đang chạy 3 chiến dịch</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="chart-container shadow-sm">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0"><i class="bi bi-graph-up-arrow me-2"></i>Biểu đồ tăng trưởng Doanh thu</h5>
                    <select class="form-select form-select-sm w-auto border-0 bg-light fw-bold">
                        <option>6 tháng gần nhất</option>
                        <option>Năm nay</option>
                    </select>
                </div>
                <canvas id="revenueChart" height="300"></canvas>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="chart-container shadow-sm">
                <h5 class="fw-bold mb-4"><i class="bi bi-pie-chart me-2"></i>Cơ cấu nguồn Leads</h5>
                <canvas id="leadsDonutChart" height="300"></canvas>
                <div class="mt-4 small">
                    <div class="d-flex justify-content-between mb-1"><span><i class="bi bi-circle-fill text-primary me-2"></i>Facebook Ads</span><b>45%</b></div>
                    <div class="d-flex justify-content-between mb-1"><span><i class="bi bi-circle-fill text-success me-2"></i>Tự nhiên</span><b>30%</b></div>
                    <div class="d-flex justify-content-between"><span><i class="bi bi-circle-fill text-warning me-2"></i>Khác</span><b>25%</b></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // 1. Biểu đồ đường (Doanh thu)
        const ctxRevenue = document.getElementById('revenueChart').getContext('2d');
        new Chart(ctxRevenue, {
            type: 'line',
            data: {
                labels: ['Tháng 10', 'Tháng 11', 'Tháng 12', 'Tháng 1', 'Tháng 2', 'Tháng 3'],
                datasets: [{
                    label: 'Doanh thu (VNĐ)',
                    data: [15000000, 22000000, 18000000, 25000000, 30000000, 35000000],
                    borderColor: '#3b82f6',
                    backgroundColor: 'rgba(59, 130, 246, 0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 6,
                    pointBackgroundColor: '#fff',
                    pointBorderWidth: 3
                }]
            },
            options: { responsive: true, plugins: { legend: { display: false } } }
        });

        // 2. Biểu đồ Donut (Nguồn Leads)
        const ctxLeads = document.getElementById('leadsDonutChart').getContext('2d');
        new Chart(ctxLeads, {
            type: 'doughnut',
            data: {
                labels: ['Facebook', 'Tự nhiên', 'Khác'],
                datasets: [{
                    data: [45, 30, 25],
                    backgroundColor: ['#3b82f6', '#10b981', '#f59e0b'],
                    borderWidth: 0,
                    cutout: '75%'
                }]
            },
            options: { responsive: true, plugins: { legend: { display: false } } }
        });
    </script>
}