@model ITPRO_CRM.Models.HocVien
@{
    ViewData["Title"] = "Thêm Học viên mới";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-header bg-primary text-white p-4">
                    <h5 class="mb-0 fw-bold"><i class="fa-solid fa-user-plus me-2"></i>Thêm Hồ sơ Học viên</h5>
                </div>
                <div class="card-body p-4 bg-light bg-opacity-25">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <h6 class="text-primary fw-bold text-uppercase small border-bottom pb-2 mb-3">Thông tin cơ bản</h6>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="HoTen" class="form-label small fw-bold">Họ và Tên <span class="text-danger">*</span></label>
                                <input asp-for="HoTen" class="form-control" placeholder="Nhập họ tên..." required />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="GioiTinh" class="form-label small fw-bold">Giới tính</label>
                                <select asp-for="GioiTinh" class="form-select">
                                    <option value="Nam">Nam</option>
                                    <option value="Nữ">Nữ</option>
                                    <option value="Khác">Khác</option>
                                </select>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="NgaySinh" class="form-label small fw-bold">Ngày sinh</label>
                                <input asp-for="NgaySinh" class="form-control" type="date" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="DiaChi" class="form-label small fw-bold">Địa chỉ</label>
                                <input asp-for="DiaChi" class="form-control" placeholder="Số nhà, Quận/Huyện..." />
                            </div>
                        </div>

                        <h6 class="text-success fw-bold text-uppercase small border-bottom pb-2 mb-3 mt-4">Liên hệ & Mạng xã hội</h6>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="SoDienThoai" class="form-label small fw-bold">Số điện thoại</label>
                                <input asp-for="SoDienThoai" class="form-control" placeholder="09xxxxxxxx" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label small fw-bold">Email</label>
                                <input asp-for="Email" class="form-control" type="email" />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="FacebookLink" class="form-label small fw-bold"><i class="fa-brands fa-facebook text-primary"></i> Link Facebook</label>
                                <input asp-for="FacebookLink" class="form-control form-control-sm" placeholder="https://facebook.com/..." />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ZaloLink" class="form-label small fw-bold"><i class="fa-solid fa-comment-dots text-success"></i> Link Zalo</label>
                                <input asp-for="ZaloLink" class="form-control form-control-sm" placeholder="https://zalo.me/..." />
                            </div>
                        </div>

                        <h6 class="text-warning fw-bold text-uppercase small border-bottom pb-2 mb-3 mt-4">Học vấn & Công việc</h6>
                        <div class="row mb-3 bg-white p-3 rounded border mx-0">
                            <div class="col-md-4">
                                <label asp-for="TruongHoc" class="form-label small fw-bold">Trường học</label>
                                <input asp-for="TruongHoc" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="NganhHoc" class="form-label small fw-bold">Chuyên ngành</label>
                                <input asp-for="NganhHoc" class="form-control form-control-sm" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="CongViecHienTai" class="form-label small fw-bold">Nơi làm việc</label>
                                <input asp-for="CongViecHienTai" class="form-control form-control-sm" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MucTieuHocTap" class="form-label small fw-bold text-primary">Mục tiêu / Ghi chú</label>
                            <textarea asp-for="MucTieuHocTap" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="ChienDichId" class="form-label small fw-bold">Nguồn khách hàng</label>
                                <select asp-for="ChienDichId" class="form-select" asp-items="ViewBag.ChienDichId">
                                    <option value="">-- Tự nhiên --</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="TrangThai" class="form-label small fw-bold">Trạng thái</label>
                                <select asp-for="TrangThai" class="form-select fw-bold text-primary">
                                    <option value="0">⭐ Tiềm năng</option>
                                    <option value="1">📞 Đang tư vấn</option>
                                    <option value="2">✅ Đã nhập học</option>
                                </select>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 border-top pt-3">
                            <a asp-action="Index" class="btn btn-secondary px-4">Hủy</a>
                            <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">Lưu hồ sơ</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}