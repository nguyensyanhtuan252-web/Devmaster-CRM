@model ITPRO_CRM.Models.HocVien

@{
    ViewData["Title"] = "Hồ sơ: " + Model.HoTen;
    // 👇 QUAN TRỌNG: Dòng này để nhận tín hiệu từ Controller xem nên mở Tab nào
    var activeTab = TempData["ActiveTab"] as string ?? "info";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
            <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
        </a>
        <div class="d-flex gap-2">
            @if (Model.TrangThai == 0 || Model.TrangThai == 1)
            {
                <button type="button" class="btn btn-success btn-sm rounded-pill px-4 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#enrollModal">
                    <i class="fa-solid fa-graduation-cap me-2 fa-bounce"></i> LÀM THỦ TỤC NHẬP HỌC
                </button>
            }

            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm rounded-pill px-4 fw-bold shadow-sm">
                <i class="fa-solid fa-pen me-1"></i> Sửa hồ sơ
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 text-center h-100">
                <div class="card-body p-4">
                    <div class="mb-3 position-relative d-inline-block">
                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto shadow" style="width: 100px; height: 100px; font-size: 2.5rem; font-weight: bold;">
                            @(Model.HoTen?.Substring(0, 1) ?? "H")
                        </div>
                        <span class="position-absolute bottom-0 end-0 badge rounded-pill bg-success border border-white">
                            @(Model.TrangThai == 2 ? "Học viên" : (Model.TrangThai == 1 ? "Đang tư vấn" : "Tiềm năng"))
                        </span>
                    </div>
                    <h5 class="fw-bold text-dark mb-1">@Model.HoTen</h5>
                    <p class="text-muted small mb-2">@Model.Email</p>

                    @if (!string.IsNullOrEmpty(Model.MaHocVien))
                    {
                        <div class="d-inline-block bg-primary bg-opacity-10 text-primary fw-bold border border-primary border-opacity-25 rounded-pill px-3 py-1 mb-3 shadow-sm">
                            <i class="fa-solid fa-id-card-clip me-1"></i> MSHV: @Model.MaHocVien
                        </div>
                    }
                    else
                    {
                        <div class="mb-3"></div>
                    }
                    <div class="d-grid gap-2 text-start bg-light p-3 rounded-3 small">
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Ngày sinh:</span>
                            <span class="fw-bold">@(Model.NgaySinh.ToString("dd/MM/yyyy") == "01/01/0001" ? "--" : Model.NgaySinh.ToString("dd/MM/yyyy"))</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Điện thoại:</span>
                            <span class="fw-bold text-primary">@Model.SoDienThoai</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Địa chỉ:</span>
                            <span class="fw-bold text-end" style="max-width: 150px;">@(Model.DiaChi ?? "--")</span>
                        </div>
                    </div>

                    <div class="mt-3 d-flex justify-content-center gap-2">
                        @if (!string.IsNullOrEmpty(Model.FacebookLink))
                        {
                            <a href="@Model.FacebookLink" target="_blank" class="btn btn-outline-primary btn-sm rounded-circle" style="width: 35px; height: 35px; padding: 0; line-height: 33px;"><i class="fa-brands fa-facebook-f"></i></a>
                        }
                        @if (!string.IsNullOrEmpty(Model.ZaloLink))
                        {
                            <a href="@Model.ZaloLink" target="_blank" class="btn btn-outline-success btn-sm rounded-circle" style="width: 35px; height: 35px; padding: 0; line-height: 33px;"><i class="fa-solid fa-comment-dots"></i></a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-header bg-white border-bottom py-3">
                    <ul class="nav nav-tabs card-header-tabs" id="myTab" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link fw-bold @(activeTab == "info" ? "active" : "")"
                                    id="info-tab" data-bs-toggle="tab" data-bs-target="#info" type="button">
                                <i class="fa-solid fa-circle-info me-2 text-info"></i>Thông tin chung
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link fw-bold @(activeTab == "history" ? "active" : "")"
                                    id="history-tab" data-bs-toggle="tab" data-bs-target="#history" type="button">
                                <i class="fa-solid fa-clock-rotate-left me-2 text-warning"></i>Lịch sử tư vấn
                            </button>
                        </li>
                    </ul>
                </div>

                <div class="card-body p-4">
                    <div class="tab-content" id="myTabContent">

                        <div class="tab-pane fade @(activeTab == "info" ? "show active" : "")" id="info">
                            <h6 class="fw-bold text-uppercase text-dark mb-3 small"><i class="fa-solid fa-id-card-clip me-2"></i>Hồ sơ cá nhân</h6>
                            <div class="row g-3 mb-4 border-bottom pb-4">
                                <div class="col-md-6">
                                    <div class="d-flex align-items-center mb-2">
                                        <i class="fa-solid fa-building-columns text-muted me-2" style="width:20px"></i>
                                        <div>
                                            <small class="text-muted d-block" style="font-size: 0.75rem">Trường học</small>
                                            <span class="fw-bold">@(Model.TruongHoc ?? "--")</span>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center">
                                        <i class="fa-solid fa-briefcase text-muted me-2" style="width:20px"></i>
                                        <div>
                                            <small class="text-muted d-block" style="font-size: 0.75rem">Nơi làm việc</small>
                                            <span class="fw-bold">@(Model.CongViecHienTai ?? "--")</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="d-flex align-items-center mb-2">
                                        <i class="fa-solid fa-book-open text-muted me-2" style="width:20px"></i>
                                        <div>
                                            <small class="text-muted d-block" style="font-size: 0.75rem">Chuyên ngành</small>
                                            <span class="fw-bold">@(Model.NganhHoc ?? "--")</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <h6 class="fw-bold text-uppercase text-primary mb-3 small"><i class="fa-solid fa-bullseye me-2"></i>Mục tiêu & Nhu cầu</h6>
                            <div class="bg-primary bg-opacity-10 p-3 rounded-3 mb-4 border border-primary border-opacity-10">
                                @if (!string.IsNullOrEmpty(Model.MucTieuHocTap))
                                {
                                    <p class="mb-0 text-dark fst-italic">"@Model.MucTieuHocTap"</p>
                                }
                                else
                                {
                                    <p class="mb-0 text-muted fst-italic">-- Chưa cập nhật mục tiêu học tập --</p>
                                }
                            </div>

                            <h6 class="fw-bold text-uppercase text-success mb-3 small"><i class="fa-solid fa-graduation-cap me-2"></i>Thông tin xếp lớp</h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="small text-muted">Lớp học đăng ký</label>
                                    <div class="fw-bold">@(Model.LopHoc?.TenLop ?? "Chưa xếp lớp")</div>
                                </div>
                                <div class="col-md-6">
                                    <label class="small text-muted">Nguồn giới thiệu</label>
                                    <div class="fw-bold">@(Model.ChienDich?.TenChienDich ?? "Khách tự nhiên")</div>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade @(activeTab == "history" ? "show active" : "")" id="history">

                            <form asp-action="AddNote" method="post" class="mb-4 pb-4 border-bottom">
                                <input type="hidden" name="HocVienId" value="@Model.Id" />
                                <div class="row g-2">
                                    <div class="col-md-2">
                                        <select name="HinhThuc" class="form-select form-select-sm shadow-none">
                                            <option value="Gọi điện">📞 Gọi điện</option>
                                            <option value="Gặp mặt">🤝 Gặp mặt</option>
                                            <option value="Zalo/Tin nhắn">💬 Nhắn tin</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <input name="NoiDung" class="form-control form-control-sm shadow-none" placeholder="Nội dung trao đổi..." required />
                                    </div>
                                    <div class="col-md-2">
                                        <input name="KetQua" class="form-control form-control-sm shadow-none" placeholder="Kết quả..." />
                                    </div>
                                    <div class="col-md-3">
                                        <div class="input-group input-group-sm" title="Hẹn lịch liên lạc lại">
                                            <span class="input-group-text bg-white text-danger border-danger border-opacity-50">
                                                <i class="fa-regular fa-calendar-check"></i>
                                            </span>
                                            <input type="datetime-local" name="NgayHen" class="form-control form-control-sm border-danger border-opacity-50 shadow-none" />
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <button type="submit" class="btn btn-primary btn-sm w-100 fw-bold">Gửi</button>
                                    </div>
                                </div>
                            </form>

                            <div class="timeline">
                                @if (Model.LichSuTuVans != null && Model.LichSuTuVans.Count > 0)
                                {
                                    @foreach (var item in Model.LichSuTuVans.OrderByDescending(x => x.NgayTuVan))
                                    {
                                        <div class="d-flex mb-3">
                                            <div class="me-3 text-center" style="width: 50px;">
                                                <small class="d-block fw-bold text-muted">@item.NgayTuVan.ToString("dd/MM")</small>
                                                <small class="text-muted" style="font-size: 10px;">@item.NgayTuVan.ToString("HH:mm")</small>
                                            </div>
                                            <div class="flex-grow-1 bg-light p-2 rounded">
                                                <div class="d-flex justify-content-between">
                                                    <strong class="text-primary small">@item.HinhThuc</strong>
                                                    <span class="text-muted small" style="font-size: 10px;">Bởi: @(item.NguoiTuVan ?? "Admin")</span>
                                                </div>
                                                <p class="mb-0 small mt-1">@item.NoiDung</p>
                                                @if (!string.IsNullOrEmpty(item.KetQua))
                                                {
                                                    <div class="mt-1"><span class="badge bg-secondary bg-opacity-25 text-dark border" style="font-size: 0.7rem;">Kết quả: @item.KetQua</span></div>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-center text-muted py-3">Chưa có lịch sử tư vấn nào.</div>
                                }
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="enrollModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <form asp-controller="HocViens" asp-action="EnrollStudent" method="post">
                <input type="hidden" name="id" value="@Model.Id" />

                <div class="modal-header border-0 bg-success bg-opacity-10 rounded-top-4 pb-3">
                    <h5 class="modal-title fw-bold text-success">
                        <i class="fa-solid fa-file-signature me-2"></i>Thủ tục Nhập học: <span class="text-dark">@Model.HoTen</span>
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body p-4 bg-light">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <h6 class="fw-bold text-primary border-bottom pb-2 mb-3"><i class="fa-solid fa-book-open-reader me-2"></i>THÔNG TIN ĐÀO TẠO</h6>

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted">Xếp vào Lớp học <span class="text-danger">*</span></label>
                                <select name="lopHocId" class="form-select border-2 shadow-none" required onchange="tuDongDienHocPhi(this)">
                                    <option value="" data-hocphi="0">-- Chọn lớp học đang mở --</option>
                                    @if (ViewBag.DanhSachLop != null)
                                    {
                                        foreach (var lop in ViewBag.DanhSachLop)
                                        {
                                            <option value="@lop.Id" data-hocphi="@lop.HocPhi">@lop.TenLop</option>
                                        }
                                    }
                                </select>
                            </div>

                            

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted">Ghi chú cho Giáo vụ</label>
                                <textarea name="ghiChu" class="form-control border-2 shadow-none" rows="3" placeholder="Ví dụ: Cần mượn máy tính, học viên xin vào trễ..."></textarea>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <h6 class="fw-bold text-success border-bottom pb-2 mb-3"><i class="fa-solid fa-file-invoice-dollar me-2"></i>THÔNG TIN TÀI CHÍNH</h6>

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted">Tổng học phí gốc (VNĐ) <span class="text-danger">*</span></label>
                                <input type="number" id="inpGoc" name="hocPhi" class="form-control border-2 shadow-none text-end fw-bold" value="0" min="0" required onkeyup="tinhTien()" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted">Giảm trừ / Học bổng (VNĐ)</label>
                                <div class="input-group">
                                    <input type="number" id="inpGiam" name="giamTru" class="form-control border-2 shadow-none text-end fw-bold text-danger" value="0" min="0" onkeyup="tinhTien()" />
                                    <input type="text" name="lyDoGiamGia" class="form-control border-2 shadow-none" placeholder="Lý do (Cựu HV, Khuyến mãi...)" style="width: 45%;" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted">Khách đóng ngay hôm nay (VNĐ)</label>
                                <input type="number" id="inpDong" name="daNop" class="form-control form-control-lg border-2 shadow-none text-end fw-bold text-success" value="0" min="0" required onkeyup="tinhTien()" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted">Hình thức thanh toán</label>
                                <select name="hinhThuc" class="form-select border-2 shadow-none">
                                    <option value="Chuyển khoản">💳 Chuyển khoản (Mặc định)</option>
                                    <option value="Tiền mặt">💵 Tiền mặt</option>
                                    <option value="Quẹt thẻ POS">🏧 Quẹt thẻ POS</option>
                                </select>
                            </div>

                            <div class="bg-white rounded-3 p-3 border border-2 border-warning shadow-sm">
                                <div class="d-flex justify-content-between mb-2 small">
                                    <span class="text-muted fw-bold">Tổng phải thu:</span>
                                    <span class="fw-bold text-dark" id="txtPhaiThu">0 đ</span>
                                </div>
                                <div class="d-flex justify-content-between small">
                                    <span class="text-muted fw-bold">Còn nợ lại:</span>
                                    <span class="fw-bold text-danger" id="txtConNo">0 đ</span>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

                <div class="modal-footer border-0 bg-white rounded-bottom-4 pt-3 pb-3">
                    <button type="button" class="btn btn-light fw-bold rounded-pill px-4" data-bs-dismiss="modal">Hủy bỏ</button>
                    <button type="submit" class="btn btn-success fw-bold rounded-pill px-5 shadow-sm">
                        <i class="fa-solid fa-check-circle me-1"></i> XÁC NHẬN CHỐT ĐƠN
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Hàm mới: Tự động lấy giá tiền từ Lớp Học bắn xuống ô Học Phí Gốc
    function tuDongDienHocPhi(selectElement) {
        let selectedOption = selectElement.options[selectElement.selectedIndex];
        let hocPhi = selectedOption.getAttribute('data-hocphi') || 0;

        document.getElementById('inpGoc').value = hocPhi;
        tinhTien(); // Gọi hàm tính tiền để cập nhật luôn dòng "Còn nợ"
    }

    // Hàm cũ (Giữ nguyên)
    function tinhTien() {
        let goc = parseFloat(document.getElementById('inpGoc').value) || 0;
        let giam = parseFloat(document.getElementById('inpGiam').value) || 0;
        let dong = parseFloat(document.getElementById('inpDong').value) || 0;

        let phaiThu = goc - giam;
        let conNo = phaiThu - dong;

        document.getElementById('txtPhaiThu').innerText = phaiThu.toLocaleString('vi-VN') + " đ";
        document.getElementById('txtConNo').innerText = (conNo > 0 ? conNo.toLocaleString('vi-VN') : 0) + " đ";
    }
</script>