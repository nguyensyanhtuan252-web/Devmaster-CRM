@{
    ViewData["Title"] = "Báo cáo chiến lược";
    // Chuyển đổi dữ liệu từ Controller sang JSON để Javascript đọc được
    var revenueData = Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.RevenueData);
    var months = Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.Months);
    var studentStats = Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.StudentStats);
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    .kpi-card {
        background: #ffffff;
        border: none;
        border-radius: 1.2rem;
        transition: all 0.3s ease;
        border-left: 5px solid #3b82f6;
    }

        .kpi-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,.08) !important;
        }

    .icon-shape {
        width: 48px;
        height: 48px;
        background: rgba(59, 130, 246, 0.1);
        color: #3b82f6;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .chart-container {
        background: #fff;
        border-radius: 1.5rem;
        padding: 25px;
        height: 100%;
    }
</style>

<div class="container-fluid py-4 bg-light">
    <div class="d-flex justify-content-between align-items-center mb-4 px-3">
        <div>
            <h2 class="fw-bold text-dark mb-0"><i class="bi bi-speedometer2 me-2 text-primary"></i>DASHBOARD TỔNG QUAN</h2>
            <p class="text-muted small mb-0">Dữ liệu cập nhật mới nhất tính đến hôm nay, @DateTime.Now.ToString("dd/MM/yyyy")</p>
        </div>
        <button class="btn btn-white shadow-sm border rounded-pill px-4 fw-bold" onclick="window.print()">
            <i class="bi bi-printer me-1"></i> In báo cáo
        </button>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="kpi-card shadow-sm p-4 border-primary">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small fw-bold text-uppercase">Tổng doanh thu</span>
                        <h3 class="fw-bold mb-0">@(ViewBag.TongDoanhThu?.ToString("N0") ?? "0")đ</h3>
                    </div>
                    <div class="icon-shape bg-primary bg-opacity-10 text-primary"><i class="bi bi-currency-dollar fs-4"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card shadow-sm p-4 border-success">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small fw-bold text-uppercase">Học viên mới</span>
                        <h3 class="fw-bold mb-0">@ViewBag.HocVienMoi</h3>
                    </div>
                    <div class="icon-shape bg-success bg-opacity-10 text-success"><i class="bi bi-people fs-4"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card shadow-sm p-4 border-warning">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small fw-bold text-uppercase">Tỷ lệ chốt</span>
                        <h3 class="fw-bold mb-0">@ViewBag.TiLeChot%</h3>
                    </div>
                    <div class="icon-shape bg-warning bg-opacity-10 text-warning"><i class="bi bi-funnel fs-4"></i></div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card shadow-sm p-4 border-info">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-muted small fw-bold text-uppercase">Hệ thống</span>
                        <h3 class="fw-bold mb-0">Online</h3>
                    </div>
                    <div class="icon-shape bg-info bg-opacity-10 text-info"><i class="bi bi-cpu fs-4"></i></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="chart-container shadow-sm">
                <h5 class="fw-bold mb-4"><i class="bi bi-graph-up-arrow me-2 text-primary"></i>Biểu đồ tăng trưởng Doanh thu</h5>
                <canvas id="revenueChart" style="max-height: 400px;"></canvas>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="chart-container shadow-sm">
                <h5 class="fw-bold mb-4"><i class="bi bi-pie-chart me-2 text-primary"></i>Tỷ lệ chuyển đổi Lead</h5>
                <canvas id="studentChart" style="max-height: 300px;"></canvas>
                <div class="mt-4">
                    <div class="d-flex justify-content-between mb-2 small">
                        <span><i class="bi bi-circle-fill text-secondary me-2"></i>Tiềm năng</span>
                        <b id="leadVal"></b>
                    </div>
                    <div class="d-flex justify-content-between mb-2 small">
                        <span><i class="bi bi-circle-fill text-warning me-2"></i>Đang tư vấn</span>
                        <b id="pipeVal"></b>
                    </div>
                    <div class="d-flex justify-content-between small">
                        <span><i class="bi bi-circle-fill text-success me-2"></i>Học viên</span>
                        <b id="custVal"></b>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // 1. Cấu hình Biểu đồ Doanh thu (Đổi từ bar sang line cho sang)
    const ctxRev = document.getElementById('revenueChart').getContext('2d');

    // Tạo hiệu ứng Gradient (mờ dần bên dưới đường kẻ)
    let gradient = ctxRev.createLinearGradient(0, 0, 0, 400);
    gradient.addColorStop(0, 'rgba(59, 130, 246, 0.4)');
    gradient.addColorStop(1, 'rgba(59, 130, 246, 0)');

    new Chart(ctxRev, {
        type: 'line',
        data: {
            labels: @Html.Raw(months),
            datasets: [{
                label: 'Doanh thu (VNĐ)',
                data: @Html.Raw(revenueData),
                borderColor: '#3b82f6',
                backgroundColor: gradient,
                fill: true,
                tension: 0.4, // Tạo độ cong cho đường
                pointRadius: 5,
                pointBackgroundColor: '#fff',
                pointBorderColor: '#3b82f6',
                pointBorderWidth: 2
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, grid: { display: false } },
                x: { grid: { display: false } }
            }
        }
    });

    // 2. Cấu hình Biểu đồ Trạng thái (Doughnut Chart với lỗ rỗng to hơn)
    const statsData = @Html.Raw(studentStats);
    document.getElementById('leadVal').innerText = statsData[0];
    document.getElementById('pipeVal').innerText = statsData[1];
    document.getElementById('custVal').innerText = statsData[2];

    const ctxStu = document.getElementById('studentChart').getContext('2d');
    new Chart(ctxStu, {
        type: 'doughnut',
        data: {
            labels: ['Tiềm năng', 'Đang tư vấn', 'Học viên'],
            datasets: [{
                data: statsData,
                backgroundColor: ['#94a3b8', '#f59e0b', '#10b981'],
                borderWidth: 0,
                cutout: '75%' // Tạo lỗ rỗng to cho biểu đồ
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } }
        }
    });
</script>