@model IEnumerable<ITPRO_CRM.Models.EmailMarketing>
@{
    ViewData["Title"] = "Email Marketing";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold">📧 Chiến dịch Email</h4>
    <a asp-action="Create" class="btn btn-primary fw-bold"><i class="fa-solid fa-pen-nib me-2"></i> Soạn Email mới</a>
</div>

@if (TempData["Success"] != null)
{
     <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card shadow-sm border-0">
    <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
            <tr>
                <th class="ps-4">Tiêu đề</th>
                <th>Đối tượng</th>
                <th>Ngày gửi</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="ps-4 fw-bold text-primary">@item.TieuDe</td>
                    <td>@item.DoiTuongGui</td>
                    <td>@item.NgayGui.ToString("dd/MM/yyyy HH:mm")</td>
                    <td><span class="badge bg-success">Đã gửi</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>