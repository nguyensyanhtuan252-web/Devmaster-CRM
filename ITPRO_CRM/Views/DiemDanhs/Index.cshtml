@model List<ITPRO_CRM.Models.DiemDanh>

@{
    ViewData["Title"] = "Điểm danh Lớp: " + ViewBag.LopHoc?.TenLop;
    var lopHoc = ViewBag.LopHoc as ITPRO_CRM.Models.LopHoc;
    var ngayDiemDanh = (DateTime)ViewBag.Ngay;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h4 class="fw-bold text-dark mb-1"><i class="fa-solid fa-clipboard-list text-success me-2"></i> ĐIỂM DANH HỌC VIÊN</h4>
                    <p class="text-muted mb-0">Lớp: <span class="fw-bold text-primary">@lopHoc?.TenLop</span> | Ngày: <span class="fw-bold text-danger">@ngayDiemDanh.ToString("dd/MM/yyyy")</span></p>
                </div>
                <a asp-controller="LopHocs" asp-action="Index" class="btn btn-light border rounded-pill shadow-sm px-4 fw-bold">
                    <i class="fa-solid fa-arrow-left me-1"></i> Trở về
                </a>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <form asp-action="Save" method="post">
                    <input type="hidden" name="lopId" value="@lopHoc?.Id" />

                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4">#</th>
                                    <th>Họ và Tên</th>
                                    <th class="text-center" style="width: 250px;">Trạng thái</th>
                                    <th class="pe-4">Ghi chú (Lý do vắng)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Count > 0)
                                {
                                    for (int i = 0; i < Model.Count; i++)
                                    {
                                        <tr>
                                            <td class="ps-4 text-muted fw-bold">@(i + 1)</td>
                                            <td>
                                                <div class="fw-bold text-dark">@Model[i].HocVien?.HoTen</div>
                                                <div class="small text-muted">@Model[i].HocVien?.SoDienThoai</div>

                                                <input type="hidden" name="listDiemDanh[@i].HocVienId" value="@Model[i].HocVienId" />
                                                <input type="hidden" name="listDiemDanh[@i].LopHocId" value="@Model[i].LopHocId" />
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group shadow-sm" role="group">
                                                    <input type="radio" class="btn-check" name="listDiemDanh[@i].TrangThai" id="btnradio1_@i" value="1" @(Model[i].TrangThai == 1 ? "checked" : "")>
                                                    <label class="btn btn-outline-success fw-bold px-3" for="btnradio1_@i"><i class="fa-solid fa-check me-1"></i> Có mặt</label>

                                                    <input type="radio" class="btn-check" name="listDiemDanh[@i].TrangThai" id="btnradio2_@i" value="0" @(Model[i].TrangThai == 0 ? "checked" : "")>
                                                    <label class="btn btn-outline-danger fw-bold px-3" for="btnradio2_@i"><i class="fa-solid fa-xmark me-1"></i> Vắng</label>
                                                </div>
                                            </td>
                                            <td class="pe-4">
                                                <input type="text" name="listDiemDanh[@i].GhiChu" value="@Model[i].GhiChu" class="form-control border-2 shadow-none" placeholder="Nhập lý do vắng..." />
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted">Lớp học này hiện chưa có học viên nào.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="card-footer bg-white border-top p-4 d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow-sm">
                            <i class="fa-solid fa-floppy-disk me-2"></i> LƯU KẾT QUẢ ĐIỂM DANH
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>