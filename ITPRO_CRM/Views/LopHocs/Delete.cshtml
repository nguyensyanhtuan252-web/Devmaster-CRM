@model ITPRO_CRM.Models.LopHoc

@{
    ViewData["Title"] = "Xóa Lớp học";
}

<div class="container mt-5">
    <div class="card shadow border-danger">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0"><i class="fa-solid fa-triangle-exclamation"></i> Xác nhận Xóa Lớp học</h4>
        </div>
        <div class="card-body">
            <h5 class="card-title text-danger fw-bold">Bạn có chắc chắn muốn xóa lớp học này?</h5>
            <p class="card-text text-muted">Hành động này không thể hoàn tác. Dữ liệu học viên trong lớp sẽ bị ảnh hưởng.</p>

            <div class="alert alert-secondary">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Tên lớp:</dt>
                    <dd class="col-sm-9 fw-bold">@Model.TenLop</dd>

                    <dt class="col-sm-3">Ngày khai giảng:</dt>
                    <dd class="col-sm-9">@Model.NgayKhaiGiang.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-sm-3">Học phí:</dt>
                    <dd class="col-sm-9">@Model.HocPhi.ToString("#,##0") đ</dd>

                    <dt class="col-sm-3">Trạng thái:</dt>
                    <dd class="col-sm-9">
                        @if (Model.TrangThai == 1)
                        {
                            <span>Đang học</span>
                        }
                        else if (Model.TrangThai == 0)
                        {
                            <span>Sắp mở</span>
                        }
                        else
                        {
                            <span>Đã kết thúc</span>
                        }
                    </dd>
                </dl>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
                <button type="submit" class="btn btn-danger px-4">Xóa vĩnh viễn</button>
            </form>
        </div>
    </div>
</div>