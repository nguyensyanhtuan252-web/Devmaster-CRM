@{
    ViewData["Title"] = "Đổi mật khẩu bảo mật";
}

<style>
    /* 1. Nền trang riêng cho Security */
    .security-page {
        background: #f8f9fa;
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* 2. Thẻ Card trung tâm */
    .security-card {
        background: white;
        width: 100%;
        max-width: 480px;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.08);
        padding: 40px;
        border: 1px solid rgba(0,0,0,0.02);
    }

    /* 3. Icon ổ khóa đẹp */
    .lock-icon-wrapper {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
        color: #1565c0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        margin: 0 auto 25px;
        box-shadow: 0 5px 15px rgba(33, 150, 243, 0.2);
    }

    /* 4. Input Style hiện đại */
    .input-group-text {
        background: white;
        border-right: none;
        color: #6c757d;
    }

    .form-control-secure {
        border-left: none;
        border-right: none;
        padding: 12px 5px;
        font-size: 15px;
    }

        .form-control-secure:focus {
            box-shadow: none;
            border-color: #dee2e6;
        }
    /* Viền input khi focus sẽ đổi màu cả group */
    .input-group:focus-within {
        box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.15);
        border-radius: 8px;
        border-color: #0d6efd;
    }

    .input-group {
        border: 1px solid #dee2e6;
        border-radius: 8px;
        transition: all 0.2s;
        overflow: hidden;
    }

    /* 5. Nút con mắt (Show/Hide) */
    .btn-toggle-pass {
        background: white;
        border: none;
        border-left: none;
        color: #adb5bd;
        cursor: pointer;
        padding: 0 15px;
        transition: color 0.2s;
    }

        .btn-toggle-pass:hover {
            color: #0d6efd;
        }
</style>

<div class="security-page">
    <div class="security-card">

        <div class="text-center mb-4">
            <div class="lock-icon-wrapper">
                <i class="fa-solid fa-shield-halved"></i>
            </div>
            <h4 class="fw-bold text-dark">Đổi mật khẩu</h4>
            <p class="text-muted small">Để bảo vệ tài khoản, vui lòng không chia sẻ mật khẩu cho người lạ.</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success d-flex align-items-center rounded-3 mb-4" role="alert">
                <i class="fa-solid fa-circle-check me-2"></i>
                <div>@TempData["Success"]</div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger d-flex align-items-center rounded-3 mb-4" role="alert">
                <i class="fa-solid fa-triangle-exclamation me-2"></i>
                <div>@TempData["Error"]</div>
            </div>
        }

        <form asp-action="ChangePassword" method="post">

            <div class="mb-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Mật khẩu hiện tại</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fa-solid fa-key"></i></span>
                    <input type="password" name="MatKhauCu" class="form-control form-control-secure" id="passOld" placeholder="••••••" required>
                    <button type="button" class="btn-toggle-pass" onclick="togglePass('passOld', this)">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Mật khẩu mới</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                    <input type="password" name="MatKhauMoi" class="form-control form-control-secure" id="passNew" placeholder="Ít nhất 6 ký tự" required>
                    <button type="button" class="btn-toggle-pass" onclick="togglePass('passNew', this)">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold text-muted text-uppercase">Xác nhận mật khẩu</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fa-solid fa-check-double"></i></span>
                    <input type="password" name="XacNhanMatKhau" class="form-control form-control-secure" id="passConfirm" placeholder="Nhập lại mật khẩu mới" required>
                    <button type="button" class="btn-toggle-pass" onclick="togglePass('passConfirm', this)">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary py-2 fw-bold rounded-pill shadow-sm">
                    Xác nhận đổi mật khẩu
                </button>
                <a asp-action="Index" class="btn btn-light py-2 rounded-pill text-muted fw-bold mt-2">
                    Hủy bỏ & Quay lại
                </a>
            </div>
        </form>
    </div>
</div>

<script>
    function togglePass(inputId, btn) {
        const input = document.getElementById(inputId);
        const icon = btn.querySelector('i');

        if (input.type === "password") {
            input.type = "text";
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
        } else {
            input.type = "password";
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
        }
    }
</script>