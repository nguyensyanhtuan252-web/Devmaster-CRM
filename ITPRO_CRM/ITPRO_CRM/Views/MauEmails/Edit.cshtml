@model ITPRO_CRM.Models.MauEmail

@{
    ViewData["Title"] = "Chỉnh sửa mẫu Email";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Sora:wght@300;400;600;700&display=swap');

    .email-page {
        font-family: 'Sora', sans-serif;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 28px;
    }

    .page-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: #e2e8f0;
        margin: 0 0 4px;
        letter-spacing: -0.3px;
    }

    .page-subtitle {
        font-size: 0.78rem;
        color: #64748b;
        margin: 0;
    }

    .btn-back {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.09);
        border-radius: 9px;
        color: #94a3b8;
        font-family: 'Sora', sans-serif;
        font-size: 0.8rem;
        padding: 8px 16px;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        text-decoration: none;
        transition: background .2s, color .2s;
    }

        .btn-back:hover {
            background: rgba(255,255,255,0.09);
            color: #e2e8f0;
        }

    /* ── ID badge ── */
    .id-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(251,191,36,0.1);
        border: 1px solid rgba(251,191,36,0.2);
        border-radius: 8px;
        padding: 5px 12px;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.75rem;
        color: #fbbf24;
        margin-bottom: 20px;
    }

    /* ── Layout ── */
    .edit-grid {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 20px;
        align-items: start;
    }

    @@media (max-width: 900px) {
        .edit-grid {
            grid-template-columns: 1fr;
        }
    }

    /* ── Card ── */
    .card-dark {
        background: #1a1d2e;
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 14px;
        padding: 28px;
    }

    .card-section-title {
        font-size: 0.72rem;
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin: 0 0 18px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .card-section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(255,255,255,0.06);
        }

    /* ── Form controls ── */
    .mau-label {
        font-size: 0.74rem;
        font-weight: 600;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 7px;
        display: block;
    }

        .mau-label .required {
            color: #f87171;
            margin-left: 3px;
        }

    .mau-input {
        width: 100%;
        background: rgba(255,255,255,0.04) !important;
        border: 1px solid rgba(255,255,255,0.09) !important;
        color: #e2e8f0 !important;
        border-radius: 9px;
        padding: 10px 14px;
        font-family: 'Sora', sans-serif;
        font-size: 0.84rem;
        outline: none;
        transition: border-color .2s, background .2s;
    }

        .mau-input::placeholder {
            color: #334155;
        }

        .mau-input:focus {
            border-color: #f59e0b !important;
            background: rgba(245,158,11,0.05) !important;
            box-shadow: 0 0 0 3px rgba(245,158,11,0.1);
        }

    .field-hint {
        font-size: 0.73rem;
        color: #475569;
        margin-top: 5px;
    }

        .field-hint code {
            background: rgba(255,255,255,0.07);
            border-radius: 4px;
            padding: 1px 5px;
            font-family: 'IBM Plex Mono', monospace;
            font-size: 0.72rem;
            color: #93c5fd;
        }

    /* ── Loại mẫu ── */
    .loai-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
    }

    .loai-card {
        position: relative;
        cursor: pointer;
    }

        .loai-card input[type="radio"] {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

        .loai-card label {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            padding: 12px 8px;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 10px;
            cursor: pointer;
            font-size: 0.75rem;
            color: #64748b;
            text-align: center;
            transition: all .18s;
            line-height: 1.3;
        }

            .loai-card label i {
                font-size: 1.1rem;
            }

        .loai-card input:checked + label {
            border-color: currentColor;
            color: var(--ac);
            background: rgba(var(--ac-rgb), 0.08);
        }

    .loai-marketing {
        --ac: #34d399;
        --ac-rgb: 52,211,153;
    }

    .loai-taichinh {
        --ac: #fbbf24;
        --ac-rgb: 251,191,36;
    }

    .loai-thongbao {
        --ac: #60a5fa;
        --ac-rgb: 96,165,250;
    }

    .loai-khac {
        --ac: #a78bfa;
        --ac-rgb: 167,139,250;
    }

    /* ── Biến tags ── */
    .var-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 4px;
    }

    .var-tag {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.71rem;
        background: rgba(99,102,241,0.12);
        color: #a5b4fc;
        border: 1px solid rgba(99,102,241,0.2);
        border-radius: 5px;
        padding: 3px 8px;
        cursor: pointer;
        transition: background .15s;
        user-select: none;
    }

        .var-tag:hover {
            background: rgba(99,102,241,0.22);
        }

    /* ── Editor wrap ── */
    .editor-wrap {
        border-radius: 9px;
        border: 1px solid rgba(255,255,255,0.09);
        min-height: 200px;
        /* ĐÃ XÓA OVERFLOW HIDDEN Ở ĐÂY ĐỂ TRÁNH BỊ CẮT THANH CÔNG CỤ */
    }

        .editor-wrap:focus-within {
            border-color: #f59e0b;
            box-shadow: 0 0 0 3px rgba(245,158,11,0.1);
        }

    .cke_chrome {
        border: none !important;
        border-radius: 0 !important;
    }

    /* ── Buttons ── */
    .btn-group-form {
        display: flex;
        gap: 10px;
        margin-top: 4px;
    }

    .btn-save {
        flex: 1;
        background: linear-gradient(135deg, #d97706, #b45309);
        border: none;
        border-radius: 10px;
        color: #fff;
        font-family: 'Sora', sans-serif;
        font-size: 0.87rem;
        font-weight: 700;
        padding: 13px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        transition: opacity .2s, transform .15s;
        letter-spacing: 0.3px;
    }

        .btn-save:hover {
            opacity: .88;
            transform: translateY(-1px);
        }

    .btn-cancel {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.09);
        border-radius: 10px;
        color: #64748b;
        font-family: 'Sora', sans-serif;
        font-size: 0.84rem;
        padding: 13px 20px;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 7px;
        transition: background .2s, color .2s;
    }

        .btn-cancel:hover {
            background: rgba(255,255,255,0.09);
            color: #e2e8f0;
        }

    /* ── Meta card ── */
    .meta-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        font-size: 0.8rem;
    }

        .meta-row:last-child {
            border-bottom: none;
        }

    .meta-key {
        color: #475569;
    }

    .meta-val {
        color: #94a3b8;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.75rem;
    }

    /* ── Danger zone ── */
    .danger-zone {
        background: rgba(239,68,68,0.05);
        border: 1px solid rgba(239,68,68,0.15);
        border-radius: 12px;
        padding: 18px;
    }

    .danger-title {
        font-size: 0.72rem;
        font-weight: 700;
        color: #ef4444;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin: 0 0 12px;
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .btn-delete-link {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        width: 100%;
        background: rgba(239,68,68,0.1);
        border: 1px solid rgba(239,68,68,0.2);
        border-radius: 9px;
        color: #f87171;
        font-family: 'Sora', sans-serif;
        font-size: 0.82rem;
        font-weight: 600;
        padding: 10px;
        text-decoration: none;
        transition: background .2s;
    }

        .btn-delete-link:hover {
            background: rgba(239,68,68,0.18);
            color: #fca5a5;
        }

    .text-danger.small {
        font-size: 0.75rem;
        margin-top: 4px;
        display: block;
    }
</style>

<div class="email-page container-fluid mt-4">

    <div class="page-header">
        <div>
            <h5 class="page-title"><i class="fa-solid fa-pen-to-square text-warning me-2"></i>Chỉnh sửa mẫu Email</h5>
            <p class="page-subtitle">Cập nhật nội dung và thông tin mẫu email</p>
        </div>
        <a asp-action="Index" class="btn-back"><i class="fa-solid fa-arrow-left"></i> Danh sách</a>
    </div>

    <div class="id-badge">
        <i class="fa-solid fa-fingerprint"></i>
        ID: @Model.Id &nbsp;·&nbsp; Tạo lúc: @Model.NgayTao.ToString("dd/MM/yyyy HH:mm")
    </div>

    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="NgayTao" />

        <div class="edit-grid">

            <div style="display:flex;flex-direction:column;gap:18px;">

                <div class="card-dark">
                    <p class="card-section-title"><i class="fa-solid fa-circle-info" style="color:#fbbf24;"></i> Thông tin cơ bản</p>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
                        <div>
                            <label class="mau-label">Tên gợi nhớ <span class="required">*</span></label>
                            <input asp-for="TenMau" class="mau-input" placeholder="VD: Mau_Chao_Mung" />
                            <span asp-validation-for="TenMau" class="text-danger small"></span>
                            <p class="field-hint">Không dấu, không khoảng cách</p>
                        </div>

                        <div>
                            <label class="mau-label">Loại mẫu</label>
                            <input asp-for="LoaiMau" type="hidden" id="loaiMauInput" />
                            <div class="loai-grid">
                                <div class="loai-card loai-marketing">
                                    <input type="radio" name="_loai" id="r_mkt" value="Marketing" />
                                    <label for="r_mkt" style="color:var(--ac)"><i class="fa-solid fa-tag"></i> Marketing</label>
                                </div>
                                <div class="loai-card loai-taichinh">
                                    <input type="radio" name="_loai" id="r_tc" value="Tài chính" />
                                    <label for="r_tc" style="color:var(--ac)"><i class="fa-solid fa-circle-dollar-to-slot"></i> Tài chính</label>
                                </div>
                                <div class="loai-card loai-thongbao">
                                    <input type="radio" name="_loai" id="r_tb" value="Thông báo" />
                                    <label for="r_tb" style="color:var(--ac)"><i class="fa-solid fa-bell"></i> Thông báo</label>
                                </div>
                                <div class="loai-card loai-khac">
                                    <input type="radio" name="_loai" id="r_kh" value="Khác" />
                                    <label for="r_kh" style="color:var(--ac)"><i class="fa-solid fa-circle"></i> Khác</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="mau-label">Tiêu đề Email mặc định <span class="required">*</span></label>
                        <input asp-for="TieuDe" class="mau-input" id="subjectInput" placeholder="VD: [Devmaster] Chào mừng {{TenHocVien}}..." />
                        <span asp-validation-for="TieuDe" class="text-danger small"></span>
                        <p class="field-hint">Biến: <code>{{TenHocVien}}</code> <code>{{Thang}}</code> <code>{{NgayHetHan}}</code></p>
                    </div>
                </div>

                <div class="card-dark">
                    <p class="card-section-title"><i class="fa-solid fa-code" style="color:#a78bfa;"></i> Nội dung mẫu</p>

                    <div style="margin-bottom:12px;">
                        <label class="mau-label">Chèn biến nhanh</label>
                        <div class="var-tags">
                            <span class="var-tag" data-var="{{TenHocVien}}">{{TenHocVien}}</span>
                            <span class="var-tag" data-var="{{Thang}}">{{Thang}}</span>
                            <span class="var-tag" data-var="{{SoTien}}">{{SoTien}}</span>
                            <span class="var-tag" data-var="{{NgayHetHan}}">{{NgayHetHan}}</span>
                            <span class="var-tag" data-var="{{TenKhoaHoc}}">{{TenKhoaHoc}}</span>
                            <span class="var-tag" data-var="{{LienHe}}">{{LienHe}}</span>
                        </div>
                    </div>

                    <div class="editor-wrap">
                        <textarea asp-for="NoiDung" id="editor_template"></textarea>
                    </div>
                    <span asp-validation-for="NoiDung" class="text-danger small"></span>
                </div>

                <div class="btn-group-form">
                    <button type="submit" class="btn-save">
                        <i class="fa-solid fa-floppy-disk"></i> LƯU THAY ĐỔI
                    </button>
                    <a asp-action="Index" class="btn-cancel">
                        <i class="fa-solid fa-xmark"></i> Huỷ
                    </a>
                </div>

            </div>

            <div style="display:flex;flex-direction:column;gap:18px;">

                <div class="card-dark">
                    <p class="card-section-title"><i class="fa-solid fa-circle-info" style="color:#60a5fa;"></i> Thông tin bản ghi</p>
                    <div class="meta-row">
                        <span class="meta-key">ID</span>
                        <span class="meta-val">#@Model.Id</span>
                    </div>
                    <div class="meta-row">
                        <span class="meta-key">Ngày tạo</span>
                        <span class="meta-val">@Model.NgayTao.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="meta-row">
                        <span class="meta-key">Giờ tạo</span>
                        <span class="meta-val">@Model.NgayTao.ToString("HH:mm")</span>
                    </div>
                    <div class="meta-row">
                        <span class="meta-key">Loại hiện tại</span>
                        <span class="meta-val" id="currentLoai">@Model.LoaiMau</span>
                    </div>
                </div>

                <div class="card-dark">
                    <p class="card-section-title"><i class="fa-solid fa-eye" style="color:#34d399;"></i> Xem trước tiêu đề</p>
                    <div style="background:#0f1117;border-radius:9px;padding:14px;border:1px solid rgba(255,255,255,0.05);">
                        <div style="font-size:0.72rem;color:#475569;margin-bottom:6px;font-family:'IBM Plex Mono',monospace;">
                            Hộp thư đến →
                        </div>
                        <div id="prevSubject" style="font-weight:600;color:#e2e8f0;font-size:0.83rem;word-break:break-all;">
                            @Model.TieuDe
                        </div>
                        <div style="font-size:0.72rem;color:#334155;margin-top:6px;">
                            from: no-reply@devmaster.vn
                        </div>
                    </div>
                </div>

                <div class="danger-zone">
                    <p class="danger-title"><i class="fa-solid fa-triangle-exclamation"></i> Vùng nguy hiểm</p>
                    <p style="font-size:0.77rem;color:#64748b;margin-bottom:12px;line-height:1.5;">
                        Xoá mẫu email này khỏi hệ thống. Hành động không thể hoàn tác.
                    </p>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-delete-link">
                        <i class="fa-solid fa-trash"></i> Xoá mẫu này
                    </a>
                </div>

            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdnjs.cloudflare.com/ajax/libs/ckeditor/4.22.1/ckeditor.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            try {
                // 1. Kiểm tra xem thư viện đã được tải về máy chưa
                if (typeof CKEDITOR === 'undefined') {
                    alert("LỖI: Trình duyệt không tải được CKEditor. Vui lòng tắt phần mềm chặn quảng cáo (AdBlock) hoặc kiểm tra lại mạng!");
                    return;
                }

                // 2. Khởi tạo CKEditor Mặc Định (Tự động bung Full tất cả các nút công cụ, không tự custom để tránh lỗi)
                CKEDITOR.replace('editor_template', {
                    height: 450
                });

                // 3. Cập nhật dữ liệu CKEditor vào textarea trước khi nhấn LƯU
                var form = document.querySelector('form');
                if (form) {
                    form.addEventListener('submit', function() {
                        for (var instanceName in CKEDITOR.instances) {
                            CKEDITOR.instances[instanceName].updateElement();
                        }
                    });
                }

                // 4. Đồng bộ Radio Button Loại Mẫu (Xử lý an toàn)
                var currentLoai = '@Html.Raw(Model?.LoaiMau ?? "")';
                document.querySelectorAll('input[name="_loai"]').forEach(function (r) {
                    if (r.value === currentLoai) r.checked = true;

                    r.addEventListener('change', function () {
                        var loaiInput = document.getElementById('loaiMauInput');
                        var loaiLabel = document.getElementById('currentLoai');
                        if (loaiInput) loaiInput.value = this.value;
                        if (loaiLabel) loaiLabel.textContent = this.value;
                    });
                });

                // 5. Live preview Tiêu đề
                var subjectInput = document.getElementById('subjectInput');
                var prevSubject  = document.getElementById('prevSubject');
                if (subjectInput && prevSubject) {
                    subjectInput.addEventListener('input', function () {
                        prevSubject.textContent = this.value || '(Chưa có tiêu đề)';
                    });
                }

                // 6. Click copy Biến nhanh
                document.querySelectorAll('.var-tag').forEach(function (tag) {
                    tag.addEventListener('click', function () {
                        navigator.clipboard.writeText(this.dataset.var).catch(function () {});
                        this.style.background = 'rgba(99,102,241,0.35)';
                        var self = this;
                        setTimeout(function () { self.style.background = ''; }, 600);
                    });
                });

            } catch (error) {
                // Nếu code bị lỗi, bắt nó báo ra màn hình ngay!
                alert("Đã xảy ra lỗi hệ thống: " + error.message);
                console.error(error);
            }
        });
    </script>
}