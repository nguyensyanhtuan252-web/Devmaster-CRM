@using ITPRO_CRM.Models
@using Microsoft.AspNetCore.Http
@model IEnumerable<ITPRO_CRM.Models.PhieuThu>

@{
    ViewData["Title"] = "Quản lý Tài chính";
    var tongDoanhThu = Model.Sum(x => x.SoTien);
    var giaoDichHomNay = Model.Count(x => x.NgayThu.Date == DateTime.Now.Date);

    // Lấy quyền từ Session
    var currentRole = Context.Session.GetInt32("VaiTro");
}

<style>
    /* Đồng bộ thẻ thống kê với trang Học viên */
    .stat-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-bottom: 20px;
    }

    .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 16px 20px;
        position: relative;
        overflow: hidden;
        transition: 0.2s;
    }

        .stat-card:hover {
            transform: translateY(-2px);
            border-color: var(--border2);
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
        }

        .stat-card.c-accent::before {
            background: var(--accent);
        }

        .stat-card.c-success::before {
            background: var(--success);
        }

        .stat-card.c-warning::before {
            background: var(--warning);
        }

    .stat-lbl {
        font-size: 10px;
        font-weight: 600;
        color: var(--text3);
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 8px;
    }

    .stat-val {
        font-size: 24px;
        font-weight: 700;
        color: var(--text);
        font-family: 'DM Mono', monospace;
        line-height: 1;
    }

    .stat-icon {
        position: absolute;
        right: 20px;
        bottom: 15px;
        font-size: 32px;
        opacity: 0.05;
        color: var(--text);
    }

    /* Nút bấm trên Toolbar */
    .dm-btn {
        background: var(--surface2);
        border: 1px solid var(--border);
        color: var(--text2);
        font-size: 12px;
        font-weight: 600;
        padding: 7px 14px;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: 0.15s;
        text-decoration: none;
        cursor: pointer;
    }

        .dm-btn:hover {
            background: var(--border);
            color: var(--text);
        }

        .dm-btn.pri {
            background: var(--accent);
            color: #fff;
            border-color: var(--accent);
        }

            .dm-btn.pri:hover {
                background: #2563eb;
                color: #fff;
            }

        .dm-btn.suc {
            background: rgba(63,185,80,0.1);
            color: var(--success);
            border-color: rgba(63,185,80,0.2);
        }

            .dm-btn.suc:hover {
                background: rgba(63,185,80,0.2);
            }

    /* Bảng dữ liệu tối giản */
    .dm-table-wrap {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
    }

    .dm-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12.5px;
    }

        .dm-table th {
            background: var(--surface2);
            color: var(--text3);
            font-weight: 600;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 12px 16px;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

            /* Hiệu ứng con trỏ chuột cho tiêu đề Ngày nộp */
            .dm-table th.sortable {
                cursor: pointer;
                transition: 0.2s;
                user-select: none;
            }

                .dm-table th.sortable:hover {
                    color: var(--accent);
                    background: var(--surface);
                }

        .dm-table td {
            padding: 12px 16px;
            border-bottom: 1px solid var(--border);
            color: var(--text2);
            vertical-align: middle;
        }

        .dm-table tr:last-child td {
            border-bottom: none;
        }

        .dm-table tr:hover td {
            background: var(--surface2);
            color: var(--text);
        }

    .av-circle {
        width: 28px;
        height: 28px;
        background: var(--surface2);
        border: 1px solid var(--border);
        color: var(--accent);
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 11px;
        flex-shrink: 0;
    }

    .text-money {
        font-family: 'DM Mono', monospace;
        font-weight: 700;
        color: var(--success);
        font-size: 13.5px;
    }

    .act-btn {
        width: 26px;
        height: 26px;
        border-radius: 5px;
        border: 1px solid var(--border);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--text2);
        font-size: 11px;
        transition: 0.1s;
        text-decoration: none;
        background: transparent;
        cursor: pointer;
    }

        .act-btn:hover {
            background: var(--surface2);
            color: var(--text);
            border-color: var(--border2);
        }

        .act-btn.d:hover {
            background: rgba(239,68,68,0.1);
            color: var(--danger);
            border-color: var(--danger);
        }

        .act-btn.p:hover {
            background: rgba(59,130,246,0.1);
            color: var(--accent);
            border-color: var(--accent);
        }

    .dm-pill {
        font-size: 10px;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 4px;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .pill-cash {
        background: rgba(245,158,11,0.1);
        color: var(--warning);
        border: 1px solid rgba(245,158,11,0.2);
    }

    .pill-bank {
        background: rgba(59,130,246,0.1);
        color: var(--accent);
        border: 1px solid rgba(59,130,246,0.2);
    }

    /* Ô input tìm kiếm */
    .dm-input-search {
        background: var(--surface2);
        border: 1px solid var(--border);
        color: var(--text);
        font-size: 12px;
        padding: 7px 12px;
        border-radius: 6px;
        outline: none;
        transition: 0.2s;
    }

        .dm-input-search:focus {
            border-color: var(--accent);
        }

        .dm-input-search::placeholder {
            color: var(--text3);
        }
</style>

<div class="container-fluid py-4">
    <div class="stat-row">
        <div class="stat-card c-accent">
            <div class="stat-lbl">Doanh thu <span id="lblDoanhThu">tổng</span></div>
            <div class="stat-val" id="valTongDoanhThu" style="color: var(--accent);">@(tongDoanhThu.ToString("N0")) đ</div>
            <i class="fa-solid fa-sack-dollar stat-icon"></i>
        </div>
        <div class="stat-card c-success">
            <div class="stat-lbl">Giao dịch <span id="lblGiaoDich">hôm nay</span></div>
            <div class="stat-val"><span id="valGiaoDich">@giaoDichHomNay</span> <span style="font-size: 12px; font-weight: 500; color: var(--text3); font-family: 'DM Sans', sans-serif;">phiếu</span></div>
            <i class="fa-solid fa-calendar-day stat-icon"></i>
        </div>
        <div class="stat-card c-warning">
            <div class="stat-lbl">Công nợ (Dự kiến)</div>
            <div class="stat-val" style="color: var(--warning);">
                @(((decimal)(ViewBag.CongNo ?? 0)).ToString("N0")) đ
            </div>
            <i class="fa-solid fa-file-invoice-dollar stat-icon"></i>
        </div>
    </div>

    <div class="dm-table-wrap">
        <div class="d-flex justify-content-between align-items-center p-3 border-bottom flex-wrap gap-2" style="border-color: var(--border) !important;">

            <div class="d-flex align-items-center gap-2">
                <i class="fa-solid fa-magnifying-glass" style="color: var(--text3);"></i>
                <input type="text" id="txtSearch" class="dm-input-search" style="width: 300px;" placeholder="Tìm mã phiếu, học viên, nội dung..." onkeyup="applyFilters()">
            </div>

            <div class="d-flex gap-2">
                <a href="@Url.Action("ExportExcel", "PhieuThus")" class="dm-btn suc" id="btnExport" onclick="exportExcel(event)"><i class="fa-solid fa-file-excel"></i> Xuất Excel</a>

                @if (currentRole == (int)LoaiVaiTro.Admin || currentRole == (int)LoaiVaiTro.KeToan)
                {
                    <a asp-action="Create" class="dm-btn pri"><i class="fa-solid fa-plus"></i> Tạo Phiếu thu</a>
                }
            </div>
        </div>

        <div style="overflow-x: auto;">
            <table class="dm-table">
                <thead>
                    <tr>
                        <th class="ps-4">Mã phiếu</th>
                        <th>Học viên / Người nộp</th>
                        <th>Nội dung thu</th>
                        <th>Số tiền</th>
                        <th>Hình thức</th>

                        <th class="sortable" onclick="sortTable()" title="Bấm để sắp xếp theo ngày nộp">
                            Ngày nộp <i class="fa-solid fa-sort-down ms-1" id="sortIcon" style="color: var(--accent);"></i>
                        </th>

                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="tblBody">
                    @foreach (var item in Model)
                    {
                        <tr class="tbl-row" data-money="@item.SoTien" data-date="@item.NgayThu.ToString("yyyyMMddHHmmss")">
                            <td class="ps-4" style="font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 600;">#@item.MaPhieu</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="av-circle">@(item.HocVien?.HoTen?.Substring(0, 1) ?? "K")</div>
                                    <div>
                                        <div style="font-weight: 600; color: var(--text); font-size: 12.5px;">@(item.HocVien?.HoTen ?? "Khách vãng lai")</div>
                                        <div style="font-size: 10px; color: var(--text3);"><i class="fa-solid fa-book-open me-1"></i> @(item.LopHoc?.TenLop ?? "Chưa xếp lớp")</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="d-inline-block text-truncate" style="max-width: 200px; font-size: 12px; color: var(--text);" title="@item.NoiDung">
                                    @item.NoiDung
                                </span>
                            </td>
                            <td>
                                <span class="text-money">@item.SoTien.ToString("N0") <span style="font-size: 10px; font-weight: 500; color: var(--text3);">đ</span></span>
                            </td>
                            <td>
                                @if (item.HinhThuc == 1)
                                {
                                    <span class="dm-pill pill-bank"><i class="fa-solid fa-building-columns"></i> Chuyển khoản</span>
                                }
                                else
                                {
                                    <span class="dm-pill pill-cash"><i class="fa-solid fa-money-bill-wave"></i> Tiền mặt</span>
                                }
                            </td>
                            <td>
                                <div style="color: var(--text); font-size: 11.5px; font-family: 'DM Mono', monospace; font-weight: 500;">@(item.NgayThu.ToString("dd/MM/yyyy"))</div>
                                <div style="font-size: 10px; color: var(--text3);">Thu bởi: @(item.NguoiThu ?? "Admin")</div>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-1">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="act-btn p" title="In / Chi tiết"><i class="fa-solid fa-print"></i></a>

                                    @if (currentRole == (int)LoaiVaiTro.Admin || currentRole == (int)LoaiVaiTro.KeToan)
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="act-btn" title="Sửa"><i class="fa-solid fa-pen"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="act-btn d" title="Xóa"><i class="fa-solid fa-trash"></i></a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="p-3 bg-transparent d-flex justify-content-between align-items-center" style="border-top: 1px solid var(--border);">
            <span id="lblCountBottom" style="font-size: 11px; color: var(--text3);">Hiển thị @Model.Count() giao dịch mới nhất</span>
            <div class="d-flex gap-1">
                <button class="act-btn" disabled><i class="fa-solid fa-chevron-left"></i></button>
                <button class="act-btn" style="background: var(--surface2); color: var(--text); border-color: var(--border2);">1</button>
                <button class="act-btn"><i class="fa-solid fa-chevron-right"></i></button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // HÀM LOẠI BỎ DẤU TIẾNG VIỆT
        function removeAccents(str) {
            if (!str) return '';
            return str.normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/đ/g, 'd').replace(/Đ/g, 'D').toLowerCase();
        }

        // TÌM KIẾM VÀ TÍNH TỔNG TIỀN REAL-TIME
        function applyFilters() {
            var q = removeAccents(document.getElementById('txtSearch').value);
            var rows = document.querySelectorAll('.tbl-row');
            var totalMoney = 0;
            var visibleCount = 0;

            for (var i = 0; i < rows.length; i++) {
                var row = rows[i];
                var textContent = removeAccents(row.textContent || row.innerText);
                var money = parseFloat(row.getAttribute('data-money')) || 0;

                if (q === '' || textContent.includes(q)) {
                    row.style.display = '';
                    totalMoney += money;
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            }

            document.getElementById('lblDoanhThu').innerText = (q !== '') ? "đang lọc" : "tổng";
            document.getElementById('lblGiaoDich').innerText = (q !== '') ? "đang hiển thị" : "hôm nay";

            document.getElementById('valTongDoanhThu').innerText = totalMoney.toLocaleString('vi-VN') + " đ";
            document.getElementById('valGiaoDich').innerText = visibleCount;
            document.getElementById('lblCountBottom').innerText = "Hiển thị " + visibleCount + " giao dịch";
        }

        // HÀM SẮP XẾP DANH SÁCH LÊN/XUỐNG THEO NGÀY
        let sortDesc = true; // Mặc định là danh sách đang xếp Mới nhất (Giảm dần)

        function sortTable() {
            sortDesc = !sortDesc; // Đảo chiều trạng thái

            const tbody = document.getElementById('tblBody');
            const rows = Array.from(tbody.querySelectorAll('.tbl-row'));
            const icon = document.getElementById('sortIcon');

            // Đổi giao diện Icon
            icon.className = sortDesc ? 'fa-solid fa-sort-down ms-1' : 'fa-solid fa-sort-up ms-1';

            // Tiến hành sắp xếp mảng dựa trên thuộc tính data-date
            rows.sort((a, b) => {
                let valA = a.getAttribute('data-date');
                let valB = b.getAttribute('data-date');

                return sortDesc ? valB.localeCompare(valA) : valA.localeCompare(valB);
            });

            // Gắn lại các thẻ HTML đã sắp xếp vào Bảng
            rows.forEach(row => tbody.appendChild(row));
        }

        // XUẤT EXCEL CHỈ BAO GỒM NHỮNG GÌ ĐANG TÌM KIẾM
        function exportExcel(e) {
            e.preventDefault(); // Chặn việc chuyển trang ngay lập tức
            var q = document.getElementById('txtSearch').value;

            // Xây dựng URL
            var url = '@Url.Action("ExportExcel", "PhieuThus")';
            if (q !== '') {
                url += '?search=' + encodeURIComponent(q);
            }

            // Điều hướng để tải file
            window.location.href = url;
        }
    </script>
}