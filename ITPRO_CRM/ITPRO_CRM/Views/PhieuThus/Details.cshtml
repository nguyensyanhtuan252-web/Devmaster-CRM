@model ITPRO_CRM.Models.PhieuThu

@{
    ViewData["Title"] = "Chi tiết Phiếu thu";
}

<style>
    /* CSS hiển thị trên Web (Dark/Light Mode) */
    .receipt-container {
        max-width: 650px;
        margin: 0 auto;
        position: relative;
    }

    .receipt-box {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 40px;
        box-shadow: var(--shadow);
        color: var(--text);
        position: relative;
        overflow: hidden;
    }

    /* Con dấu (Watermark) ĐÃ THU TIỀN */
    .watermark-stamp {
        position: absolute;
        top: 180px;
        right: 40px;
        color: rgba(239, 68, 68, 0.15); /* Màu đỏ mờ */
        font-size: 45px;
        font-weight: 800;
        text-transform: uppercase;
        transform: rotate(-15deg);
        border: 4px solid rgba(239, 68, 68, 0.15);
        padding: 10px 20px;
        border-radius: 10px;
        pointer-events: none;
        user-select: none;
    }

    .r-title {
        font-size: 20px;
        font-weight: 800;
        color: var(--text);
        letter-spacing: 1px;
        margin-bottom: 2px;
    }

    .r-sub {
        font-size: 11px;
        color: var(--text3);
        margin-bottom: 2px;
    }

    .r-head-right {
        text-align: right;
    }

        .r-head-right h3 {
            color: var(--accent);
            font-weight: 800;
            font-size: 18px;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

    .r-code {
        font-family: 'DM Mono', monospace;
        font-size: 12px;
        font-weight: 600;
        color: var(--text);
        background: var(--surface2);
        padding: 2px 8px;
        border-radius: 4px;
    }

    .r-divider {
        border-top: 2px dashed var(--border);
        margin: 25px 0;
    }

    .r-lbl {
        font-size: 10px;
        font-weight: 700;
        color: var(--text3);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 6px;
    }

    .r-val {
        font-size: 13.5px;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 12px;
    }

    .r-money {
        font-size: 22px;
        font-weight: 800;
        color: var(--success);
        font-family: 'DM Mono', monospace;
        line-height: 1;
        margin-bottom: 8px;
    }

    .r-box-desc {
        background: var(--surface2);
        border-left: 3px solid var(--accent);
        padding: 12px 16px;
        border-radius: 0 6px 6px 0;
        margin-top: 10px;
    }

    .dm-btn-back {
        background: var(--surface2);
        border: 1px solid var(--border);
        color: var(--text2);
        font-size: 12px;
        font-weight: 600;
        padding: 8px 16px;
        border-radius: 8px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: 0.2s;
    }

        .dm-btn-back:hover {
            background: var(--border);
            color: var(--text);
        }

    .dm-btn-print {
        background: var(--accent);
        color: #fff;
        font-size: 12px;
        font-weight: 600;
        padding: 8px 20px;
        border-radius: 8px;
        border: none;
        transition: 0.2s;
    }

        .dm-btn-print:hover {
            background: #2563eb;
        }

    /* CSS khi bấm In (Ctrl+P) - Ép về Trắng / Đen chuyên nghiệp */
    @@media print {
        .sidebar, header, footer, .dm-btn-back, .dm-btn-print, .no-print {
            display: none !important;
        }

        body, .container-fluid, .main-wrap, .page-content {
            background-color: white !important;
            padding: 0 !important;
            margin: 0 !important;
        }

        .receipt-container {
            max-width: 100% !important;
        }

        .receipt-box {
            border: none !important;
            box-shadow: none !important;
            padding: 0 !important;
            color: black !important;
        }

        .r-title, .r-val, .r-money {
            color: black !important;
        }

        .r-head-right h3 {
            color: black !important;
        }

        .r-sub, .r-lbl {
            color: #555 !important;
        }

        .r-code {
            background: #f0f0f0 !important;
            border: 1px solid #ccc !important;
        }

        .r-divider {
            border-top: 1px dashed #aaa !important;
        }

        .r-box-desc {
            background: #f9f9f9 !important;
            border-left: 3px solid #666 !important;
        }

        .watermark-stamp {
            color: rgba(255, 0, 0, 0.2) !important;
            border-color: rgba(255, 0, 0, 0.2) !important;
        }
    }
</style>

<div class="container py-4">
    <div class="receipt-container">
        <div class="d-flex justify-content-between mb-4 no-print">
            <a asp-action="Index" class="dm-btn-back"><i class="fa-solid fa-arrow-left me-2"></i> Quay lại</a>
            <button onclick="window.print()" class="dm-btn-print"><i class="fa-solid fa-print me-2"></i> IN BIÊN LAI</button>
        </div>

        <div class="receipt-box">
            <div class="watermark-stamp">ĐÃ THU TIỀN</div>

            <div class="row align-items-center">
                <div class="col-7">
                    <div class="r-title"><i class="fa-solid fa-graduation-cap me-1"></i> ITPRO ACADEMY</div>
                    <div class="r-sub">Trụ sở: Số 1 Đại Cồ Việt, Hai Bà Trưng, Hà Nội</div>
                    <div class="r-sub">Hotline: 0988.888.888 | Web: itpro.edu.vn</div>
                </div>
                <div class="col-5 r-head-right">
                    <h3>BIÊN LAI THU TIỀN</h3>
                    <div class="r-sub mb-1">Mã phiếu: <span class="r-code">@Model.MaPhieu</span></div>
                    <div class="r-sub">Ngày lập: <span style="font-weight:600; color:var(--text);">@(Model.NgayThu.ToString("dd/MM/yyyy"))</span></div>
                </div>
            </div>

            <div class="r-divider"></div>

            <div class="row">
                <div class="col-sm-6">
                    <div class="r-lbl">Họ tên người nộp tiền</div>
                    <div class="r-val" style="font-size: 16px; color: var(--accent);">@Model.HocVien?.HoTen</div>

                    <div class="r-lbl">Mã học viên</div>
                    <div class="r-val" style="font-family: 'DM Mono', monospace;">HV@(Model.HocVienId.ToString("D4"))</div>

                    <div class="r-lbl">Lớp học đăng ký</div>
                    <div class="r-val">@(Model.LopHoc?.TenLop ?? "Thu khác / Không gắn lớp")</div>
                </div>

                <div class="col-sm-6 text-end">
                    <div class="r-lbl">Số tiền thanh toán</div>
                    <div class="r-money">@(Model.SoTien.ToString("#,##0")) <span style="font-size: 14px;">VNĐ</span></div>

                    <div class="r-lbl">Hình thức thanh toán</div>
                    <div class="r-val">
                        @if (Model.HinhThuc == 0)
                        {
                            <span>Tiền mặt</span>
                        }
                        else
                        {
                            <span>Chuyển khoản</span>
                        }
                    </div>

                    <div class="r-lbl">Thu ngân viên</div>
                    <div class="r-val">@(Model.NguoiThu ?? "Admin")</div>
                </div>
            </div>

            <div class="r-box-desc mt-2">
                <div class="r-lbl" style="margin-bottom: 2px;">Lý do nộp tiền</div>
                <div style="font-size: 13px; font-style: italic; line-height: 1.5; color: var(--text);">@Model.NoiDung</div>
            </div>

            <div class="row mt-5 pt-3 text-center">
                <div class="col-6">
                    <div style="font-size: 12px; font-weight: 700; color: var(--text); text-transform: uppercase;">Người nộp tiền</div>
                    <div style="font-size: 10px; color: var(--text3); font-style: italic;">(Ký, ghi rõ họ tên)</div>
                    <div style="height: 90px;"></div>
                </div>
                <div class="col-6">
                    <div style="font-size: 12px; font-weight: 700; color: var(--text); text-transform: uppercase;">Người lập phiếu</div>
                    <div style="font-size: 10px; color: var(--text3); font-style: italic;">(Ký, ghi rõ họ tên)</div>
                    <div style="height: 90px;"></div>
                    <div style="font-size: 13px; font-weight: 600; color: var(--text);">@Model.NguoiThu</div>
                </div>
            </div>

            <div class="text-center mt-4 pt-3" style="border-top: 1px dashed var(--border);">
                <span style="font-size: 11px; font-style: italic; color: var(--text3);">Cảm ơn quý khách đã tin tưởng và sử dụng dịch vụ của ITPRO Academy!</span>
            </div>
        </div>
    </div>
</div>