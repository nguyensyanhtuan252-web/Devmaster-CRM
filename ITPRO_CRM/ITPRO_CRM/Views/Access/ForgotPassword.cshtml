@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên mật khẩu — ITPRO CRM</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --form-bg: #f5f7fc;
            --card-bg: #ffffff;
            --form-border: rgba(0,0,0,0.06);
            --form-text: #0f1629;
            --form-muted: #7a84a0;
            --form-hint: #b0b8d4;
            --label-clr: #6b78a0;
            --input-bg: #f2f4fb;
            --input-bg-f: #ffffff;
            --input-border: #dde1ef;
            --input-border-f: #2d5be3;
            --input-shadow-f: rgba(45,91,227,0.13);
            --input-text: #0f1629;
            --btn-bg: #1636c6;
            --btn-hover: #0f28a8;
            --btn-shadow: rgba(22,54,198,0.32);
            --error-bg: rgba(239,68,68,0.07);
            --error-bdr: rgba(239,68,68,0.22);
            --error-clr: #c0392b;
            --link-clr: #2d5be3;
            --logo-bg: rgba(22,54,198,0.10);
            --logo-clr: #1636c6;
            --shadow: 0 10px 40px rgba(0,0,0,0.08);
        }

        [data-theme="dark"] {
            --form-bg: #0d1117;
            --card-bg: #161b27;
            --form-border: rgba(255,255,255,0.05);
            --form-text: #e4eaf8;
            --form-muted: #7a88b0;
            --form-hint: #3d4a68;
            --label-clr: #606b8f;
            --input-bg: #1a2440;
            --input-bg-f: #1f2b4a;
            --input-border: rgba(255,255,255,0.08);
            --input-border-f: #4f8ef7;
            --input-shadow-f: rgba(79,142,247,0.15);
            --input-text: #ccd5f0;
            --btn-bg: #2d5be3;
            --btn-hover: #4f8ef7;
            --btn-shadow: rgba(45,91,227,0.28);
            --error-bg: rgba(239,68,68,0.10);
            --error-bdr: rgba(239,68,68,0.25);
            --error-clr: #f87171;
            --link-clr: #7fb3ff;
            --logo-bg: rgba(79,142,247,0.12);
            --logo-clr: #7fb3ff;
            --shadow: 0 10px 40px rgba(0,0,0,0.3);
        }

        html, body {
            height: 100%;
            font-family: 'Inter', sans-serif;
            background: var(--form-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            -webkit-font-smoothing: antialiased;
            transition: background 0.3s ease;
        }

        .form-box {
            width: 100%;
            max-width: 420px;
            background: var(--card-bg);
            padding: 40px 32px;
            border-radius: 20px;
            border: 1px solid var(--form-border);
            box-shadow: var(--shadow);
            animation: riseUp 0.4s cubic-bezier(0.16,1,0.3,1) both;
            margin: 20px;
        }

        @@keyframes riseUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .form-logo-wrap {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            background: var(--logo-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            transition: background 0.3s ease;
        }

            .form-logo-wrap i {
                font-size: 22px;
                color: var(--logo-clr);
                transition: color 0.3s;
            }

        .form-greeting {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--form-text);
            margin-bottom: 8px;
            text-align: center;
            letter-spacing: -0.3px;
        }

        .form-sub {
            font-size: 0.85rem;
            color: var(--form-muted);
            margin-bottom: 28px;
            line-height: 1.5;
            text-align: center;
        }

        .login-error {
            background: var(--error-bg);
            border: 1px solid var(--error-bdr);
            border-radius: 11px;
            padding: 12px 15px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 13px;
            color: var(--error-clr);
            font-weight: 500;
            margin-bottom: 22px;
        }

        .field-wrap {
            margin-bottom: 20px;
        }

        .field-label {
            display: block;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.65px;
            text-transform: uppercase;
            color: var(--label-clr);
            margin-bottom: 8px;
        }

        .field-row {
            display: flex;
            align-items: center;
            background: var(--input-bg);
            border: 1px solid var(--input-border);
            border-radius: 12px;
            overflow: hidden;
            transition: all 0.22s ease;
        }

            .field-row:focus-within {
                background: var(--input-bg-f);
                border-color: var(--input-border-f);
                box-shadow: 0 0 0 4px var(--input-shadow-f);
            }

        .field-icon {
            padding: 0 14px;
            color: var(--form-hint);
            font-size: 14px;
        }

        .field-row:focus-within .field-icon {
            color: var(--input-border-f);
        }

        .field-input {
            flex: 1;
            border: none;
            background: transparent;
            padding: 13px 14px 13px 0;
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            color: var(--input-text);
            outline: none;
        }

            .field-input::placeholder {
                color: var(--form-hint);
            }

        .btn-login {
            width: 100%;
            padding: 13.5px 20px;
            border: none;
            border-radius: 12px;
            background: var(--btn-bg);
            color: #fff;
            font-size: 14px;
            font-weight: 700;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 9px;
            box-shadow: 0 5px 20px var(--btn-shadow);
            transition: all 0.22s ease;
            margin-bottom: 24px;
        }

            .btn-login:hover {
                background: var(--btn-hover);
                transform: translateY(-2px);
                box-shadow: 0 8px 28px var(--btn-shadow);
            }

        .form-footer {
            text-align: center;
            font-size: 13px;
            color: var(--form-muted);
        }

            .form-footer a {
                color: var(--link-clr);
                text-decoration: none;
                font-weight: 600;
            }

                .form-footer a:hover {
                    opacity: 0.8;
                }
    </style>
</head>
<body>

    <div class="form-box">
        <div class="form-logo-wrap">
            <i class="fa-solid fa-key"></i>
        </div>

        <h2 class="form-greeting">Quên mật khẩu?</h2>
        <p class="form-sub">Nhập email được liên kết với tài khoản của bạn để nhận đường dẫn đặt lại mật khẩu.</p>

        @if (ViewBag.Message != null)
        {
            <div class="login-error" style="background: rgba(16,185,129,0.1); border-color: rgba(16,185,129,0.25); color: #10b981;">
                <i class="fa-solid fa-circle-check"></i>
                <span>@ViewBag.Message</span>
            </div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="login-error">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span>@ViewBag.Error</span>
            </div>
        }

        <form asp-action="ForgotPassword" method="post">
            <div class="field-wrap">
                <label class="field-label">Email tài khoản</label>
                <div class="field-row">
                    <span class="field-icon"><i class="fa-regular fa-envelope"></i></span>
                    <input type="email" name="email" class="field-input" placeholder="nhanvien@itpro.vn" required autofocus />
                </div>
            </div>

            <button type="submit" class="btn-login">
                <i class="fa-solid fa-paper-plane"></i> Gửi link khôi phục
            </button>

            <div class="form-footer">
                Nhớ lại mật khẩu? <a asp-controller="Access" asp-action="Login">Quay lại đăng nhập</a>
            </div>
        </form>
    </div>

    <script>
        const html = document.documentElement;
        const savedTheme = localStorage.getItem('dm_theme') || 'dark';
        html.setAttribute('data-theme', savedTheme);
    </script>
</body>
</html>