@section Scripts {
    <script>
        var STATUS = parseInt('@status') || 0;
        var curFilter = 'all';

        // Fix lỗi mờ Modal
        document.addEventListener("DOMContentLoaded", function () {
            var modalExcel = document.getElementById('importModal');
            if (modalExcel) document.body.appendChild(modalExcel);
        });

        function downloadTemplate() {
            window.location.href = '@Url.Action("DownloadTemplate", "HocViens")';
        }

        // HÀM LOẠI BỎ DẤU TIẾNG VIỆT (Giúp gõ "tuan" vẫn ra "Tuấn")
        function removeAccents(str) {
            if (!str) return '';
            return str.normalize('NFD')
                      .replace(/[\u0300-\u036f]/g, '')
                      .replace(/đ/g, 'd').replace(/Đ/g, 'D')
                      .toLowerCase();
        }

        function setFilter(f, card) {
            curFilter = f;
            var cards = document.querySelectorAll('.stat-card');
            for (var i = 0; i < cards.length; i++) cards[i].classList.remove('active');
            card.classList.add('active');
            applyFilters();
        }

        // HÀM LỌC SIÊU TỐI ƯU & CHỐNG ĐỤNG ĐỘ ID HEADER
        function applyFilters() {
            try {
                // 1. Chỉ tìm đúng ô input nằm trong khu vực bảng (.tb-l)
                var searchInput = document.querySelector('.tb-l input[type="text"]');
                var q = searchInput ? removeAccents(searchInput.value) : '';

                var srcInput = document.getElementById('filterSource');
                var src = (STATUS === 0 && srcInput && srcInput.value !== '') ? removeAccents(srcInput.value) : '';

                var lopInput = document.getElementById('filterLop');
                var lop = (STATUS === 2 && lopInput && lopInput.value !== '') ? removeAccents(lopInput.value) : '';

                // 2. Lấy TẤT CẢ các thẻ dữ liệu (Bảng, List, Kanban)
                var items = document.querySelectorAll('.tbl-row, .list-row, .k-card');
                var cnt = 0;

                for (var i = 0; i < items.length; i++) {
                    var item = items[i];
                    var isKanban = item.classList.contains('k-card');

                    // 3. Gom toàn bộ chữ hiển thị trên dòng đó để tìm kiếm (An toàn tuyệt đối)
                    var rawText = item.textContent || item.innerText || '';
                    var itemText = removeAccents(rawText);

                    // 4. So sánh
                    var mSearch = (q === '') || itemText.includes(q);
                    var mSrc = (src === '') || itemText.includes(src);
                    var mLop = (lop === '') || itemText.includes(lop);

                    var mFilter = true;
                    if (!isKanban) {
                        mFilter = (curFilter === 'all') || item.classList.contains(curFilter);
                    }

                    // 5. Ẩn Hiện
                    if (mSearch && mSrc && mLop && mFilter) {
                        item.style.display = '';
                        if (!isKanban) cnt++;
                    } else {
                        item.style.display = 'none';
                    }
                }

                // 6. Cập nhật con số hiển thị
                var label = STATUS === 0 ? 'tiềm năng' : (STATUS === 1 ? 'đang tư vấn' : 'học viên');
                var el1 = document.getElementById('visibleCount');
                if (el1) el1.textContent = cnt + ' ' + label;

                var el2 = document.getElementById('countTxt');
                if (el2) el2.textContent = cnt + ' bản ghi';

            } catch (err) {
                console.error("Lỗi tìm kiếm: ", err);
            }
        }

        function switchView(v) {
            var kanban = document.getElementById('kanbanView');
            var list = document.getElementById('listView');
            if (!kanban || !list) return;

            if (v === 'kanban') {
                kanban.style.display = ''; list.style.display = 'none';
                var btnK = document.getElementById('btnKanban'); if (btnK) btnK.classList.add('on');
                var btnL = document.getElementById('btnList'); if (btnL) btnL.classList.remove('on');
            } else {
                kanban.style.display = 'none'; list.style.display = '';
                var btnL = document.getElementById('btnList'); if (btnL) btnL.classList.add('on');
                var btnK = document.getElementById('btnKanban'); if (btnK) btnK.classList.remove('on');
            }
            localStorage.setItem('pipelineView', v);
            applyFilters();
        }

        if (STATUS === 1) {
            switchView(localStorage.getItem('pipelineView') || 'kanban');
        }

        function toggleAll(cb) {
            var chks = document.querySelectorAll('.row-chk');
            for (var i = 0; i < chks.length; i++) chks[i].checked = cb.checked;
        }
    </script>
}