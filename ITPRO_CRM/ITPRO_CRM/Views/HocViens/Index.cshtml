                                            }
                                            else
                                            {
                                                <span style="color:var(--text3)">Chưa cấp mã</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div style="font-size:12.5px;font-weight:500;color:var(--text)">@(item.SoDienThoai ?? "—")</div>
                                <div style="font-size:11px;color:var(--text2)">@(item.Email ?? "—")</div>
                            </td>
                            <td>
                                @if (item.LopHoc != null)
                                {
                                    <span class="class-pill ok"><i class="fa-solid fa-chalkboard"></i> @item.LopHoc.TenLop</span>
                                }
                                else
                                {
                                    <span class="class-pill wa"><i class="fa-solid fa-clock"></i> Chờ xếp lớp</span>
                                }
                            </td>
