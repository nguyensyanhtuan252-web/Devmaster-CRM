                    <tr>
                        
                        <th>Khách hàng</th>
                        <th>Liên hệ</th>
                        <th>Nguồn</th>
                        <th>Sale phụ trách</th>
                        <th>Ngày tạo</th>
                        <th>Tình trạng</th>
                        <th style="text-align:right">Thao tác</th>
                    </tr>
                </thead>
