                        if (isCold) rowCls += " cold";
                        if (hasSoc) rowCls += " social";

                        <tr class="@rowCls"
                            data-name="@(item.HoTen?.ToLower())"
                            data-phone="@(item.SoDienThoai?.ToLower() ?? "")"
                            data-email="@(item.Email?.ToLower() ?? "")"
                            data-source="@srcLower">
                            
                            <td>
