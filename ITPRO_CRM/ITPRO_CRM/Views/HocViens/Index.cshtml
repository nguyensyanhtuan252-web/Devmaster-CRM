                        bool hasSoc = !string.IsNullOrEmpty(item.FacebookLink) || !string.IsNullOrEmpty(item.ZaloLink);
                        
                        string src = item.NguonGoc ?? item.ChienDich?.TenChienDich ?? "Tự nhiên";
                        string srcLower = src.ToLower();

