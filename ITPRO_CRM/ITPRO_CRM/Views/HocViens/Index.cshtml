@model IEnumerable<ITPRO_CRM.Models.HocVien>
@{
    // BẢN SỬA LỖI: Ưu tiên bắt trạng thái trực tiếp từ thanh địa chỉ URL (?trangThai=0)
    int status = 2;
    if (Context.Request.Query.ContainsKey("trangThai") && int.TryParse(Context.Request.Query["trangThai"], out int queryStatus))
    {
        status = queryStatus;
    }
    else if (ViewBag.CurrentStatus != null)
    {
        status = ViewBag.CurrentStatus;
    }

    // Lọc lại dữ liệu chuẩn xác ngay tại View
    var displayModel = status == 2
        ? Model.Where(x => x.TrangThai >= 2).ToList()
        : Model.Where(x => x.TrangThai == status).ToList();

    // Tiêu đề & icon theo từng chế độ
    string pageTitle = status == 0 ? "Tiềm năng" : status == 1 ? "Đang tư vấn" : "Học viên";
    string pageIcon = status == 0 ? "fa-bolt" : status == 1 ? "fa-comments-dollar" : "fa-users";
    string iconColor = status == 0 ? "var(--warning)" : status == 1 ? "var(--accent)" : "var(--success)";
    string iconBg = status == 0 ? "var(--warning-dim)" : status == 1 ? "var(--accent-dim)" : "var(--success-dim)";
    string pageDesc = status == 0 ? "Danh sách khách hàng tiềm năng — cần liên hệ và chăm sóc"
                     : status == 1 ? "Theo dõi và chuyển đổi khách hàng đang trong quá trình tư vấn"
                     : "Quản lý học viên chính thức — lớp học và học phí";
    ViewData["Title"] = pageTitle;

    // Thống kê chung (Dùng displayModel thay vì Model)
    var total = displayModel.Count();

    // === Status 0: TIỀM NĂNG ===
    var homNayLeads = displayModel.Count(x => x.NgayTao.HasValue && x.NgayTao.Value.Date == DateTime.Today);
    var chuaTuongTac = displayModel.Count(x => x.LichSuTuVans == null || !x.LichSuTuVans.Any());
    var coSocial = displayModel.Count(x => !string.IsNullOrEmpty(x.FacebookLink) || !string.IsNullOrEmpty(x.ZaloLink));

    // === Status 1: ĐANG TƯ VẤN ===
    var homNayHen = displayModel.Count(x => x.NgayHen.HasValue && x.NgayHen.Value.Date == DateTime.Today);
    var quaHan = displayModel.Count(x => x.NgayHen.HasValue && x.NgayHen.Value.Date < DateTime.Today);
    var chuaHen = displayModel.Count(x => !x.NgayHen.HasValue);

    // === Status 2: HỌC VIÊN ===
    var dangHoc = displayModel.Count(x => x.LopHocId != null);
    var coNo = displayModel.Count(x => x.LopHoc != null && (x.LopHoc.HocPhi - (x.PhieuThus?.Sum(p => p.SoTien) ?? 0m)) > 0);
    var chuaXep = displayModel.Count(x => x.LopHocId == null);
}

<style>
    /* ═══════════════════════════════════
                   SHARED STYLES — dùng đúng CSS vars của Layout
                   ═══════════════════════════════════ */
    .page-hdr {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 12px;
    }

        .page-hdr h1 {
            font-size: 18px;
            font-weight: 700;
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 9px;
            margin: 0;
        }

        .page-hdr p {
            font-size: 12px;
            color: var(--text2);
            margin: 3px 0 0;
        }

    .hdr-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0;
    }

    /* Stat cards */
    .stat-row {
        display: grid;
        gap: 12px;
        margin-bottom: 20px;
    }

    .stat-row-4 {
        grid-template-columns: repeat(4,1fr);
    }

    .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 14px 16px;
        cursor: pointer;
        transition: all .15s;
        position: relative;
        overflow: hidden;
    }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
        }

        .stat-card.c-accent::before {
            background: var(--accent);
        }

        .stat-card.c-warning::before {
            background: var(--warning);
        }

        .stat-card.c-danger::before {
            background: var(--danger);
        }

        .stat-card.c-success::before {
            background: var(--success);
        }

        .stat-card.c-muted::before {
            background: var(--text3);
        }

        .stat-card:hover {
            border-color: var(--border2);
            transform: translateY(-1px);
        }

        .stat-card.active {
            border-color: var(--accent);
            background: var(--accent-dim);
        }

    .stat-lbl {
        font-size: 10px;
        font-weight: 600;
        color: var(--text2);
        text-transform: uppercase;
        letter-spacing: .8px;
        margin-bottom: 6px;
    }

    .stat-val {
        font-size: 26px;
        font-weight: 700;
        color: var(--text);
        line-height: 1;
    }

    .stat-sub {
        font-size: 11px;
        color: var(--text2);
        margin-top: 4px;
    }

    /* Toolbar */
    .tb {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
        gap: 10px;
        flex-wrap: wrap;
    }

    .tb-l, .tb-r {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .si {
        position: relative;
    }

        .si i {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text2);
            font-size: 12px;
            pointer-events: none;
        }

        .si input {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 7px;
            padding: 7px 12px 7px 32px;
            color: var(--text);
            font-size: 12.5px;
            font-family: inherit;
            width: 210px;
            outline: none;
            transition: .15s;
        }

            .si input:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px var(--accent-dim);
            }

            .si input::placeholder {
                color: var(--text3);
            }

    .sel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 7px;
        padding: 7px 10px;
        color: var(--text);
        font-size: 12.5px;
        font-family: inherit;
        outline: none;
        cursor: pointer;
    }

        .sel:focus {
            border-color: var(--accent);
        }

    .btn-c {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        border: 1px solid var(--border);
        transition: .12s;
        background: var(--surface);
        color: var(--text2);
        white-space: nowrap;
        text-decoration: none;
    }

        .btn-c:hover {
            background: var(--surface2);
            color: var(--text);
        }

        .btn-c.pri {
            background: var(--accent) !important;
            color: #fff !important;
            border-color: var(--accent) !important;
        }

            .btn-c.pri:hover {
                background: var(--accent-h) !important;
                border-color: var(--accent-h) !important;
            }

    /* Table base */
    .tbl-wrap {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
    }

    .crm-tbl {
        width: 100%;
        border-collapse: collapse;
        font-size: 12.5px;
    }

        .crm-tbl thead th {
            padding: 10px 14px;
            text-align: left;
            font-size: 10px;
            font-weight: 600;
            color: var(--text3);
            text-transform: uppercase;
            letter-spacing: .8px;
            border-bottom: 1px solid var(--border);
            background: var(--surface2);
            white-space: nowrap;
        }

        .crm-tbl tbody td {
            padding: 12px 14px;
            border-bottom: 1px solid var(--border);
            color: var(--text2);
            vertical-align: middle;
        }

        .crm-tbl tbody tr:last-child td {
            border-bottom: none;
        }

        .crm-tbl tbody tr:hover td {
            background: var(--surface2);
            color: var(--text);
        }

    /* Shared components */
    /* Tìm và sửa đoạn này (khoảng dòng 68-70) */
    .av {
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        flex-shrink: 0;
        border-radius: 8px;
        /* THÊM 2 DÒNG NÀY ĐỂ CỐ ĐỊNH 1 MÀU (Nền xanh nhạt, chữ xanh đậm) */
        background-color: #e0e7ff !important;
        color: #1e40af !important;
    }

    .av-34 {
        width: 34px;
        height: 34px;
        font-size: 13px;
    }

    .av-28 {
        width: 28px;
        height: 28px;
        font-size: 11px;
        border-radius: 6px;
    }

    .act-btn {
        width: 27px;
        height: 27px;
        border-radius: 5px;
        border: 1px solid var(--border);
        background: transparent;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--text2);
        font-size: 11px;
        cursor: pointer;
        transition: .1s;
        text-decoration: none;
    }

        .act-btn:hover {
            background: var(--surface2);
            color: var(--text);
            border-color: var(--border2);
        }

        .act-btn.d:hover {
            background: var(--danger-dim);
            color: var(--danger);
            border-color: var(--danger);
        }

        .act-btn.s:hover {
            background: var(--success-dim);
            color: var(--success);
            border-color: var(--success);
        }

    .tbl-foot {
        padding: 10px 14px;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--surface2);
    }

        .tbl-foot span {
            font-size: 11px;
            color: var(--text2);
        }

    .empty-st {
        padding: 48px;
        text-align: center;
    }

        .empty-st i {
            font-size: 28px;
            color: var(--text3);
            display: block;
            margin-bottom: 10px;
        }

        .empty-st p {
            font-size: 13px;
            color: var(--text2);
            margin: 0;
        }

    /* Source badge */
    .src-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 2px 8px;
        border-radius: 5px;
        font-size: 10.5px;
        font-weight: 600;
        background: var(--surface2);
        color: var(--text2);
        border: 1px solid var(--border);
    }

    /* ─── STATUS 1: KANBAN ─── */
    .kanban-board {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 14px;
        margin-bottom: 20px;
    }

    .kanban-col {
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 10px;
        display: flex;
        flex-direction: column;
        min-height: 420px;
    }

    .k-head {
        padding: 12px 14px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
    }

        .k-head::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            border-radius: 10px 10px 0 0;
        }

        .k-head.kh-muted::before {
            background: var(--text3);
        }

        .k-head.kh-accent::before {
            background: var(--accent);
        }

        .k-head.kh-warn::before {
            background: var(--warning);
        }

        .k-head.kh-danger::before {
            background: var(--danger);
        }

    .k-head-title {
        font-size: 12px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .k-badge {
        font-size: 10px;
        font-weight: 700;
        padding: 1px 7px;
        border-radius: 8px;
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--text2);
    }

    .k-body {
        padding: 10px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        overflow-y: auto;
        max-height: 55vh;
        flex: 1;
    }

    .k-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 12px;
        cursor: pointer;
        transition: all .15s;
        text-decoration: none;
        display: block;
        position: relative;
        overflow: hidden;
    }

        .k-card::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 2px;
        }

        .k-card.lm::before {
            background: var(--text3);
        }

        .k-card.la::before {
            background: var(--accent);
        }

        .k-card.lt::before {
            background: var(--warning);
        }

        .k-card.lo::before {
            background: var(--danger);
        }

        .k-card:hover {
            border-color: var(--border2);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(0,0,0,.15);
        }

    .k-name {
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 3px;
    }

    .k-phone {
        font-size: 11.5px;
        color: var(--text2);
    }

    .k-meta {
        margin-top: 9px;
        padding-top: 8px;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .k-sale {
        font-size: 10.5px;
        color: var(--text2);
    }

    .k-date {
        font-size: 10.5px;
        font-weight: 600;
    }

    .pill {
        font-size: 10px;
        font-weight: 600;
        padding: 2px 6px;
        border-radius: 4px;
    }

    .pill-muted {
        background: var(--surface2);
        color: var(--text3);
        border: 1px solid var(--border);
    }

    .pill-accent {
        background: var(--accent-dim);
        color: var(--accent);
    }

    .pill-warn {
        background: var(--warning-dim);
        color: var(--warning);
    }

    .pill-danger {
        background: var(--danger-dim);
        color: var(--danger);
    }

    .k-empty {
        padding: 24px;
        text-align: center;
        color: var(--text3);
        font-size: 12px;
    }

        .k-empty i {
            font-size: 20px;
            display: block;
            margin-bottom: 8px;
        }

    /* view toggle */
    .vt {
        display: flex;
        gap: 3px;
    }

    .vt-btn {
        width: 30px;
        height: 30px;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--text2);
        font-size: 12px;
        transition: .12s;
    }

        .vt-btn.on, .vt-btn:hover {
            background: var(--surface2);
            color: var(--text);
            border-color: var(--border2);
        }

    /* ─── STATUS 2: DEBT BAR ─── */
    .debt-bar {
        height: 4px;
        border-radius: 2px;
        background: var(--border);
        margin-top: 5px;
        overflow: hidden;
        width: 90px;
    }

    .debt-fill {
        height: 100%;
        border-radius: 2px;
    }

    .class-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 9px;
        border-radius: 5px;
        font-size: 11px;
        font-weight: 600;
    }

        .class-pill.ok {
            background: var(--accent-dim);
            color: var(--accent);
        }

        .class-pill.wa {
            background: var(--warning-dim);
            color: var(--warning);
        }

    /* modal */
    .modal-content {
        background: var(--surface);
        border: 1px solid var(--border2);
        border-radius: 12px;
    }

    .modal-header {
        border-bottom: 1px solid var(--border);
        padding: 16px 20px;
    }

    .modal-footer {
        border-top: 1px solid var(--border);
        padding: 12px 20px;
    }

    .modal-title {
        font-size: 14px;
        font-weight: 600;
        color: var(--text);
    }

    .btn-close {
        filter: invert(1) opacity(.5);
    }

    [data-theme="light"] .btn-close {
        filter: none;
    }

    @@media(max-width:900px) {
        .kanban-board {
            grid-template-columns: repeat(2,1fr);
        }

        .stat-row-4 {
            grid-template-columns: repeat(2,1fr);
        }
    }

    @@media(max-width:576px) {
        .si input {
            width: 150px;
        }

        .kanban-board {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page-hdr">
    <div>
        <h1>
            <span class="hdr-icon" style="background:@iconBg;color:@iconColor">
                <i class="fa-solid @pageIcon"></i>
            </span>
            @pageTitle
        </h1>
        <p>@pageDesc</p>
    </div>
    <div style="display:flex;gap:8px;align-items:center">
        @if (status == 1)
        {
            <div class="vt" id="viewToggle">
                <button class="vt-btn on" id="btnKanban" onclick="switchView('kanban')" title="Kanban">
                    <i class="fa-solid fa-table-cells-large"></i>
                </button>
                <button class="vt-btn" id="btnList" onclick="switchView('list')" title="Danh sách">
                    <i class="fa-solid fa-list"></i>
                </button>
            </div>
        }
        @if (status == 0)
        {
            <button class="btn-c" data-bs-toggle="modal" data-bs-target="#importModal">
                <i class="fa-solid fa-file-import"></i> Nhập Excel
            </button>
        }
        @if (status == 2)
        {
            <a href="@Url.Action("ExportExcel","HocViens",new{status=2})" class="btn-c">
                <i class="fa-solid fa-file-export" style="color:var(--success)"></i> Xuất Excel
            </a>
        }
        <a asp-action="Create" class="btn-c pri">
            <i class="fa-solid fa-plus"></i>
            @(status == 0 ? "Thêm tiềm năng" : status == 1 ? "Thêm mới" : "Thêm học viên")
        </a>
    </div>
</div>

<div class="stat-row stat-row-4">
    @if (status == 0)
    {
        <div class="stat-card c-accent active" onclick="setFilter('all',this)">
            <div class="stat-lbl">Tổng tiềm năng</div>
            <div class="stat-val">@total</div>
            <div class="stat-sub">Đang theo dõi</div>
        </div>
        <div class="stat-card c-warning" onclick="setFilter('today',this)">
            <div class="stat-lbl">Mới hôm nay</div>
            <div class="stat-val" style="color:var(--warning)">@homNayLeads</div>
            <div class="stat-sub">Cần liên hệ ngay</div>
        </div>
        <div class="stat-card c-danger" onclick="setFilter('cold',this)">
            <div class="stat-lbl">Chưa tương tác</div>
            <div class="stat-val" style="color:var(--danger)">@chuaTuongTac</div>
            <div class="stat-sub">Chưa có lịch sử gọi</div>
        </div>
        <div class="stat-card c-success" onclick="setFilter('social',this)">
            <div class="stat-lbl">Có Facebook/Zalo</div>
            <div class="stat-val" style="color:var(--success)">@coSocial</div>
            <div class="stat-sub">Có thể nhắn tin</div>
        </div>
    }
    @if (status == 1)
    {
        <div class="stat-card c-accent active" onclick="setFilter('all',this)">
            <div class="stat-lbl">Tổng đang tư vấn</div>
            <div class="stat-val">@total</div>
            <div class="stat-sub">Đang theo dõi</div>
        </div>
        <div class="stat-card c-warning" onclick="setFilter('today',this)">
            <div class="stat-lbl">Hẹn hôm nay</div>
            <div class="stat-val" style="color:var(--warning)">@homNayHen</div>
            <div class="stat-sub">Cần gọi ngay</div>
        </div>
        <div class="stat-card c-danger" onclick="setFilter('overdue',this)">
            <div class="stat-lbl">Quá hạn</div>
            <div class="stat-val" style="color:var(--danger)">@quaHan</div>
            <div class="stat-sub">Cần xử lý gấp</div>
        </div>
        <div class="stat-card c-muted" onclick="setFilter('unset',this)">
            <div class="stat-lbl">Chưa hẹn lịch</div>
            <div class="stat-val" style="color:var(--text2)">@chuaHen</div>
            <div class="stat-sub">Cần đặt lịch</div>
        </div>
    }
    @if (status == 2)
    {
        <div class="stat-card c-accent @(ViewBag.CurrentFilter == "all" || string.IsNullOrEmpty(ViewBag.CurrentFilter) ? "active" : "")"
             onclick="window.location.href='@Url.Action("Index", new { filter = "all" })'" style="cursor:pointer;">
            <div class="stat-lbl">Tổng học viên</div>
            <div class="stat-val">@ViewBag.CountTong</div>
            <div class="stat-sub">Đang quản lý</div>
        </div>

        <div class="stat-card c-success @(ViewBag.CurrentFilter == "co-lop" ? "active" : "")"
             onclick="window.location.href='@Url.Action("Index", new { filter = "co-lop" })'" style="cursor:pointer;">
            <div class="stat-lbl">Đang có lớp</div>
            <div class="stat-val" style="color:var(--success)">@ViewBag.CountCoLop</div>
            <div class="stat-sub">Đã xếp lớp học</div>
        </div>

        <div class="stat-card c-danger @(ViewBag.CurrentFilter == "no-phi" ? "active" : "")"
             onclick="window.location.href='@Url.Action("Index", new { filter = "no-phi" })'" style="cursor:pointer;">
            <div class="stat-lbl">Còn nợ học phí</div>
            <div class="stat-val" style="color:var(--danger)">@ViewBag.CountNoPhi</div>
