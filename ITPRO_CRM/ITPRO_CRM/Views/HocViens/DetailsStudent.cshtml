@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js"></script>

    <script>
        // --- 1. FIX LỖI BÓNG MỜ CHO TẤT CẢ CÁC MODAL ---
        // Đẩy tất cả các modal ra ngoài body để không bị kẹt hiệu ứng CSS
        document.body.appendChild(document.getElementById('quickEmailModal'));
        document.body.appendChild(document.getElementById('modalGiaoVienNote')); // Fix mờ cho Ghi chú Giáo viên
        document.body.appendChild(document.getElementById('modalViewPhieu'));
        document.body.appendChild(document.getElementById('modalThuTien'));
        document.body.appendChild(document.getElementById('enrollModal'));

        // --- 2. CÁC HÀM FORMAT VÀ TÍNH TOÁN TIỀN ---
        function formatTien(input) {
            let val = input.value.replace(/\D/g, '');
            if (val === '') {
                input.value = '';
                document.getElementById('valSoTienGuiLen').value = 0;
                return;
            }
            let num = parseInt(val, 10);
            input.value = num.toLocaleString('en-US'); // Tự động thêm dấu phẩy
            document.getElementById('valSoTienGuiLen').value = num; // Ghi số gốc vào thẻ ẩn
        }

        function tuDongDienHocPhi(sel) {
            let opt = sel.options[sel.selectedIndex];
            document.getElementById('inpGoc').value = opt.getAttribute('data-hocphi') || 0;
            tinhTien();
        }

        function tinhTien() {
            let goc = parseFloat(document.getElementById('inpGoc').value) || 0;
            let giam = parseFloat(document.getElementById('inpGiam').value) || 0;
            let dong = parseFloat(document.getElementById('inpDong').value) || 0;
            let phaiThu = goc - giam;
            document.getElementById('txtPhaiThu').innerText = phaiThu.toLocaleString('vi-VN') + " đ";
            document.getElementById('txtConNo').innerText = ((phaiThu - dong) > 0 ? (phaiThu - dong).toLocaleString('vi-VN') : 0) + " đ";
        }

        // --- 3. HÀM MỞ MODAL XEM CHI TIẾT PHIẾU THU ---
        function xemPhieuThu(ma, ngay, tien, hinhthuc, nguoi, nd) {
            document.getElementById('vMa').innerText = ma;
            document.getElementById('vNgay').innerText = ngay;
            document.getElementById('vTien').innerText = tien + " đ";
            document.getElementById('vHinhThuc').innerText = hinhthuc;
            document.getElementById('vNguoiThu').innerText = nguoi;
            document.getElementById('vNoiDung').innerText = nd;
            new bootstrap.Modal(document.getElementById('modalViewPhieu')).show();
        }

        // --- 4. CẤU HÌNH GỬI EMAIL VÀ CKEDITOR ---
        var quickEditor;
        var myModalEl = document.getElementById('quickEmailModal');

        myModalEl.addEventListener('shown.bs.modal', function () {
            if (!quickEditor) {
                CKEDITOR.config.versionCheck = false;
                quickEditor = CKEDITOR.replace('quickNoiDung', {
                    height: 200,
                    toolbarGroups: [
                        { name: 'basicstyles', groups: [ 'basicstyles' ] },
                        { name: 'paragraph', groups: [ 'list', 'align' ] },
                        { name: 'links' }, { name: 'colors' }
                    ],
                    removeButtons: 'Subscript,Superscript,Strike'
                });
            }
        });

        myModalEl.addEventListener('hidden.bs.modal', function () {
            $('#quickTieuDe').val('');
            if (quickEditor) quickEditor.setData('');
            $('#quickEmailAlert').addClass('d-none').removeClass('alert-success alert-danger');
        });

        function executeQuickEmail() {
            var hvId = $('#quickHocVienId').val();
            var title = $('#quickTieuDe').val();
            var content = quickEditor ? quickEditor.getData() : $('#quickNoiDung').val();
            var btn = $('#btnSendQuickEmail');
            var alertBox = $('#quickEmailAlert');

            if (!title.trim() || !content.trim()) {
                alertBox.removeClass('d-none alert-success').addClass('alert-danger').text("Vui lòng nhập đầy đủ tiêu đề và nội dung.");
                return;
            }

            btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin me-1"></i> Đang gửi...');
            alertBox.addClass('d-none');

            $.ajax({
                url: '/EmailMarketing/SendQuickEmail',
                type: 'POST',
                data: { hocVienId: hvId, tieuDe: title, noiDung: content },
                success: function (res) {
                    btn.prop('disabled', false).html('<i class="fa-solid fa-paper-plane me-1"></i> Gửi ngay');
                    alertBox.removeClass('d-none alert-danger alert-success');

                    if (res.success) {
                        alertBox.addClass('alert-success').html('<i class="fa-solid fa-check me-1"></i> ' + res.message);
                        setTimeout(function() {
                            var modal = bootstrap.Modal.getInstance(myModalEl);
                            modal.hide();
                        }, 1500);
                    } else {
                        alertBox.addClass('alert-danger').html('<i class="fa-solid fa-circle-exclamation me-1"></i> ' + res.message);
                    }
                },
                error: function () {
                    btn.prop('disabled', false).html('<i class="fa-solid fa-paper-plane me-1"></i> Gửi ngay');
                    alertBox.removeClass('d-none alert-success').addClass('alert-danger').text("Đã xảy ra lỗi kết nối mạng!");
                }
            });
        }
    </script>
}