@model ITPRO_CRM.Models.CauHinh

@{
    ViewData["Title"] = "Chi tiết cấu hình";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap');

    .settings-root {
        font-family: 'Be Vietnam Pro', sans-serif;
        background: #f0f4f8;
        min-height: 100vh;
        padding: 2rem 1.5rem;
    }

    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 2rem;
    }

    .page-header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .page-header-icon {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #1e40af, #3b82f6);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.2rem;
        flex-shrink: 0;
        box-shadow: 0 4px 14px rgba(59,130,246,0.4);
    }

    .page-header h4 {
        font-weight: 700;
        color: #0f172a;
        margin: 0;
        font-size: 1.3rem;
    }

    .page-header p {
        margin: 0;
        font-size: 0.85rem;
        color: #64748b;
    }

    .btn-edit {
        font-family: 'Be Vietnam Pro', sans-serif;
        font-size: 0.88rem;
        font-weight: 700;
        color: #fff;
        background: linear-gradient(135deg, #2563eb, #3b82f6);
        border: none;
        border-radius: 10px;
        padding: 0.6rem 1.3rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        box-shadow: 0 3px 10px rgba(59,130,246,0.3);
    }

        .btn-edit:hover {
            background: linear-gradient(135deg, #1d4ed8, #2563eb);
            color: #fff;
            transform: translateY(-1px);
        }

    .config-card {
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 2px 20px rgba(15, 23, 42, 0.06);
        overflow: hidden;
        border: 1px solid rgba(226,232,240,0.7);
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1.6rem 2rem 1.2rem;
        border-bottom: 1px solid #f1f5f9;
    }

    .section-header-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: linear-gradient(135deg, #3b82f6, #06b6d4);
    }

    .section-header h6 {
        font-weight: 700;
        color: #1e293b;
        margin: 0;
        font-size: 0.95rem;
    }

    .detail-body {
        padding: 1.8rem 2rem;
    }

    .detail-row {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 1rem 0;
        border-bottom: 1px solid #f8fafc;
    }

        .detail-row:last-child {
            border-bottom: none;
        }

    .detail-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: #eff6ff;
        color: #3b82f6;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .detail-meta {
        flex: 1;
    }

        .detail-meta label {
            font-size: 0.75rem;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.7px;
            display: block;
            margin-bottom: 0.2rem;
        }

        .detail-meta span {
            font-size: 0.95rem;
            font-weight: 600;
            color: #1e293b;
        }

            .detail-meta span.empty {
                color: #cbd5e1;
                font-weight: 400;
                font-style: italic;
            }

    .card-footer-actions {
        background: #f8fafc;
        border-top: 1px solid #e9eef4;
        padding: 1.2rem 2rem;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 0.75rem;
    }

    .btn-back {
        font-family: 'Be Vietnam Pro', sans-serif;
        font-size: 0.88rem;
        font-weight: 600;
        color: #64748b;
        background: #fff;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        padding: 0.6rem 1.4rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        transition: all 0.2s;
    }

        .btn-back:hover {
            border-color: #cbd5e1;
            color: #334155;
        }
</style>

<div class="settings-root">
    <div class="row justify-content-center">
        <div class="col-lg-9 col-xl-8">

            <div class="page-header">
                <div class="page-header-left">
                    <div class="page-header-icon">
                        <i class="fa-solid fa-circle-info"></i>
                    </div>
                    <div>
                        <h4>Chi tiết cấu hình</h4>
                        <p>Thông tin hiện tại của hệ thống</p>
                    </div>
                </div>
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-edit">
                    <i class="fa-solid fa-pen"></i> Chỉnh sửa
                </a>
            </div>

            <div class="config-card">

                <div class="section-header">
                    <div class="section-header-dot"></div>
                    <h6>Thông tin trung tâm</h6>
                </div>

                <div class="detail-body">

                    <div class="detail-row">
                        <div class="detail-icon"><i class="fa-solid fa-landmark"></i></div>
                        <div class="detail-meta">
                            <label>Tên trung tâm</label>
                            <span>@(string.IsNullOrWhiteSpace(Model?.TenTrungTam) ? "Chưa cập nhật" : Model.TenTrungTam)</span>
                        </div>
                    </div>

                    <div class="detail-row">
                        <div class="detail-icon"><i class="fa-solid fa-location-dot"></i></div>
                        <div class="detail-meta">
                            <label>Địa chỉ trụ sở</label>
                            <span class="@(string.IsNullOrWhiteSpace(Model?.DiaChi) ? "empty" : "")">
                                @(string.IsNullOrWhiteSpace(Model?.DiaChi) ? "Chưa cập nhật" : Model.DiaChi)
                            </span>
                        </div>
                    </div>

                    <div class="detail-row">
                        <div class="detail-icon"><i class="fa-solid fa-phone"></i></div>
                        <div class="detail-meta">
                            <label>Hotline liên hệ</label>
                            <span class="@(string.IsNullOrWhiteSpace(Model?.SoDienThoai) ? "empty" : "")">
                                @(string.IsNullOrWhiteSpace(Model?.SoDienThoai) ? "Chưa cập nhật" : Model.SoDienThoai)
                            </span>
                        </div>
                    </div>

                </div>

                <div class="card-footer-actions">
                    <a asp-action="Index" class="btn-back">
                        <i class="fa-solid fa-arrow-left"></i> Quay lại
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>
