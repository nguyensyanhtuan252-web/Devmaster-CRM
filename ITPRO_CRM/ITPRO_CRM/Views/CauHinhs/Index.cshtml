@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        // Tab switching
        function switchTab(btn, targetId) {
            document.querySelectorAll('.cfg-tab').forEach(t => t.classList.remove('active'));
            btn.classList.add('active');
            ['tab-general', 'tab-display', 'tab-advanced'].forEach(id => {
                const el = document.getElementById(id);
                if (el) el.style.display = (id === targetId) ? 'block' : 'none';
            });
        }

        // Logo preview
        document.getElementById('logoInput').addEventListener('change', function () {
            const file = this.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = e => {
                const preview = document.getElementById('logoPreview');
                preview.innerHTML = `<img src="${e.target.result}" alt="Logo" style="width:100%;height:100%;object-fit:cover;border-radius:14px">`;
            };
            reader.readAsDataURL(file);
        });

        // XỬ LÝ LỖI "IM LÌM" VÀ HIỆN THANH LƯU CẤU HÌNH
        const configForm = document.getElementById('configForm');
        const saveBar = document.getElementById('saveBar');

        if (configForm && saveBar) {
            // 1. Chỉ hiện thanh lưu khi người dùng nhập thông tin
            const showSaveBar = () => { saveBar.style.display = 'flex'; };
            configForm.addEventListener('input', showSaveBar);
            configForm.addEventListener('change', showSaveBar);
        }

        // 2. Tự động chuyển Tab nếu Server trả về lỗi chưa nhập đúng yêu cầu
        document.addEventListener("DOMContentLoaded", function() {
            const firstError = document.querySelector('.input-validation-error, .text-danger:not(:empty)');
            if (firstError) {
                // Mở thanh lưu ra để nhắc nhở có lỗi
                if (saveBar) saveBar.style.display = 'flex';

                // Đi tìm xem lỗi đang bị giấu ở tab nào và mở tab đó lên
                const errorTab = firstError.closest('div[id^="tab-"]');
                if (errorTab) {
                    const tabBtn = document.getElementById('btn-' + errorTab.id);
                    if (tabBtn) tabBtn.click();
                }
            }
        });
    </script>
}