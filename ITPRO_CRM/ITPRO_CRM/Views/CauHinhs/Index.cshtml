@model ITPRO_CRM.Models.CauHinh

@{
    ViewData["Title"] = "Thiết lập hệ thống";
}

@if (TempData["Success"] != null)
{
    <div id="toast-success" style="position:fixed;top:1.2rem;right:1.5rem;z-index:9999;background:var(--surface);border:1px solid var(--border);border-left:4px solid var(--success);color:var(--text-main);padding:1rem 1.5rem;border-radius:8px;font-size:0.9rem;font-weight:600;display:flex;align-items:center;gap:0.75rem;box-shadow:var(--shadow-md)">
        <i class="fa-solid fa-circle-check" style="color:var(--success);font-size:1.2rem"></i> @TempData["Success"]
    </div>
    <script>setTimeout(()=>document.getElementById('toast-success')?.remove(),3500)</script>
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap');

    * {
        box-sizing: border-box;
    }

    /* ĐỒNG BỘ DARK MODE BẰNG BIẾN HỆ THỐNG */
    .cfg-root {
        font-family: 'Be Vietnam Pro', sans-serif;
        background: var(--surface-2);
        color: var(--text-main);
        min-height: 100vh;
        padding: 1.5rem; /* Thêm padding để tách giao diện ra khỏi viền màn hình */
        transition: background 0.3s;
    }

    /* HERO BANNER (Đã được bo tròn và làm nổi) */
    .cfg-hero {
        background: linear-gradient(135deg, var(--accent) 0%, #1e40af 100%);
        padding: 2rem 2.5rem;
        position: relative;
        overflow: hidden;
        border-radius: 16px; /* Bo tròn cực đẹp */
        box-shadow: 0 8px 24px rgba(37,99,235,0.15);
        max-width: 1200px;
        margin: 0 auto 1.5rem;
    }

    [data-theme="dark"] .cfg-hero {
        background: linear-gradient(135deg, #1e3a8a 0%, #0f172a 100%);
        box-shadow: 0 8px 24px rgba(0,0,0,0.5);
    }

    .cfg-hero::before {
        content: '';
        position: absolute;
        top: -60px;
        right: -60px;
        width: 280px;
        height: 280px;
        border-radius: 50%;
        background: rgba(255,255,255,0.06);
    }

    .cfg-hero::after {
        content: '';
        position: absolute;
        bottom: -80px;
        left: 30%;
        width: 360px;
        height: 360px;
        border-radius: 50%;
        background: rgba(255,255,255,0.04);
    }

    .cfg-hero-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
        z-index: 1;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .cfg-hero-left {
        display: flex;
        align-items: center;
        gap: 1.2rem;
    }

    .cfg-hero-icon {
        width: 56px;
        height: 56px;
        background: rgba(255,255,255,0.18);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.4rem;
        border: 1px solid rgba(255,255,255,0.25);
    }

    .cfg-hero h3 {
        color: #fff;
        font-weight: 800;
        font-size: 1.45rem;
        margin: 0 0 0.2rem;
        letter-spacing: -0.4px;
    }

    .cfg-hero p {
        color: rgba(255,255,255,0.72);
        margin: 0;
        font-size: 0.87rem;
    }

    .cfg-hero-badge {
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.25);
        color: #fff;
        font-size: 0.78rem;
        font-weight: 700;
        padding: 0.35rem 0.9rem;
        border-radius: 20px;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

        .cfg-hero-badge .dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #4ade80;
            animation: blink 2s ease-in-out infinite;
        }

    @@keyframes blink {
        0%, 100% {
            opacity: 1
        }

        50% {
            opacity: 0.4
        }
    }

    /* TABS */
    .cfg-tabs-wrap {
        background: transparent;
        border-bottom: 2px solid var(--border);
        display: flex;
        gap: 0.5rem;
        overflow-x: auto;
        max-width: 1200px;
        margin: 0 auto 1.5rem;
    }

    .cfg-tab {
        padding: 0.8rem 1.2rem;
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--text-muted);
        border: none;
        background: transparent;
        border-bottom: 2px solid transparent;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
        margin-bottom: -2px;
        white-space: nowrap;
    }

        .cfg-tab:hover {
            color: var(--accent);
        }

        .cfg-tab.active {
            color: var(--accent);
            border-bottom-color: var(--accent);
        }

    .tab-badge {
        background: rgba(59,127,255,0.12);
        color: var(--accent);
        font-size: 0.7rem;
        font-weight: 700;
        padding: 0.15rem 0.45rem;
        border-radius: 10px;
    }

    /* BODY */
    .cfg-body {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 1.5rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    /* CARDS */
    .cfg-card, .sidebar-card {
        background: var(--surface);
        border-radius: 16px;
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        overflow: hidden;
        margin-bottom: 1.25rem;
    }

    .cfg-card-head, .sidebar-card-head {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        padding: 1.25rem 1.6rem;
        border-bottom: 1px solid var(--border);
    }

    .sidebar-card-head {
        font-size: 0.87rem;
        font-weight: 700;
        color: var(--text-main);
        padding: 1.1rem 1.4rem;
        gap: 0.5rem;
    }

    .cfg-card-head-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.95rem;
        flex-shrink: 0;
    }

    .icon-blue {
        background: rgba(59,127,255,0.12);
        color: var(--accent);
    }

    .icon-green {
        background: rgba(34,197,94,0.12);
        color: var(--accent-green);
    }

    .icon-amber {
        background: rgba(245,158,11,0.12);
        color: var(--accent-amber);
    }

    .icon-slate {
        background: var(--surface-2);
        color: var(--text-muted);
    }

    .cfg-card-head h6 {
        font-weight: 700;
        font-size: 0.97rem;
        color: var(--text-main);
        margin: 0;
    }

    .cfg-card-head p {
        font-size: 0.78rem;
        color: var(--text-light);
        margin: 0.1rem 0 0;
    }

    .cfg-card-body, .sidebar-card-body {
        padding: 1.5rem 1.6rem;
    }

    .sidebar-card-body {
        padding: 1.2rem 1.4rem;
    }

    /* LOGO */
    .logo-zone {
        display: flex;
        align-items: center;
        gap: 1.4rem;
        padding: 1.25rem;
        border: 2px dashed var(--border);
        border-radius: 14px;
        background: var(--surface-2);
        cursor: pointer;
        transition: all 0.2s;
        margin-bottom: 1.5rem;
    }

        .logo-zone:hover {
            border-color: var(--accent);
            background: rgba(59,127,255,0.05);
        }

    .logo-avatar {
        width: 64px;
        height: 64px;
        border-radius: 14px;
        background: linear-gradient(135deg,#1e40af,#3b82f6);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.5rem;
        font-weight: 800;
        flex-shrink: 0;
        box-shadow: var(--shadow);
        overflow: hidden;
    }

        .logo-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .logo-info strong {
        display: block;
        font-size: 0.92rem;
        font-weight: 700;
        color: var(--text-main);
        margin-bottom: 0.2rem;
    }

    .logo-info span {
        font-size: 0.78rem;
        color: var(--text-light);
    }

    .logo-upload-btn {
        margin-left: auto;
        background: var(--surface);
        border: 1.5px solid var(--border);
        color: var(--text-muted);
        font-size: 0.8rem;
        font-weight: 600;
        padding: 0.45rem 0.9rem;
        border-radius: 8px;
        cursor: pointer;
        white-space: nowrap;
        transition: all 0.15s;
    }

        .logo-upload-btn:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

    /* FIELDS */
    .field-row {
        display: grid;
        gap: 1.1rem;
        margin-bottom: 1.1rem;
    }

        .field-row.col2 {
            grid-template-columns: 1fr 1fr;
        }

    .field-wrap {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .field-label {
        font-size: 0.74rem;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.65px;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

        .field-label i {
            color: var(--text-light);
        }

    .field-input {
        width: 100%;
        border: 1.5px solid var(--border);
        border-radius: 10px;
        padding: 0.72rem 1rem;
        font-family: 'Be Vietnam Pro',sans-serif;
        font-size: 0.92rem;
        font-weight: 500;
        color: var(--text-main);
        background: var(--surface-2);
        outline: none;
        transition: all 0.18s;
    }

        .field-input:focus {
            border-color: var(--accent);
            background: var(--surface);
            box-shadow: 0 0 0 4px rgba(59,127,255,0.1);
        }

        .field-input::placeholder {
            color: var(--text-light);
            font-weight: 400;
        }

    .field-hint {
        font-size: 0.75rem;
        color: var(--text-light);
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    /* BẢN SỬA: ĐÃ DÙNG FLEXBOX ĐỂ Ô SỐ ĐIỆN THOẠI KHÍT RỊT VÀ HOÀN HẢO */
    .phone-wrap {
        display: flex;
        align-items: stretch;
        border: 1.5px solid var(--border);
        border-radius: 10px;
        background: var(--surface-2);
        overflow: hidden;
        transition: all 0.18s;
    }

        .phone-wrap:focus-within {
            border-color: var(--accent);
            background: var(--surface);
            box-shadow: 0 0 0 4px rgba(59,127,255,0.1);
        }

    .phone-prefix {
        display: flex;
        align-items: center;
        padding: 0 1rem;
        background: var(--surface);
        border-right: 1.5px solid var(--border);
        color: var(--text-muted);
        font-weight: 600;
        font-size: 0.88rem;
    }

    .phone-wrap .field-input {
        border: none;
        border-radius: 0;
        background: transparent;
        padding-left: 0.8rem;
        box-shadow: none !important;
    }

        .phone-wrap .field-input:focus {
            box-shadow: none;
        }
    /* --- HẾT PHẦN SỬA PHONE KHUNG --- */

    .section-divider {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin: 1.5rem 0 1.2rem;
        color: var(--text-light);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.6px;
    }

        .section-divider::before, .section-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

    /* SIDEBAR STATS */
    .stat-item {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        padding: 0.7rem 0;
        border-bottom: 1px solid var(--border);
    }

        .stat-item:last-child {
            border-bottom: none;
        }

    .stat-icon {
        width: 34px;
        height: 34px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        flex-shrink: 0;
    }

    .stat-text {
        flex: 1;
        min-width: 0;
    }

        .stat-text strong {
            display: block;
            font-size: 0.88rem;
            font-weight: 700;
            color: var(--text-main);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .stat-text span {
            font-size: 0.74rem;
            color: var(--text-light);
        }

    .checklist-item {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        padding: 0.55rem 0;
        font-size: 0.84rem;
        color: var(--text-muted);
        font-weight: 500;
        border-bottom: 1px solid var(--border);
    }

        .checklist-item:last-child {
            border-bottom: none;
        }

    .check-icon {
        color: var(--accent-green);
        font-size: 0.9rem;
        flex-shrink: 0;
    }

    .warn-icon {
        color: var(--accent-amber);
        font-size: 0.9rem;
        flex-shrink: 0;
    }

    .version-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: rgba(34,197,94,0.12);
        border: 1px solid rgba(34,197,94,0.25);
        color: var(--accent-green);
        font-size: 0.76rem;
        font-weight: 700;
        padding: 0.3rem 0.75rem;
        border-radius: 20px;
        white-space: nowrap;
    }

    /* BẢN SỬA: THANH LƯU CẤU HÌNH THÀNH DẠNG NỔI (FLOATING STICKY BAR) */
    .cfg-save-bar {
        position: sticky;
        bottom: 1rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1rem 1.5rem;
        display: none; /* MẶC ĐỊNH ẨN */
        align-items: center;
        justify-content: space-between;
        z-index: 50;
        gap: 1rem;
        flex-wrap: wrap;
        box-shadow: 0 8px 30px rgba(0,0,0,0.15);
        max-width: 1200px;
        margin: 0 auto;
    }

    .save-bar-hint {
        font-size: 0.85rem;
        color: var(--text-muted);
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .save-bar-actions {
        display: flex;
        gap: 0.75rem;
        align-items: center;
    }

    .btn-cancel {
        font-family: 'Be Vietnam Pro',sans-serif;
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--text-muted);
        background: var(--surface-2);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 0.6rem 1.3rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        cursor: pointer;
        transition: all 0.18s;
    }

        .btn-cancel:hover {
            border-color: var(--text-light);
            color: var(--text-main);
        }

    .btn-save {
        font-family: 'Be Vietnam Pro',sans-serif;
        font-size: 0.88rem;
        font-weight: 700;
        color: #fff;
        background: linear-gradient(135deg,#1d4ed8,#2563eb);
        border: none;
        border-radius: 10px;
        padding: 0.65rem 1.6rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 3px 10px rgba(37,99,235,0.4);
    }

        .btn-save:hover {
            background: linear-gradient(135deg,#1e40af,#1d4ed8);
            transform: translateY(-1px);
        }

    @@media (max-width:960px) {
        .cfg-body {
            grid-template-columns: 1fr;
        }

        .field-row.col2 {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="cfg-root">
    <form asp-action="Index" enctype="multipart/form-data" id="configForm" novalidate>
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger px-4 pt-2" style="font-size:0.83rem"></div>

        <div class="cfg-hero">
            <div class="cfg-hero-inner">
                <div class="cfg-hero-left">
                    <div class="cfg-hero-icon"><i class="fa-solid fa-sliders"></i></div>
                    <div>
                        <h3>Thiết lập hệ thống</h3>
                        <p>Quản lý thông tin trung tâm · Tùy chỉnh hiển thị · Cấu hình liên hệ</p>
                    </div>
                </div>
                <div class="cfg-hero-badge"><span class="dot"></span> Hệ thống đang hoạt động</div>
            </div>
        </div>

        <div class="cfg-tabs-wrap">
            <button type="button" class="cfg-tab active" onclick="switchTab(this,'tab-general')" id="btn-tab-general">
                <i class="fa-solid fa-building"></i> Thông tin chung
            </button>
            <button type="button" class="cfg-tab" onclick="switchTab(this,'tab-display')" id="btn-tab-display">
                <i class="fa-solid fa-palette"></i> Hiển thị & Ngôn ngữ <span class="tab-badge">Mới</span>
            </button>
            <button type="button" class="cfg-tab" onclick="switchTab(this,'tab-advanced')" id="btn-tab-advanced">
                <i class="fa-solid fa-shield-halved"></i> Nâng cao
            </button>
        </div>

        <div class="cfg-body">

            <div>

                <div id="tab-general">

                    <div class="cfg-card">
                        <div class="cfg-card-head">
                            <div class="cfg-card-head-icon icon-blue"><i class="fa-solid fa-landmark"></i></div>
                            <div>
                                <h6>Nhận diện thương hiệu</h6>
                                <p>Tên, logo và địa chỉ chính thức của trung tâm</p>
                            </div>
                        </div>
                        <div class="cfg-card-body">

                            <div class="logo-zone" onclick="document.getElementById('logoInput').click()">
                                <div class="logo-avatar" id="logoPreview">
                                    @if (!string.IsNullOrEmpty(Model.LogoUrl))
                                    {
                                        <img src="@Model.LogoUrl" alt="Logo" />
                                    }
                                    else
                                    {
                                        <span>IT</span>
                                    }
                                </div>
                                <div class="logo-info">
                                    <strong>Logo trung tâm</strong>
                                    <span>PNG hoặc JPG · Khuyến nghị 256×256px · Tối đa 2MB</span>
                                </div>
                                <button type="button" class="logo-upload-btn"><i class="fa-solid fa-cloud-arrow-up me-1"></i> Tải lên</button>
                            </div>
                            <input type="file" id="logoInput" name="logoFile" accept="image/*" style="display:none">
                            <input type="hidden" asp-for="LogoUrl" />

                            <div class="field-row">
                                <div class="field-wrap">
                                    <label class="field-label"><i class="fa-solid fa-building"></i> Tên trung tâm / Đơn vị</label>
                                    <input asp-for="TenTrungTam" class="field-input" placeholder="VD: ITPRO Academy" />
                                    <span class="field-hint"><i class="fa-solid fa-circle-info"></i> Tên này sẽ xuất hiện trên hóa đơn, hợp đồng và báo cáo.</span>
                                    <span asp-validation-for="TenTrungTam" class="text-danger" style="font-size:0.78rem"></span>
                                </div>
                            </div>
                            <div class="field-row">
                                <div class="field-wrap">
                                    <label class="field-label"><i class="fa-solid fa-location-dot"></i> Địa chỉ trụ sở chính</label>
                                    <input asp-for="DiaChi" class="field-input" placeholder="Số nhà, đường, quận/huyện, tỉnh/thành phố" />
                                    <span asp-validation-for="DiaChi" class="text-danger" style="font-size:0.78rem"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="cfg-card">
                        <div class="cfg-card-head">
                            <div class="cfg-card-head-icon icon-green"><i class="fa-solid fa-address-book"></i></div>
                            <div>
                                <h6>Thông tin liên hệ</h6>
                                <p>Hotline và kênh liên lạc hiển thị cho học viên</p>
                            </div>
                        </div>
                        <div class="cfg-card-body">
                            <div class="field-row col2">
                                <div class="field-wrap">
                                    <label class="field-label"><i class="fa-solid fa-phone"></i> Hotline chính</label>
                                    <div class="phone-wrap">
                                        <span class="phone-prefix"><i class="fa-solid fa-phone" style="font-size:0.78rem;margin-right:4px;"></i> +84</span>
                                        <input asp-for="SoDienThoai" class="field-input" placeholder="9x xxx xxxx" />
                                    </div>
                                    <span class="field-hint"><i class="fa-solid fa-circle-info"></i> Số điện thoại hỗ trợ học viên.</span>
                                    <span asp-validation-for="SoDienThoai" class="text-danger" style="font-size:0.78rem"></span>
                                </div>
                                <div class="field-wrap">
                                    <label class="field-label"><i class="fa-solid fa-phone-volume"></i> Hotline dự phòng</label>
                                    <div class="phone-wrap">
                                        <span class="phone-prefix"><i class="fa-solid fa-phone" style="font-size:0.78rem;margin-right:4px;"></i> +84</span>
                                        <input asp-for="HotlineDuPhong" class="field-input" placeholder="Tùy chọn" />
                                    </div>
                                    <span class="field-hint"><i class="fa-solid fa-circle-info"></i> Dùng khi hotline chính bận.</span>
                                </div>
                            </div>

                            <div class="section-divider">Mạng xã hội & Website</div>

                            <div class="field-row col2">
                                <div class="field-wrap">
                                    <label class="field-label"><i class="fa-brands fa-facebook"></i> Facebook Page</label>
                                    <input asp-for="Facebook" class="field-input" placeholder="facebook.com/itpro.academy" />
                                </div>
                                <div class="field-wrap">
                                    <label class="field-label"><i class="fa-brands fa-youtube"></i> Kênh YouTube</label>
                                    <input asp-for="Youtube" class="field-input" placeholder="youtube.com/@@itpro" />
                                </div>
                            </div>
                            <div class="field-row col2">
                                <div class="field-wrap">
