@model ITPRO_CRM.Models.CauHinh

@{
    ViewData["Title"] = "Xóa cấu hình";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap');

    .settings-root {
        font-family: 'Be Vietnam Pro', sans-serif;
        background: #f0f4f8;
        min-height: 100vh;
        padding: 2rem 1.5rem;
    }

    .page-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .page-header-icon {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #dc2626, #ef4444);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.2rem;
        flex-shrink: 0;
        box-shadow: 0 4px 14px rgba(239,68,68,0.4);
    }

    .page-header h4 {
        font-weight: 700;
        color: #0f172a;
        margin: 0;
        font-size: 1.3rem;
    }

    .page-header p {
        margin: 0;
        font-size: 0.85rem;
        color: #64748b;
    }

    .config-card {
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 2px 20px rgba(15, 23, 42, 0.06);
        overflow: hidden;
        border: 1px solid rgba(226,232,240,0.7);
    }

    .warn-banner {
        background: linear-gradient(135deg, #fef2f2, #fff7ed);
        border-bottom: 1px solid #fecaca;
        padding: 1.2rem 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .warn-banner-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: #fee2e2;
        color: #ef4444;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .warn-banner strong {
        font-size: 0.95rem;
        font-weight: 700;
        color: #7f1d1d;
        display: block;
    }

    .warn-banner span {
        font-size: 0.82rem;
        color: #b91c1c;
    }

    .detail-body {
        padding: 1.8rem 2rem;
    }

    .detail-row {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 0.9rem 0;
        border-bottom: 1px solid #f8fafc;
    }

        .detail-row:last-child {
            border-bottom: none;
        }

    .detail-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: #fef2f2;
        color: #ef4444;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .detail-meta {
        flex: 1;
    }

        .detail-meta label {
            font-size: 0.75rem;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.7px;
            display: block;
            margin-bottom: 0.2rem;
        }

        .detail-meta span {
            font-size: 0.95rem;
            font-weight: 600;
            color: #1e293b;
        }

    .card-footer-actions {
        background: #f8fafc;
        border-top: 1px solid #e9eef4;
        padding: 1.2rem 2rem;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 0.75rem;
    }

    .btn-cancel {
        font-family: 'Be Vietnam Pro', sans-serif;
        font-size: 0.88rem;
        font-weight: 600;
        color: #64748b;
        background: #fff;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        padding: 0.6rem 1.4rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        transition: all 0.2s;
    }

        .btn-cancel:hover {
            border-color: #cbd5e1;
            color: #334155;
        }

    .btn-delete {
        font-family: 'Be Vietnam Pro', sans-serif;
        font-size: 0.88rem;
        font-weight: 700;
        color: #fff;
        background: linear-gradient(135deg, #dc2626, #ef4444);
        border: none;
        border-radius: 10px;
        padding: 0.65rem 1.6rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 3px 10px rgba(239,68,68,0.35);
    }

        .btn-delete:hover {
            background: linear-gradient(135deg, #b91c1c, #dc2626);
            box-shadow: 0 5px 16px rgba(239,68,68,0.45);
            transform: translateY(-1px);
        }
</style>

<div class="settings-root">
    <div class="row justify-content-center">
        <div class="col-lg-9 col-xl-8">

            <div class="page-header">
                <div class="page-header-icon">
                    <i class="fa-solid fa-trash"></i>
                </div>
                <div>
                    <h4>Xóa cấu hình</h4>
                    <p>Hành động này không thể hoàn tác</p>
                </div>
            </div>

            <div class="config-card">

                <div class="warn-banner">
                    <div class="warn-banner-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>
                    <div>
                        <strong>Xác nhận xóa cấu hình</strong>
                        <span>Toàn bộ thông tin dưới đây sẽ bị xóa vĩnh viễn khỏi hệ thống.</span>
                    </div>
                </div>

                <div class="detail-body">

                    <div class="detail-row">
                        <div class="detail-icon"><i class="fa-solid fa-landmark"></i></div>
                        <div class="detail-meta">
                            <label>Tên trung tâm</label>
                            <span>@Model?.TenTrungTam</span>
                        </div>
                    </div>

                    <div class="detail-row">
                        <div class="detail-icon"><i class="fa-solid fa-location-dot"></i></div>
                        <div class="detail-meta">
                            <label>Địa chỉ</label>
                            <span>@Model?.DiaChi</span>
                        </div>
                    </div>

                    <div class="detail-row">
                        <div class="detail-icon"><i class="fa-solid fa-phone"></i></div>
                        <div class="detail-meta">
                            <label>Hotline</label>
                            <span>@Model?.SoDienThoai</span>
                        </div>
                    </div>

                </div>

                <div class="card-footer-actions">
                    <a asp-action="Index" class="btn-cancel">
                        <i class="fa-solid fa-xmark"></i> Hủy bỏ
                    </a>
                    <form asp-action="Delete" style="display:inline">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn-delete">
                            <i class="fa-solid fa-trash"></i> Xác nhận xóa
                        </button>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>
