@model ITPRO_CRM.Models.GiangVien

@{
    ViewData["Title"] = "Hồ sơ Giảng viên";
    var isActive = Model.TrangThai == 1;
    var avatarUrl = string.IsNullOrEmpty(Model.AnhDaiDien)
        ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(Model.HoTen ?? "GV")}&background=1d4ed8&color=fff&size=200&bold=true"
        : Model.AnhDaiDien;
}



<style>
    @@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap');

    .dtl-wrap * {
        font-family: 'Be Vietnam Pro', sans-serif;
        box-sizing: border-box;
    }

    .dtl-wrap i {
        font-family: 'Font Awesome 6 Free', 'Font Awesome 6 Brands' !important;
    }

    /* ── Breadcrumb & Header ── */
    .dtl-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 11.5px;
        color: var(--text3);
        margin-bottom: 6px;
        font-weight: 500;
    }

        .dtl-breadcrumb a {
            color: var(--text3);
            text-decoration: none;
        }

            .dtl-breadcrumb a:hover {
                color: var(--accent);
            }

        .dtl-breadcrumb i {
            font-size: 10px;
        }

    .dtl-top-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 28px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .dtl-page-title {
        font-size: 22px;
        font-weight: 800;
        color: var(--text);
        letter-spacing: -.4px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .dtl-page-title-icon {
        width: 38px;
        height: 38px;
        background: var(--accent);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 16px;
        flex-shrink: 0;
    }

    .dtl-top-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .dtl-action-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 9px 18px;
        border-radius: 9px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text2);
        cursor: pointer;
        transition: all .15s;
        font-family: 'Be Vietnam Pro', sans-serif;
    }

        .dtl-action-btn:hover {
            background: var(--accent-dim);
            color: var(--accent);
            border-color: var(--accent);
        }

        .dtl-action-btn.primary {
            background: var(--accent);
            color: #fff;
            border-color: var(--accent);
            box-shadow: 0 4px 14px rgba(var(--accent-rgb,29,78,216),.28);
        }

            .dtl-action-btn.primary:hover {
                background: var(--accent-h);
                color: #fff;
                transform: translateY(-1px);
            }

        .dtl-action-btn.danger:hover {
            background: var(--danger-dim);
            color: var(--danger);
            border-color: var(--danger);
        }

    /* ── Layout ── */
    .dtl-layout {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 20px;
        align-items: start;
    }

    /* ── Profile Card (left) ── */
    .dtl-profile-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        position: sticky;
        top: 20px;
    }

    .dtl-profile-banner {
        height: 80px;
        background: linear-gradient(135deg, var(--accent) 0%, #6366f1 100%);
        position: relative;
    }

    .dtl-profile-banner-inactive {
        background: linear-gradient(135deg, var(--text3) 0%, #9ca3af 100%);
    }

    .dtl-profile-avatar-wrap {
        position: absolute;
        bottom: -40px;
        left: 50%;
        transform: translateX(-50%);
    }

    .dtl-profile-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid var(--surface);
        box-shadow: 0 4px 16px rgba(0,0,0,.15);
        display: block;
    }

    .dtl-profile-body {
        padding: 52px 20px 24px;
        text-align: center;
    }

    .dtl-profile-name {
        font-size: 17px;
        font-weight: 800;
        color: var(--text);
        margin-bottom: 4px;
        letter-spacing: -.3px;
    }

    .dtl-profile-major {
        font-size: 12.5px;
        font-weight: 600;
        color: var(--accent);
        margin-bottom: 12px;
    }

    .dtl-status-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 20px;
    }

        .dtl-status-pill.on {
            background: var(--success-dim);
            color: var(--success);
        }

        .dtl-status-pill.off {
            background: var(--surface2);
            color: var(--text3);
            border: 1px solid var(--border);
        }

    .dtl-status-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
    }

        .dtl-status-dot.on {
            background: var(--success);
        }

        .dtl-status-dot.off {
            background: var(--text3);
        }

    /* Quick info rows */
    .dtl-quick-info {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 20px;
        text-align: left;
    }

    .dtl-qi-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 12px;
        background: var(--surface2);
        border-radius: 9px;
        border: 1px solid var(--border);
        font-size: 12.5px;
        color: var(--text);
        text-decoration: none;
        transition: border-color .13s;
    }

    a.dtl-qi-row:hover {
        border-color: var(--accent);
    }

    .dtl-qi-icon {
        width: 28px;
        height: 28px;
        border-radius: 7px;
        background: var(--accent-dim);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
        font-size: 11px;
        flex-shrink: 0;
    }

    .dtl-qi-label {
        font-size: 10.5px;
        color: var(--text3);
        font-weight: 500;
        margin-bottom: 1px;
    }

    .dtl-qi-val {
        font-weight: 600;
        color: var(--text);
        font-size: 12.5px;
    }

    /* Profile footer */
    .dtl-profile-footer {
        border-top: 1px solid var(--border);
        padding: 14px 20px;
        display: flex;
        gap: 8px;
    }

    .dtl-pf-btn {
        flex: 1;
        padding: 8px 6px;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: var(--surface2);
        color: var(--text2);
        font-size: 12px;
        font-weight: 600;
        text-align: center;
        text-decoration: none;
        cursor: pointer;
        transition: all .13s;
        font-family: 'Be Vietnam Pro', sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
    }

        .dtl-pf-btn:hover {
            background: var(--accent-dim);
            color: var(--accent);
            border-color: var(--accent);
        }

        .dtl-pf-btn.del:hover {
            background: var(--danger-dim);
            color: var(--danger);
            border-color: var(--danger);
        }

    /* ── Right: Info sections ── */
    .dtl-right {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .dtl-section {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        animation: fadeUp .3s ease both;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .dtl-section:nth-child(2) {
        animation-delay: 60ms;
    }

    .dtl-section:nth-child(3) {
        animation-delay: 120ms;
    }

    .dtl-section:nth-child(4) {
        animation-delay: 180ms;
    }

    .dtl-section-head {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 20px;
        border-bottom: 1px solid var(--border);
        background: var(--surface2);
    }

    .dtl-section-icon {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        background: var(--accent-dim);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
        font-size: 13px;
        flex-shrink: 0;
    }

    .dtl-section-title {
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
    }

    .dtl-section-sub {
        font-size: 11.5px;
        color: var(--text2);
        margin-top: 1px;
    }

    .dtl-section-body {
        padding: 20px;
    }

    /* Info grid */
    .dtl-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    .dtl-info-item {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .dtl-info-label {
        font-size: 11px;
        font-weight: 600;
        color: var(--text3);
        text-transform: uppercase;
        letter-spacing: .6px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .dtl-info-label i {
            font-size: 10px;
            color: var(--accent);
        }

    .dtl-info-val {
        font-size: 13.5px;
        font-weight: 600;
        color: var(--text);
        line-height: 1.4;
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 9px 13px;
    }

        .dtl-info-val.empty {
            color: var(--text3);
            font-weight: 400;
            font-style: italic;
            font-size: 12.5px;
        }

        .dtl-info-val a {
            color: var(--accent);
            text-decoration: none;
        }

            .dtl-info-val a:hover {
                text-decoration: underline;
            }

    /* Badge chips */
    .dtl-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        background: var(--accent-dim);
        color: var(--accent);
    }

    /* Bio / long text */
    .dtl-bio-block {
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 14px 16px;
        font-size: 13px;
        color: var(--text2);
        line-height: 1.7;
    }

    /* ID row */
    .dtl-id-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 16px;
        background: var(--surface2);
        border-radius: 9px;
        border: 1px solid var(--border);
        margin-bottom: 14px;
    }

    .dtl-id-label {
        font-size: 11.5px;
        color: var(--text3);
        font-weight: 500;
    }

    .dtl-id-val {
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
        font-family: 'JetBrains Mono', monospace;
    }

    @@media (max-width: 860px) {
        .dtl-layout {
            grid-template-columns: 1fr;
        }

        .dtl-profile-card {
            position: static;
        }

        .dtl-info-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="dtl-wrap">

    <!-- Breadcrumb -->
    <div class="dtl-breadcrumb">
        <i class="fa-solid fa-house"></i>
        <a asp-action="Index">Giảng viên</a>
        <i class="fa-solid fa-chevron-right"></i>
        Hồ sơ — @Model.HoTen
    </div>

    <!-- Top bar -->
    <div class="dtl-top-bar">
        <div class="dtl-page-title">
            <div class="dtl-page-title-icon"><i class="fa-solid fa-id-card"></i></div>
            Hồ sơ Giảng viên
        </div>
        <div class="dtl-top-actions">
            <a asp-action="Index" class="dtl-action-btn">
                <i class="fa-solid fa-arrow-left"></i> Danh sách
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="dtl-action-btn">
                <i class="fa-solid fa-pen"></i> Chỉnh sửa
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="dtl-action-btn danger">
                <i class="fa-solid fa-trash"></i> Xóa
            </a>
        </div>
    </div>

    <!-- Layout -->
    <div class="dtl-layout">

        <!-- Left: Profile card -->
        <div class="dtl-profile-card">
            <div class="dtl-profile-banner @(!isActive ? "dtl-profile-banner-inactive" : "")">
                <div class="dtl-profile-avatar-wrap">
                    <img src="@avatarUrl" class="dtl-profile-avatar" alt="@Model.HoTen">
                </div>
            </div>
            <div class="dtl-profile-body">
                <div class="dtl-profile-name">@Model.HoTen</div>
                @if (!string.IsNullOrEmpty(Model.ChuyenMon))
                {
                    <div class="dtl-profile-major">@Model.ChuyenMon</div>
                }
                <div class="dtl-status-pill @(isActive ? "on" : "off")">
                    <span class="dtl-status-dot @(isActive ? "on" : "off")"></span>
                    @(isActive ? "Đang công tác" : "Đã nghỉ")
                </div>

                <!-- Quick info -->
                <div class="dtl-quick-info">
                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <a href="mailto:@Model.Email" class="dtl-qi-row">
                            <div class="dtl-qi-icon"><i class="fa-solid fa-envelope"></i></div>
                            <div>
                                <div class="dtl-qi-label">Email</div>
                                <div class="dtl-qi-val">@Model.Email</div>
                            </div>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(Model.SoDienThoai))
                    {
                        <a href="tel:@Model.SoDienThoai" class="dtl-qi-row">
                            <div class="dtl-qi-icon"><i class="fa-solid fa-phone"></i></div>
                            <div>
                                <div class="dtl-qi-label">Điện thoại</div>
                                <div class="dtl-qi-val">@Model.SoDienThoai</div>
                            </div>
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(Model.BangCap))
                    {
                        <div class="dtl-qi-row">
                            <div class="dtl-qi-icon"><i class="fa-solid fa-graduation-cap"></i></div>
                            <div>
                                <div class="dtl-qi-label">Bằng cấp</div>
                                <div class="dtl-qi-val">@Model.BangCap</div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="dtl-profile-footer">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="dtl-pf-btn">
                    <i class="fa-solid fa-pen"></i> Sửa
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="dtl-pf-btn del">
                    <i class="fa-solid fa-trash"></i> Xóa
                </a>
            </div>
        </div>

        <!-- Right: Info sections -->
        <div class="dtl-right">

            <!-- System info -->
            <div class="dtl-section">
                <div class="dtl-section-head">
                    <div class="dtl-section-icon"><i class="fa-solid fa-fingerprint"></i></div>
                    <div>
                        <div class="dtl-section-title">Thông tin hệ thống</div>
                        <div class="dtl-section-sub">Mã định danh và trạng thái</div>
                    </div>
                </div>
                <div class="dtl-section-body">
                    <div class="dtl-id-row">
                        <span class="dtl-id-label"><i class="fa-solid fa-hashtag me-1"></i>Mã giảng viên</span>
                        <span class="dtl-id-val">#@Model.Id</span>
                    </div>
                    <div class="dtl-info-grid">
                        <div class="dtl-info-item">
                            <div class="dtl-info-label"><i class="fa-solid fa-toggle-on"></i> Trạng thái</div>
                            <div class="dtl-info-val">
                                <span class="dtl-chip" style="@(isActive ? "" : "background:var(--surface2);color:var(--text3)")">
                                    <i class="fas @(isActive ? "fa-circle-check" : "fa-circle-xmark")"></i>
                                    @(isActive ? "Đang công tác" : "Đã nghỉ")
                                </span>
                            </div>
                        </div>
                        <div class="dtl-info-item">
                            <div class="dtl-info-label"><i class="fa-solid fa-image"></i> Ảnh đại diện</div>
                            <div class="dtl-info-val @(string.IsNullOrEmpty(Model.AnhDaiDien) ? "empty" : "")">
                                @(string.IsNullOrEmpty(Model.AnhDaiDien) ? "Tự động (từ tên)" : "URL tùy chỉnh")
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Academic info -->
            <div class="dtl-section">
                <div class="dtl-section-head">
                    <div class="dtl-section-icon"><i class="fa-solid fa-graduation-cap"></i></div>
                    <div>
                        <div class="dtl-section-title">Chuyên môn & Học vấn</div>
                        <div class="dtl-section-sub">Bằng cấp, kinh nghiệm và thành tích</div>
                    </div>
                </div>
                <div class="dtl-section-body">
                    <div class="dtl-info-grid">
                        <div class="dtl-info-item">
                            <div class="dtl-info-label"><i class="fa-solid fa-chalkboard"></i> Chuyên môn</div>
                            <div class="dtl-info-val @(string.IsNullOrEmpty(Model.ChuyenMon) ? "empty" : "")">
                                @(string.IsNullOrEmpty(Model.ChuyenMon) ? "Chưa cập nhật" : Model.ChuyenMon)
                            </div>
                        </div>
                        <div class="dtl-info-item">
                            <div class="dtl-info-label"><i class="fa-solid fa-scroll"></i> Bằng cấp</div>
                            <div class="dtl-info-val @(string.IsNullOrEmpty(Model.BangCap) ? "empty" : "")">
                                @(string.IsNullOrEmpty(Model.BangCap) ? "Chưa cập nhật" : Model.BangCap)
                            </div>
                        </div>
                        <div class="dtl-info-item">
                            <div class="dtl-info-label"><i class="fa-solid fa-briefcase"></i> Kinh nghiệm</div>
                            <div class="dtl-info-val @(string.IsNullOrEmpty(Model.KinhNghiem) ? "empty" : "")">
                                @(string.IsNullOrEmpty(Model.KinhNghiem) ? "Chưa cập nhật" : Model.KinhNghiem)
                            </div>
                        </div>
                        <div class="dtl-info-item">
                            <div class="dtl-info-label"><i class="fa-solid fa-trophy"></i> Thành tích</div>
                            <div class="dtl-info-val @(string.IsNullOrEmpty(Model.ThanhTich) ? "empty" : "")">
                                @(string.IsNullOrEmpty(Model.ThanhTich) ? "Chưa cập nhật" : Model.ThanhTich)
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bio (if exists) -->
            @if (!string.IsNullOrEmpty(Model.TieuSu))
            {
                <div class="dtl-section">
                    <div class="dtl-section-head">
                        <div class="dtl-section-icon"><i class="fa-solid fa-align-left"></i></div>
                        <div>
                            <div class="dtl-section-title">Tiểu sử</div>
                            <div class="dtl-section-sub">Giới thiệu bản thân</div>
                        </div>
                    </div>
                    <div class="dtl-section-body">
                        <div class="dtl-bio-block">@Model.TieuSu</div>
                    </div>
                </div>
            }

        </div><!-- /dtl-right -->
    </div><!-- /dtl-layout -->
</div>
