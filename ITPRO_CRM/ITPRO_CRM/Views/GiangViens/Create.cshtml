@model ITPRO_CRM.Models.GiangVien

@{
    ViewData["Title"] = "Thêm Giảng viên";
}



<style>
    @@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap');

    .frm-wrap * {
        font-family: 'Be Vietnam Pro', sans-serif;
        box-sizing: border-box;
    }

    .frm-wrap i {
        font-family: 'Font Awesome 6 Free', 'Font Awesome 6 Brands' !important;
    }

    /* ── Page Header ── */
    .frm-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 11.5px;
        color: var(--text3);
        margin-bottom: 6px;
        font-weight: 500;
        letter-spacing: .3px;
    }

        .frm-breadcrumb a {
            color: var(--text3);
            text-decoration: none;
        }

            .frm-breadcrumb a:hover {
                color: var(--accent);
            }

        .frm-breadcrumb i {
            font-size: 10px;
        }

    .frm-page-title {
        font-size: 22px;
        font-weight: 800;
        color: var(--text);
        letter-spacing: -.4px;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 4px;
    }

    .frm-page-title-icon {
        width: 38px;
        height: 38px;
        background: var(--accent);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 16px;
        flex-shrink: 0;
    }

    .frm-page-sub {
        font-size: 12.5px;
        color: var(--text2);
        margin-left: 48px;
        margin-bottom: 28px;
    }

    /* ── Layout ── */
    .frm-layout {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 24px;
        align-items: start;
    }

    /* ── Avatar Preview Panel ── */
    .frm-avatar-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 28px 20px;
        text-align: center;
        position: sticky;
        top: 20px;
    }

    .frm-avatar-preview {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid var(--surface);
        box-shadow: 0 0 0 2px var(--border);
        margin: 0 auto 14px;
        display: block;
        transition: box-shadow .2s;
    }

    .frm-avatar-name {
        font-size: 15px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 3px;
        min-height: 22px;
    }

    .frm-avatar-major {
        font-size: 12px;
        color: var(--accent);
        font-weight: 600;
        margin-bottom: 16px;
        min-height: 18px;
    }

    .frm-status-toggle {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 10px 14px;
        margin-bottom: 14px;
        cursor: pointer;
        user-select: none;
    }

    .frm-status-toggle-label {
        font-size: 12.5px;
        font-weight: 600;
        color: var(--text2);
    }

    .frm-toggle-switch {
        width: 38px;
        height: 21px;
        background: var(--border);
        border-radius: 20px;
        position: relative;
        transition: background .2s;
        flex-shrink: 0;
    }

        .frm-toggle-switch.on {
            background: var(--success);
        }

        .frm-toggle-switch::after {
            content: '';
            position: absolute;
            width: 15px;
            height: 15px;
            border-radius: 50%;
            background: #fff;
            top: 3px;
            left: 3px;
            transition: transform .2s;
            box-shadow: 0 1px 4px rgba(0,0,0,.2);
        }

        .frm-toggle-switch.on::after {
            transform: translateX(17px);
        }

    .frm-panel-tip {
        font-size: 11px;
        color: var(--text3);
        line-height: 1.5;
        border-top: 1px solid var(--border);
        padding-top: 14px;
        margin-top: 4px;
        text-align: left;
    }

        .frm-panel-tip i {
            color: var(--accent);
            margin-right: 4px;
        }

    /* ── Form Card ── */
    .frm-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
    }

    .frm-section-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 16px 24px;
        border-bottom: 1px solid var(--border);
        background: var(--surface2);
    }

    .frm-section-icon {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        background: var(--accent-dim);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
        font-size: 13px;
        flex-shrink: 0;
    }

    .frm-section-title {
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
    }

    .frm-section-sub {
        font-size: 11.5px;
        color: var(--text2);
        margin-top: 1px;
    }

    .frm-section-body {
        padding: 22px 24px;
    }

    /* ── Field Grid ── */
    .frm-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .frm-grid-1 {
        display: grid;
        grid-template-columns: 1fr;
        gap: 16px;
    }

    /* ── Field ── */
    .frm-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .frm-label {
        font-size: 12.5px;
        font-weight: 600;
        color: var(--text);
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .frm-label .req {
            color: var(--danger);
            font-size: 14px;
            line-height: 1;
        }

        .frm-label .tip {
            font-size: 11px;
            font-weight: 400;
            color: var(--text3);
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 1px 6px;
            margin-left: auto;
        }

    .frm-input, .frm-select, .frm-textarea {
        width: 100%;
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 9px;
        color: var(--text);
        padding: 10px 13px;
        font-size: 13px;
        font-family: 'Be Vietnam Pro', sans-serif;
        outline: none;
        transition: border-color .15s, box-shadow .15s, background .15s;
        line-height: 1.4;
    }

        .frm-input:focus, .frm-select:focus, .frm-textarea:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(var(--accent-rgb, 29,78,216), .1);
            background: var(--surface);
        }

        .frm-input::placeholder, .frm-textarea::placeholder {
            color: var(--text3);
        }

    .frm-textarea {
        resize: vertical;
        min-height: 90px;
    }

    .frm-input.has-icon {
        padding-left: 36px;
    }

    .frm-input-wrap {
        position: relative;
    }

    .frm-input-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text3);
        font-size: 12px;
        pointer-events: none;
    }

    .frm-val-msg {
        font-size: 11.5px;
        color: var(--danger);
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .frm-val-msg i {
            font-size: 11px;
        }

    /* ── Divider between sections ── */
    .frm-divider {
        height: 1px;
        background: var(--border);
        margin: 0;
    }

    /* ── Footer ── */
    .frm-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 24px;
        background: var(--surface2);
        border-top: 1px solid var(--border);
        gap: 12px;
        flex-wrap: wrap;
    }

    .frm-back-link {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-size: 13px;
        font-weight: 600;
        color: var(--text2);
        text-decoration: none;
        transition: color .13s;
    }

        .frm-back-link:hover {
            color: var(--text);
        }

    .frm-actions {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .frm-btn-reset {
        padding: 10px 18px;
        border-radius: 9px;
        font-size: 13px;
        font-weight: 600;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text2);
        cursor: pointer;
        transition: all .13s;
        font-family: 'Be Vietnam Pro', sans-serif;
    }

        .frm-btn-reset:hover {
            border-color: var(--border2);
            color: var(--text);
        }

    .frm-btn-submit {
        padding: 10px 24px;
        border-radius: 9px;
        font-size: 13px;
        font-weight: 700;
        background: var(--accent);
        color: #fff;
        border: none;
        cursor: pointer;
        transition: all .18s;
        font-family: 'Be Vietnam Pro', sans-serif;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 14px rgba(var(--accent-rgb, 29,78,216), .28);
    }

        .frm-btn-submit:hover {
            background: var(--accent-h);
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(var(--accent-rgb, 29,78,216), .36);
        }

    /* Validation summary */
    .frm-val-summary {
        background: var(--danger-dim);
        border: 1px solid var(--danger);
        border-radius: 10px;
        padding: 12px 16px;
        margin-bottom: 20px;
        font-size: 12.5px;
        color: var(--danger);
        font-weight: 500;
    }

        .frm-val-summary ul {
            margin: 6px 0 0 16px;
            padding: 0;
        }

        .frm-val-summary li {
            margin-bottom: 3px;
        }

    @@media (max-width: 768px) {
        .frm-layout {
            grid-template-columns: 1fr;
        }

        .frm-avatar-panel {
            position: static;
        }

        .frm-grid-2 {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="frm-wrap">

    <!-- Header -->
    <div class="frm-breadcrumb">
        <i class="fa-solid fa-house"></i>
        <a asp-action="Index">Giảng viên</a>
        <i class="fa-solid fa-chevron-right"></i> Thêm mới
    </div>
    <div class="frm-page-title">
        <div class="frm-page-title-icon"><i class="fa-solid fa-user-plus"></i></div>
        Thêm Giảng viên Mới
    </div>
    <div class="frm-page-sub">Điền đầy đủ thông tin để tạo hồ sơ giảng viên.</div>

    <!-- Validation summary -->
    <div asp-validation-summary="ModelOnly" class="frm-val-summary" style="display:none"></div>

    <form asp-action="Create" id="mainForm">

        <div class="frm-layout">

            <!-- Left: Avatar preview panel -->
            <div class="frm-avatar-panel">
                <img id="avatarPreview"
                     src="https://ui-avatars.com/api/?name=GV&background=1d4ed8&color=fff&size=160&bold=true"
                     class="frm-avatar-preview" alt="Avatar">
                <div class="frm-avatar-name" id="previewName">Họ và tên</div>
                <div class="frm-avatar-major" id="previewMajor">Chuyên môn</div>

                <!-- Status toggle (visual only — synced to hidden TrangThai input) -->
                <div class="frm-status-toggle" id="statusToggle" onclick="toggleStatus()">
                    <span class="frm-status-toggle-label" id="statusLabel">
                        <i class="fa-solid fa-circle-check me-1" style="color:var(--success)"></i>Đang công tác
                    </span>
                    <div class="frm-toggle-switch on" id="toggleSwitch"></div>
                </div>
                <input type="hidden" asp-for="TrangThai" id="TrangThai" value="1">

                <div class="frm-panel-tip">
                    <i class="fa-solid fa-circle-info"></i>
                    Ảnh đại diện được tự động tạo từ tên nếu không nhập URL. Bạn có thể cập nhật sau.
                </div>
            </div>

            <!-- Right: Form card -->
            <div class="frm-card">

                <!-- Section 1: Thông tin cơ bản -->
                <div class="frm-section-header">
                    <div class="frm-section-icon"><i class="fa-solid fa-user"></i></div>
                    <div>
                        <div class="frm-section-title">Thông tin cơ bản</div>
                        <div class="frm-section-sub">Tên, liên hệ và ảnh đại diện</div>
                    </div>
                </div>
                <div class="frm-section-body">
                    <div class="frm-grid-2">
                        <div class="frm-field" style="grid-column:1/-1">
                            <label class="frm-label" asp-for="HoTen">
                                Họ và Tên <span class="req">*</span>
                            </label>
                            <div class="frm-input-wrap">
                                <i class="fa-solid fa-user frm-input-icon"></i>
                                <input asp-for="HoTen" class="frm-input has-icon" placeholder="Nguyễn Văn A"
                                       oninput="syncPreview()" id="inpHoTen">
                            </div>
                            <span asp-validation-for="HoTen" class="frm-val-msg"></span>
                        </div>
                        <div class="frm-field">
                            <label class="frm-label" asp-for="Email">
                                Email <span class="req">*</span>
                            </label>
                            <div class="frm-input-wrap">
                                <i class="fa-solid fa-envelope frm-input-icon"></i>
                                <input asp-for="Email" class="frm-input has-icon" placeholder="gv@itpro.edu.vn" type="email">
                            </div>
                            <span asp-validation-for="Email" class="frm-val-msg"></span>
                        </div>
                        <div class="frm-field">
                            <label class="frm-label" asp-for="SoDienThoai">Số Điện Thoại</label>
                            <div class="frm-input-wrap">
                                <i class="fa-solid fa-phone frm-input-icon"></i>
                                <input asp-for="SoDienThoai" class="frm-input has-icon" placeholder="0901 234 567">
                            </div>
                            <span asp-validation-for="SoDienThoai" class="frm-val-msg"></span>
                        </div>
                        <div class="frm-field" style="grid-column:1/-1">
                            <label class="frm-label" asp-for="AnhDaiDien">
                                URL Ảnh Đại Diện
                                <span class="tip">Không bắt buộc</span>
                            </label>
                            <div class="frm-input-wrap">
                                <i class="fa-solid fa-image frm-input-icon"></i>
                                <input asp-for="AnhDaiDien" class="frm-input has-icon"
                                       placeholder="https://..." oninput="syncAvatar()" id="inpAnh">
                            </div>
                            <span asp-validation-for="AnhDaiDien" class="frm-val-msg"></span>
                        </div>
                    </div>
                </div>

                <div class="frm-divider"></div>

                <!-- Section 2: Chuyên môn -->
                <div class="frm-section-header">
                    <div class="frm-section-icon"><i class="fa-solid fa-graduation-cap"></i></div>
                    <div>
                        <div class="frm-section-title">Chuyên môn & Học vấn</div>
                        <div class="frm-section-sub">Bằng cấp, kinh nghiệm và lĩnh vực chuyên sâu</div>
                    </div>
                </div>
                <div class="frm-section-body">
                    <div class="frm-grid-2">
                        <div class="frm-field">
                            <label class="frm-label" asp-for="ChuyenMon">Chuyên Môn</label>
                            <div class="frm-input-wrap">
                                <i class="fa-solid fa-chalkboard frm-input-icon"></i>
                                <input asp-for="ChuyenMon" class="frm-input has-icon"
                                       placeholder="Lập trình Web, AI..." oninput="syncMajor()" id="inpCM">
                            </div>
                            <span asp-validation-for="ChuyenMon" class="frm-val-msg"></span>
                        </div>
                        <div class="frm-field">
                            <label class="frm-label" asp-for="BangCap">Bằng Cấp</label>
                            <div class="frm-input-wrap">
                                <i class="fa-solid fa-scroll frm-input-icon"></i>
                                <input asp-for="BangCap" class="frm-input has-icon" placeholder="Thạc sĩ, Tiến sĩ...">
                            </div>
                            <span asp-validation-for="BangCap" class="frm-val-msg"></span>
                        </div>
                        <div class="frm-field">
                            <label class="frm-label" asp-for="KinhNghiem">Kinh Nghiệm</label>
                            <div class="frm-input-wrap">
                                <i class="fa-solid fa-briefcase frm-input-icon"></i>
                                <input asp-for="KinhNghiem" class="frm-input has-icon" placeholder="5 năm, 10 năm...">
                            </div>
                            <span asp-validation-for="KinhNghiem" class="frm-val-msg"></span>
                        </div>
                        <div class="frm-field">
                            <label class="frm-label" asp-for="ThanhTich">Thành Tích</label>
                            <div class="frm-input-wrap">
                                <i class="fa-solid fa-trophy frm-input-icon"></i>
                                <input asp-for="ThanhTich" class="frm-input has-icon" placeholder="Giải thưởng, chứng chỉ...">
                            </div>
                            <span asp-validation-for="ThanhTich" class="frm-val-msg"></span>
                        </div>
                    </div>
                </div>

                <!-- Footer -->
                <div class="frm-footer">
                    <a asp-action="Index" class="frm-back-link">
                        <i class="fa-solid fa-arrow-left"></i> Quay lại danh sách
                    </a>
                    <div class="frm-actions">
                        <button type="reset" class="frm-btn-reset" onclick="resetPreview()">
                            <i class="fa-solid fa-rotate-left me-1"></i> Đặt lại
                        </button>
                        <button type="submit" class="frm-btn-submit">
                            <i class="fa-solid fa-floppy-disk"></i> Lưu Giảng viên
                        </button>
                    </div>
                </div>

            </div><!-- /frm-card -->
        </div><!-- /frm-layout -->

    </form>
</div>

<script>
    let statusOn = true;

    function syncPreview() {
        const name = document.getElementById('inpHoTen').value.trim();
        document.getElementById('previewName').textContent = name || 'Họ và tên';
        if (!document.getElementById('inpAnh').value.trim()) {
            const encoded = encodeURIComponent(name || 'GV');
            document.getElementById('avatarPreview').src =
                `https://ui-avatars.com/api/?name=${encoded}&background=1d4ed8&color=fff&size=160&bold=true`;
        }
    }

    function syncMajor() {
        const major = document.getElementById('inpCM').value.trim();
        document.getElementById('previewMajor').textContent = major || 'Chuyên môn';
    }

    function syncAvatar() {
        const url = document.getElementById('inpAnh').value.trim();
        if (url) {
            document.getElementById('avatarPreview').src = url;
        } else {
            syncPreview();
        }
    }

    function toggleStatus() {
        statusOn = !statusOn;
        document.getElementById('TrangThai').value = statusOn ? 1 : 0;
        const sw = document.getElementById('toggleSwitch');
        const lbl = document.getElementById('statusLabel');
        sw.classList.toggle('on', statusOn);
        lbl.innerHTML = statusOn
            ? '<i class="fa-solid fa-circle-check me-1" style="color:var(--success)"></i>Đang công tác'
            : '<i class="fa-solid fa-circle-xmark me-1" style="color:var(--text3)"></i>Đã nghỉ';
    }

    function resetPreview() {
        setTimeout(() => {
            document.getElementById('previewName').textContent = 'Họ và tên';
            document.getElementById('previewMajor').textContent = 'Chuyên môn';
            document.getElementById('avatarPreview').src =
                'https://ui-avatars.com/api/?name=GV&background=1d4ed8&color=fff&size=160&bold=true';
            if (!statusOn) toggleStatus();
        }, 10);
    }

    // Show validation summary if has errors
    const vs = document.querySelector('[data-valmsg-summary]');
    if (vs && vs.querySelector('li')) vs.style.display = '';
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
