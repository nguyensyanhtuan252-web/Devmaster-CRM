@model IEnumerable<ITPRO_CRM.Models.GiangVien>

@{
    ViewData["Title"] = "Đội ngũ Giảng viên";
    var total = Model.Count();
    var active = Model.Count(x => x.TrangThai == 1);
    var inactive = Model.Count(x => x.TrangThai != 1);
}



<style>
    @@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap');

    .gv-wrap * {
        font-family: 'Be Vietnam Pro', sans-serif;
        box-sizing: border-box;
    }

    .gv-wrap i {
        font-family: 'Font Awesome 6 Free', 'Font Awesome 6 Brands' !important;
    }

    /* ── Page Header ── */
    .gv-page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 28px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .gv-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 11.5px;
        color: var(--text3);
        margin-bottom: 6px;
        font-weight: 500;
        letter-spacing: .3px;
    }

        .gv-breadcrumb i {
            font-size: 10px;
        }

    .gv-page-title {
        font-size: 22px;
        font-weight: 800;
        color: var(--text);
        letter-spacing: -.4px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .gv-page-title-icon {
        width: 38px;
        height: 38px;
        background: var(--accent);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 16px;
        flex-shrink: 0;
    }

    .gv-page-sub {
        font-size: 12.5px;
        color: var(--text2);
        margin-top: 4px;
        margin-left: 48px;
        font-weight: 400;
    }

    .gv-add-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: var(--accent);
        color: #fff !important;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: all .18s;
        box-shadow: 0 4px 14px rgba(var(--accent-rgb, 29,78,216), .3);
        letter-spacing: .1px;
        flex-shrink: 0;
        margin-top: 4px;
    }

        .gv-add-btn:hover {
            background: var(--accent-h);
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(var(--accent-rgb, 29,78,216), .38);
        }

        .gv-add-btn i {
            font-size: 12px;
        }

    /* ── Stat Strip ── */
    .gv-stat-strip {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 22px;
    }

    .gv-stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 16px 18px;
        display: flex;
        align-items: center;
        gap: 14px;
        transition: border-color .15s, box-shadow .15s;
        position: relative;
        overflow: hidden;
    }

        .gv-stat-card::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2px;
            border-radius: 0 0 12px 12px;
        }

        .gv-stat-card.s-total::after {
            background: var(--accent);
        }

        .gv-stat-card.s-active::after {
            background: var(--success);
        }

        .gv-stat-card.s-inactive::after {
            background: var(--text3);
        }

        .gv-stat-card:hover {
            border-color: var(--border2);
            box-shadow: var(--shadow);
        }

    .gv-stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 17px;
        flex-shrink: 0;
    }

        .gv-stat-icon.t {
            background: var(--accent-dim);
            color: var(--accent);
        }

        .gv-stat-icon.a {
            background: var(--success-dim);
            color: var(--success);
        }

        .gv-stat-icon.i {
            background: var(--surface2);
            color: var(--text3);
        }

    .gv-stat-val {
        font-size: 26px;
        font-weight: 800;
        font-family: 'JetBrains Mono', monospace;
        letter-spacing: -1px;
        line-height: 1;
    }

    .gv-stat-lbl {
        font-size: 11.5px;
        color: var(--text2);
        margin-top: 3px;
        font-weight: 500;
    }

    /* ── Toolbar ── */
    .gv-toolbar {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .gv-search-wrap {
        position: relative;
        flex: 1;
        min-width: 200px;
        max-width: 320px;
    }

        .gv-search-wrap i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text3);
            font-size: 12px;
            pointer-events: none;
        }

    .gv-search {
        width: 100%;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 9px;
        color: var(--text);
        padding: 9px 12px 9px 34px;
        font-size: 13px;
        outline: none;
        transition: border-color .15s;
        font-family: 'Be Vietnam Pro', sans-serif;
    }

        .gv-search:focus {
            border-color: var(--accent);
        }

        .gv-search::placeholder {
            color: var(--text3);
        }

    .gv-filter-group {
        display: flex;
        gap: 4px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 9px;
        padding: 3px;
    }

    .gv-filter-btn {
        padding: 6px 14px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        border: none;
        background: transparent;
        color: var(--text2);
        cursor: pointer;
        transition: all .13s;
        white-space: nowrap;
        font-family: 'Be Vietnam Pro', sans-serif;
    }

        .gv-filter-btn.active {
            background: var(--accent);
            color: #fff;
            box-shadow: 0 2px 8px rgba(var(--accent-rgb, 29,78,216),.25);
        }

        .gv-filter-btn:not(.active):hover {
            background: var(--accent-dim);
            color: var(--accent);
        }

    .gv-result-count {
        margin-left: auto;
        font-size: 12px;
        color: var(--text3);
        font-weight: 500;
        white-space: nowrap;
    }

    /* ── Grid ── */
    .gv-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 16px;
    }

    /* ── Card ── */
    .gv-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        transition: transform .22s cubic-bezier(.34,1.56,.64,1), box-shadow .22s, border-color .22s;
        animation: cardIn .3s ease both;
        position: relative;
        display: flex;
        flex-direction: column;
    }

    @@keyframes cardIn {
        from {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .gv-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 36px rgba(0,0,0,.12);
        border-color: var(--border2);
    }

    .gv-card.inactive {
        opacity: .7;
    }

    /* Card top accent bar */
    .gv-card-bar {
        height: 4px;
        width: 100%;
    }

        .gv-card-bar.active {
            background: linear-gradient(90deg, var(--success), #34d399);
        }

        .gv-card-bar.inactive {
            background: var(--border);
        }

    .gv-card-body {
        padding: 20px;
        text-align: center;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    /* Avatar */
    .gv-avatar-ring {
        position: relative;
        display: inline-block;
        margin-bottom: 14px;
    }

    .gv-avatar {
        width: 76px;
        height: 76px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid var(--surface);
        box-shadow: 0 0 0 2px var(--border);
        display: block;
    }

    .gv-card:hover .gv-avatar {
        box-shadow: 0 0 0 2px var(--accent);
    }

    .gv-dot {
        position: absolute;
        bottom: 3px;
        right: 3px;
        width: 15px;
        height: 15px;
        border-radius: 50%;
        border: 2.5px solid var(--surface);
    }

        .gv-dot.on {
            background: var(--success);
        }

        .gv-dot.off {
            background: var(--text3);
        }

    .gv-name {
        font-size: 15px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 3px;
    }

    .gv-major {
        font-size: 12px;
        font-weight: 600;
        color: var(--accent);
        margin-bottom: 8px;
    }

    .gv-degree-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 3px 10px;
        color: var(--text2);
        margin-bottom: 10px;
        font-weight: 500;
    }

    .gv-exp-tag {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 10.5px;
        background: var(--accent-dim);
        color: var(--accent);
        border-radius: 5px;
        padding: 3px 8px;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .gv-bio {
        font-size: 12px;
        color: var(--text2);
        line-height: 1.6;
        margin-bottom: 14px;
        text-align: left;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex: 1;
    }

    /* Contact row */
    .gv-contacts {
        display: flex;
        justify-content: center;
        gap: 6px;
        margin-bottom: 14px;
    }

    .gv-icon-btn {
        width: 34px;
        height: 34px;
        border-radius: 9px;
        border: 1px solid var(--border);
        background: var(--surface2);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text2);
        text-decoration: none;
        transition: all .12s;
        font-size: 12.5px;
    }

        .gv-icon-btn:hover {
            background: var(--accent-dim);
            color: var(--accent);
            border-color: var(--accent);
        }

    /* Card footer actions */
    .gv-card-footer {
        display: flex;
        border-top: 1px solid var(--border);
    }

    .gv-foot-btn {
        flex: 1;
        padding: 10px 6px;
        font-size: 12px;
        font-weight: 600;
        text-align: center;
        text-decoration: none;
        color: var(--text2);
        cursor: pointer;
        transition: all .12s;
        border: none;
        background: transparent;
        font-family: 'Be Vietnam Pro', sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
    }

        .gv-foot-btn + .gv-foot-btn {
            border-left: 1px solid var(--border);
        }

        .gv-foot-btn:hover {
            background: var(--accent-dim);
            color: var(--accent);
        }

        .gv-foot-btn.del:hover {
            background: var(--danger-dim);
            color: var(--danger);
        }

    /* Status badge */
    .gv-status-badge {
        position: absolute;
        top: 14px;
        right: 14px;
        font-size: 10px;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 20px;
        letter-spacing: .3px;
    }

        .gv-status-badge.on {
            background: var(--success-dim);
            color: var(--success);
        }

        .gv-status-badge.off {
            background: var(--surface2);
            color: var(--text3);
        }

    /* Empty state */
    .gv-empty {
        grid-column: 1 / -1;
        text-align: center;
        padding: 80px 20px;
        color: var(--text2);
    }

    .gv-empty-icon {
        width: 72px;
        height: 72px;
        background: var(--surface2);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        color: var(--text3);
        margin: 0 auto 20px;
    }

    .gv-empty h3 {
        font-size: 16px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 6px;
    }

    .gv-empty p {
        font-size: 13px;
        color: var(--text2);
        margin-bottom: 20px;
    }

    @@media (max-width: 640px) {
        .gv-stat-strip {
            grid-template-columns: 1fr;
        }

        .gv-grid {
            grid-template-columns: 1fr 1fr;
        }

        .gv-result-count {
            display: none;
        }
    }

    @@media (max-width: 400px) {
        .gv-grid {
            grid-template-columns: 1fr;
        }
    }</style>

<div class="gv-wrap">

    <!-- Header -->
    <div class="gv-page-header">
        <div>
            <div class="gv-breadcrumb">
                <i class="fa-solid fa-house"></i> Trang chủ
                <i class="fa-solid fa-chevron-right"></i> Quản lý
                <i class="fa-solid fa-chevron-right"></i> Giảng viên
            </div>
            <div class="gv-page-title">
                <div class="gv-page-title-icon"><i class="fa-solid fa-chalkboard-user"></i></div>
                Đội ngũ Giảng viên
            </div>
            <div class="gv-page-sub">@total giảng viên — @active đang công tác · @inactive đã nghỉ</div>
        </div>
        <a asp-action="Create" class="gv-add-btn">
            <i class="fa-solid fa-user-plus"></i> Thêm Giảng viên
        </a>
    </div>

    <!-- Stats -->
    <div class="gv-stat-strip">
        <div class="gv-stat-card s-total">
            <div class="gv-stat-icon t"><i class="fa-solid fa-users"></i></div>
            <div>
                <div class="gv-stat-val">@total</div>
                <div class="gv-stat-lbl">Tổng giảng viên</div>
            </div>
        </div>
        <div class="gv-stat-card s-active">
            <div class="gv-stat-icon a"><i class="fa-solid fa-circle-check"></i></div>
            <div>
                <div class="gv-stat-val" style="color:var(--success)">@active</div>
                <div class="gv-stat-lbl">Đang công tác</div>
            </div>
        </div>
        <div class="gv-stat-card s-inactive">
            <div class="gv-stat-icon i"><i class="fa-solid fa-circle-xmark"></i></div>
            <div>
                <div class="gv-stat-val" style="color:var(--text3)">@inactive</div>
                <div class="gv-stat-lbl">Đã nghỉ</div>
            </div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="gv-toolbar">
        <div class="gv-search-wrap">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" class="gv-search" id="gvSearch" placeholder="Tìm theo tên, chuyên môn..." oninput="filterGV()">
        </div>
        <div class="gv-filter-group">
            <button class="gv-filter-btn active" id="btn-all" onclick="setFilter('all')">Tất cả</button>
            <button class="gv-filter-btn" id="btn-active" onclick="setFilter('active')">Đang công tác</button>
            <button class="gv-filter-btn" id="btn-inactive" onclick="setFilter('inactive')">Đã nghỉ</button>
        </div>
        <div class="gv-result-count" id="gvCount"></div>
    </div>

    <!-- Grid -->
    <div class="gv-grid" id="gvGrid">
        @foreach (var item in Model)
        {
            var avatarUrl = string.IsNullOrEmpty(item.AnhDaiDien)
            ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(item.HoTen)}&background=1d4ed8&color=fff&size=160&bold=true&font-size=0.35"
            : item.AnhDaiDien;
            var isActive = item.TrangThai == 1;
            var statusClass = isActive ? "active" : "inactive";

            <div class="gv-card @(!isActive ? "inactive" : "")"
                 data-name="@item.HoTen.ToLower()"
                 data-major="@(item.ChuyenMon?.ToLower() ?? "")"
                 data-status="@(isActive ? "active" : "inactive")">

                <div class="gv-card-bar @statusClass"></div>

                <div class="gv-card-body">
                    <span class="gv-status-badge @(isActive ? "on" : "off")">
                        @(isActive ? "Đang công tác" : "Đã nghỉ")
                    </span>

                    <div class="gv-avatar-ring">
                        <img src="@avatarUrl" class="gv-avatar" alt="@item.HoTen">
                        <span class="gv-dot @(isActive ? "on" : "off")"></span>
                    </div>

                    <div class="gv-name">@item.HoTen</div>

                    @if (!string.IsNullOrEmpty(item.ChuyenMon))
                    {
                        <div class="gv-major">@item.ChuyenMon</div>
                    }
                    @if (!string.IsNullOrEmpty(item.BangCap))
                    {
                        <div class="gv-degree-badge">
                            <i class="fa-solid fa-graduation-cap"></i>@item.BangCap
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(item.KinhNghiem))
                    {
                        <div>
                            <span class="gv-exp-tag"><i class="fa-solid fa-briefcase"></i>@item.KinhNghiem</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(item.TieuSu))
                    {
                        <div class="gv-bio">@item.TieuSu</div>
                    }

                    <div class="gv-contacts">
                        @if (!string.IsNullOrEmpty(item.Email))
                        {
                            <a href="mailto:@item.Email" class="gv-icon-btn" title="@item.Email">
                                <i class="fa-solid fa-envelope"></i>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(item.SoDienThoai))
                        {
                            <a href="tel:@item.SoDienThoai" class="gv-icon-btn" title="@item.SoDienThoai">
                                <i class="fa-solid fa-phone"></i>
                            </a>
                        }
                        <a asp-action="Details" asp-route-id="@item.Id" class="gv-icon-btn" title="Xem hồ sơ">
                            <i class="fa-solid fa-eye"></i>
                        </a>
                    </div>
                </div>

                <div class="gv-card-footer">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="gv-foot-btn">
                        <i class="fa-solid fa-pen"></i> Chỉnh sửa
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="gv-foot-btn del">
                        <i class="fa-solid fa-trash"></i> Xóa
                    </a>
                </div>
            </div>
        }
        @if (!Model.Any())
        {
            <div class="gv-empty">
                <div class="gv-empty-icon"><i class="fa-solid fa-chalkboard-user"></i></div>
                <h3>Chưa có giảng viên nào</h3>
                <p>Thêm giảng viên đầu tiên để bắt đầu quản lý đội ngũ.</p>
                <a asp-action="Create" class="gv-add-btn" style="display:inline-flex">
                    <i class="fa-solid fa-user-plus"></i> Thêm Giảng viên
                </a>
            </div>
        }
    </div>

</div>

<script>
    let gvFilter = 'all';

    function updateCount() {
        const visible = document.querySelectorAll('.gv-card:not([style*="none"])').length;
        const total = document.querySelectorAll('.gv-card').length;
        const el = document.getElementById('gvCount');
        if (el) el.textContent = visible < total ? `Hiển thị ${visible}/${total}` : `${total} giảng viên`;
    }

    function filterGV() {
        const q = document.getElementById('gvSearch').value.toLowerCase().trim();
        document.querySelectorAll('.gv-card').forEach(card => {
            const nameOk = !q || (card.dataset.name || '').includes(q) || (card.dataset.major || '').includes(q);
            const statusOk = gvFilter === 'all' || card.dataset.status === gvFilter;
            card.style.display = (nameOk && statusOk) ? '' : 'none';
        });
        updateCount();
    }

    function setFilter(f) {
        gvFilter = f;
        document.querySelectorAll('.gv-filter-btn[id^="btn-"]').forEach(b => b.classList.remove('active'));
        document.getElementById('btn-' + f).classList.add('active');
        filterGV();
    }

    // Stagger card animations
    document.querySelectorAll('.gv-card').forEach((c, i) => {
        c.style.animationDelay = (i * 40) + 'ms';
    });

    updateCount();
</script>
