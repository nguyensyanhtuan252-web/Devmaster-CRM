@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Cảm ơn bạn đã đăng ký</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light d-flex align-items-center" style="min-height: 100vh;">
    <div class="container text-center">
        <div class="card border-0 shadow-sm mx-auto p-5" style="max-width: 500px; border-radius: 16px;">
            <div class="mb-4">
                <div style="width: 80px; height: 80px; background: #d1fae5; color: #10b981; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 40px; margin: 0 auto;">
                    ✓
                </div>
            </div>
            <h3 class="fw-bold mb-3">Đăng ký thành công!</h3>
            <p class="text-muted mb-4">Cảm ơn bạn đã quan tâm. Chuyên viên tư vấn của trung tâm sẽ liên hệ với bạn qua số điện thoại trong thời gian sớm nhất.</p>
            
        </div>
    </div>
</body>
</html>