@model ITPRO_CRM.Models.HocVien
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký nhận tư vấn - ITPRO CRM</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;700;800;900&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Montserrat', sans-serif;
            margin: 0;
            /* Tạo đường cắt chéo Nền Cam - Xanh y hệt ảnh mẫu */
            background: linear-gradient(105deg, #ff7a00 0%, #ff7a00 55%, #004aad 55%, #004aad 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            color: white;
            background-attachment: fixed;
        }

        /* KHỐI CHỮ BÊN TRÁI */
        .left-content {
            padding-right: 50px;
        }

        .main-heading {
            font-size: 52px;
            font-weight: 900;
            line-height: 1.1;
            text-transform: uppercase;
            text-shadow: 2px 4px 10px rgba(0,0,0,0.2);
            margin-bottom: 20px;
        }

        .highlight-box {
            background-color: #004aad;
            color: white;
            display: inline-block;
            padding: 10px 25px;
            font-size: 38px;
            font-weight: 900;
            border: 4px solid white;
            box-shadow: 6px 6px 0px rgba(0,0,0,0.2);
            transform: rotate(-2deg);
            margin-bottom: 20px;
        }

        /* KHỐI FORM MỜ BÊN PHẢI */
        .form-glass {
            /* Màu nền hơi nâu/cam mờ giống hệt khối form trong ảnh */
            background: rgba(139, 69, 19, 0.35);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 35px 30px;
            border-radius: 8px;
            width: 100%;
            max-width: 450px;
            margin-left: auto;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
        }

        .form-title {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .form-subtitle {
            font-size: 13px;
            margin-bottom: 25px;
            opacity: 0.9;
        }

        .form-control, .form-select {
            border-radius: 2px;
            padding: 12px 15px;
            border: none;
            margin-bottom: 15px;
            font-size: 14px;
            color: #333;
            background: #fff;
        }

            .form-control:focus, .form-select:focus {
                box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.5);
                outline: none;
            }

        /* Chữ đỏ cho dấu sao bắt buộc */
        .req-star {
            color: #dc3545;
            font-weight: bold;
        }

        /* Nút Submit bo tròn màu cam */
        .btn-submit {
            background-color: #ff7a00;
            color: #fff;
            font-weight: 700;
            border-radius: 30px;
            padding: 12px;
            width: 100%;
            border: 2px solid #ff7a00;
            transition: all 0.3s ease;
            font-size: 16px;
            margin-top: 10px;
        }

            .btn-submit:hover {
                background-color: transparent;
                color: #fff;
                border-color: #fff;
            }

        .privacy-box {
            font-size: 12px;
            line-height: 1.5;
            opacity: 0.85;
            margin-top: 15px;
            display: flex;
            align-items: flex-start;
            gap: 8px;
        }

        /* Reponsive Mobile: Chuyển vát xéo thành vát ngang */
        @@media (max-width: 991px) {
            body {
                background: linear-gradient(180deg, #ff7a00 0%, #ff7a00 40%, #004aad 40%, #004aad 100%);
                padding: 40px 0;
            }

            .left-content {
                padding-right: 0;
                text-align: center;
                margin-bottom: 40px;
            }

            .form-glass {
                margin: 0 auto;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row align-items-center">

            <div class="col-lg-6 left-content">
                <div class="main-heading">
                    LẬP TRÌNH TÍCH HỢP
                    <br /><span style="font-size: 70px;">ITPRO</span>
                </div>

                <div class="highlight-box">
                    UTC 2026
                </div>

                <h4 class="fw-bold mt-2">
                    Chương trình đào tạo CNTT
                    <br />Định hướng thực chiến doanh nghiệp
                </h4>
            </div>

            <div class="col-lg-6">
                <div class="form-glass">
                    <div class="form-title">Đăng ký nhận tư vấn tại đây!</div>
                    <div class="form-subtitle">
                        (Khóa học từ chiến dịch: <strong>@ViewBag.TenChienDich</strong>)
                    </div>

                    <form asp-action="DangKy" method="post">
                        <input type="hidden" asp-for="ChienDichId" value="@ViewBag.ChienDichId" />

                        <input asp-for="HoTen" class="form-control" placeholder="Họ và Tên *" required />

                        <input asp-for="Email" type="email" class="form-control" placeholder="Email" />

                        <input asp-for="SoDienThoai" type="tel" class="form-control" placeholder="Số điện thoại *" required />

                        <select asp-for="MucTieuHocTap" class="form-select">
                            <option value="">-- Khóa học bạn quan tâm --</option>
                            <option value="Lập trình .NET Fullstack">Lập trình .NET Fullstack</option>
                            <option value="Lập trình Java Web">Lập trình Java Web</option>
                            <option value="Phân tích nghiệp vụ BA">Phân tích nghiệp vụ (BA)</option>
                        </select>

                        <div class="privacy-box">
                            <input type="checkbox" id="chkPrivacy" required checked style="margin-top: 3px;">
                            <label for="chkPrivacy">
                                Đồng ý để dữ liệu cá nhân của Anh/Chị được thu thập trên trang này, được xử lý và lưu trữ bởi tổ chức giáo dục ITPRO (UTC) cho mục đích tư vấn.
                            </label>
                        </div>

                        <button type="submit" class="btn-submit">
                            Đăng ký tư vấn
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</body>
</html>