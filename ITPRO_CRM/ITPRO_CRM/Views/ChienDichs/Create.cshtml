@model ITPRO_CRM.Models.ChienDich
@{
    ViewData["Title"] = "Tạo Chiến Dịch Mới";
}
<style>
    .form-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
    }

    .form-hdr {
        padding: 18px 24px;
        border-bottom: 1px solid var(--border);
        background: var(--surface2);
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .form-hdr-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        background: var(--accent-dim);
        color: var(--accent);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
    }

    .form-section {
        border-bottom: 1px solid var(--border);
        padding: 22px 24px;
    }

        .form-section:last-of-type {
            border-bottom: none;
        }

    .section-label {
        font-size: 10.5px;
        font-weight: 700;
        color: var(--text3);
        text-transform: uppercase;
        letter-spacing: 1.2px;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .section-label i {
            color: var(--accent);
        }

    .fld-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--text2);
        margin-bottom: 6px;
        display: block;
    }

        .fld-label span {
            color: var(--danger);
        }

    .fld-input, .fld-select, .fld-textarea {
        width: 100%;
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 9px;
        padding: 10px 13px;
        font-size: 13px;
        color: var(--text);
        outline: none;
        transition: border-color .15s, box-shadow .15s;
        font-family: inherit;
    }

        .fld-input:focus, .fld-select:focus, .fld-textarea:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-dim);
        }

        .fld-input::placeholder, .fld-textarea::placeholder {
            color: var(--text3);
        }

    .fld-textarea {
        resize: vertical;
        min-height: 90px;
    }

    .input-group-dm {
        display: flex;
    }

        .input-group-dm .fld-input {
            border-radius: 9px 0 0 9px;
        }

    .input-addon {
        background: var(--border);
        border: 1px solid var(--border);
        border-left: none;
        border-radius: 0 9px 9px 0;
        padding: 0 14px;
        display: flex;
        align-items: center;
        font-size: 12px;
        font-weight: 700;
        color: var(--text2);
        white-space: nowrap;
    }

    .form-grid {
        display: grid;
        gap: 16px;
    }

        .form-grid.two {
            grid-template-columns: 1fr 1fr;
        }

        .form-grid.three {
            grid-template-columns: 1fr 1fr 1fr;
        }

    .btn-dm {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 10px 20px;
        border-radius: 9px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: .15s;
        text-decoration: none;
        border: none;
    }

        .btn-dm.primary {
            background: var(--accent);
            color: #fff;
        }

            .btn-dm.primary:hover {
                background: var(--accent-h);
                color: #fff;
            }

        .btn-dm.ghost {
            background: var(--surface2);
            color: var(--text2);
            border: 1px solid var(--border);
        }

            .btn-dm.ghost:hover {
                background: var(--border);
                color: var(--text);
            }

    .type-option {
        border: 1.5px solid var(--border);
        border-radius: 10px;
        padding: 14px;
        cursor: pointer;
        transition: .15s;
        text-align: center;
        background: var(--surface2);
    }

        .type-option:hover, .type-option.selected {
            border-color: var(--accent);
            background: var(--accent-dim);
        }

        .type-option i {
            font-size: 20px;
            margin-bottom: 7px;
            display: block;
        }

        .type-option span {
            font-size: 11.5px;
            font-weight: 600;
            color: var(--text);
        }

    .toggle-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .toggle-switch {
        width: 44px;
        height: 24px;
        background: var(--border2);
        border-radius: 12px;
        position: relative;
        cursor: pointer;
        transition: .2s;
    }

        .toggle-switch.on {
            background: var(--success);
        }

        .toggle-switch::after {
            content: '';
            position: absolute;
            top: 3px;
            left: 3px;
            width: 18px;
            height: 18px;
            background: #fff;
            border-radius: 50%;
            transition: .2s;
            box-shadow: 0 1px 4px rgba(0,0,0,.3);
        }

        .toggle-switch.on::after {
            left: 23px;
        }

    .helper-text {
        font-size: 11px;
        color: var(--text3);
        margin-top: 5px;
    }

    @@media (max-width:640px) {
        .form-grid.two, .form-grid.three {
            grid-template-columns: 1fr;
        }
    }
</style>

<div style="max-width:820px;margin:0 auto">
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:18px">
        <a asp-action="Index" style="width:32px;height:32px;border-radius:8px;border:1px solid var(--border);background:var(--surface2);display:flex;align-items:center;justify-content:center;color:var(--text2);text-decoration:none;font-size:13px;transition:.15s" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
            <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div style="font-size:13px;color:var(--text2)">
            <a asp-action="Index" style="color:var(--accent);text-decoration:none">Chiến dịch</a>
            <i class="fa-solid fa-chevron-right" style="font-size:9px;margin:0 6px;color:var(--text3)"></i>
            Tạo mới
        </div>
    </div>

    <div class="form-card">
        <div class="form-hdr">
            <div class="form-hdr-icon"><i class="fa-solid fa-bullhorn"></i></div>
            <div>
                <div style="font-size:14px;font-weight:700;color:var(--text)">Tạo chiến dịch Marketing mới</div>
                <div style="font-size:11.5px;color:var(--text2);margin-top:2px">Điền đầy đủ thông tin để theo dõi hiệu quả</div>
            </div>
        </div>

        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert" style="margin:16px 24px 0;background:var(--danger-dim);border:1px solid var(--danger);border-radius:9px;padding:10px 14px;font-size:12.5px;color:var(--danger)"></div>

            <!-- SECTION 1: Thông tin cơ bản -->
            <div class="form-section">
                <div class="section-label"><i class="fa-solid fa-circle-info"></i> Thông tin cơ bản</div>
                <div class="form-grid two">
                    <div style="grid-column:1/-1">
                        <label class="fld-label">Tên chiến dịch <span>*</span></label>
                        <input asp-for="TenChienDich" class="fld-input" placeholder="VD: Tuyển sinh Hè 2026 — Facebook Ads" required />
                        <span asp-validation-for="TenChienDich" class="helper-text" style="color:var(--danger)"></span>
                    </div>
                    <div>
                        <label class="fld-label">Loại chiến dịch / Nguồn</label>
                        <select asp-for="LoaiChienDich" class="fld-select">
                            <option value="Facebook Ads">📱 Facebook Ads</option>
                            <option value="Google Ads">🔍 Google Ads</option>
                            <option value="Tiktok Ads">🎵 Tiktok Ads</option>
                            <option value="Email Marketing">📧 Email Marketing</option>
                            <option value="Sự kiện Offline">🎪 Sự kiện / Hội thảo Offline</option>
                            <option value="Giới thiệu">🤝 Khách hàng giới thiệu (Referral)</option>
                            <option value="Zalo Ads">💬 Zalo Ads</option>
                            <option value="YouTube Ads">▶️ YouTube Ads</option>
                            <option value="Khác">📌 Khác</option>
                        </select>
                    </div>
                    <div>
                        <label class="fld-label">Trạng thái ban đầu</label>
                        <select asp-for="DangHoatDong" class="fld-select">
                            <option value="true">🟢 Đang hoạt động — Kích hoạt ngay</option>
                            <option value="false">⏸️ Bản nháp — Chưa chạy</option>
                        </select>
                    </div>
                    <div style="grid-column:1/-1">
                        <label class="fld-label">Mô tả / Ghi chú</label>
                        <textarea asp-for="MoTa" class="fld-textarea" placeholder="Mục tiêu chiến dịch, đối tượng, link ảnh quảng cáo, ghi chú quan trọng..."></textarea>
                    </div>
                </div>
            </div>

            <!-- SECTION 2: Kế hoạch thời gian -->
            <div class="form-section">
                <div class="section-label"><i class="fa-solid fa-calendar-days"></i> Kế hoạch thời gian</div>
                <div class="form-grid three">
                    <div>
                        <label class="fld-label">Ngày bắt đầu</label>
                        <input asp-for="NgayBatDau" type="date" class="fld-input" />
                        <span asp-validation-for="NgayBatDau" class="helper-text" style="color:var(--danger)"></span>
                    </div>
                    <div>
                        <label class="fld-label">Ngày kết thúc</label>
                        <input asp-for="NgayKetThuc" type="date" class="fld-input" />
                        <span asp-validation-for="NgayKetThuc" class="helper-text" style="color:var(--danger)"></span>
                    </div>
                    <div>
                        <label class="fld-label">Thời gian dự kiến</label>
                        <div class="fld-input" id="durationDisplay" style="color:var(--text2);cursor:default">Chọn ngày để tính</div>
                    </div>
                </div>
            </div>

            <!-- SECTION 3: Tài chính -->
            <div class="form-section">
                <div class="section-label"><i class="fa-solid fa-coins"></i> Tài chính &amp; ROI</div>
                <div class="form-grid two">
                    <div>
                        <label class="fld-label">Chi phí đầu tư dự kiến</label>
                        <div class="input-group-dm">
                            <input asp-for="NganSach" type="number" class="fld-input" placeholder="0" min="0" oninput="calcRoi()" />
                            <div class="input-addon" style="color:var(--danger)">VNĐ</div>
                        </div>
                        <div class="helper-text">Ngân sách thực tế đầu tư cho chiến dịch</div>
                        <span asp-validation-for="NganSach" class="helper-text" style="color:var(--danger)"></span>
                    </div>
                    <div>
                        <label class="fld-label">Ngân sách phê duyệt</label>
                        <div class="input-group-dm">
                            <input asp-for="NganSachDuKien" type="number" class="fld-input" placeholder="0" min="0" />
                            <div class="input-addon" style="color:var(--warning)">VNĐ</div>
                        </div>
                        <div class="helper-text">Ngân sách được duyệt / phân bổ</div>
                    </div>
                    <div>
                        <label class="fld-label">Doanh thu kỳ vọng</label>
                        <div class="input-group-dm">
                            <input asp-for="DoanhThuKyVong" type="number" class="fld-input" placeholder="0" min="0" oninput="calcRoi()" />
                            <div class="input-addon" style="color:var(--success)">VNĐ</div>
                        </div>
                        <div class="helper-text">Doanh thu học phí dự kiến từ chiến dịch này</div>
                        <span asp-validation-for="DoanhThuKyVong" class="helper-text" style="color:var(--danger)"></span>
                    </div>
                    <div>
                        <label class="fld-label">ROI ước tính</label>
                        <div class="fld-input" id="roiDisplay" style="cursor:default;font-family:'DM Mono',monospace;font-size:16px;font-weight:700;text-align:center">—</div>
                        <div class="helper-text">(Doanh thu - Chi phí) / Chi phí × 100%</div>
                    </div>
                </div>
            </div>

            <!-- FOOTER ACTIONS -->
            <div style="padding:18px 24px;background:var(--surface2);border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:10px">
                <a asp-action="Index" class="btn-dm ghost">Hủy</a>
                <button type="reset" class="btn-dm ghost">Nhập lại</button>
                <button type="submit" class="btn-dm primary">
                    <i class="fa-solid fa-rocket"></i> Tạo chiến dịch
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function calcRoi() {
            const ns = parseFloat(document.querySelector('[name="NganSach"]').value) || 0;
            const kv = parseFloat(document.querySelector('[name="DoanhThuKyVong"]').value) || 0;
            const el = document.getElementById('roiDisplay');
            if (ns <= 0) { el.textContent = '—'; el.style.color = 'var(--text2)'; return; }
            const roi = ((kv - ns) / ns * 100).toFixed(1);
            el.textContent = (roi >= 0 ? '+' : '') + roi + '%';
            el.style.color = roi >= 0 ? 'var(--success)' : 'var(--danger)';
        }
        function calcDuration() {
            const bd = document.querySelector('[name="NgayBatDau"]').value;
            const kt = document.querySelector('[name="NgayKetThuc"]').value;
            const el = document.getElementById('durationDisplay');
            if (bd && kt) {
                const days = Math.round((new Date(kt) - new Date(bd)) / 86400000);
                el.textContent = days > 0 ? days + ' ngày' : (days === 0 ? 'Cùng ngày' : 'Ngày không hợp lệ');
                el.style.color = days > 0 ? 'var(--text)' : 'var(--danger)';
            }
        }
        document.querySelector('[name="NgayBatDau"]').addEventListener('change', calcDuration);
        document.querySelector('[name="NgayKetThuc"]').addEventListener('change', calcDuration);
    </script>
}
