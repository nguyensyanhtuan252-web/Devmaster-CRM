@{
    ViewData["Title"] = "Đổi mật khẩu bảo mật";
}

<style>
    /* ─── CSS VARIABLES ─────────────────────────────────────────────── */
    :root {
        --cp-bg: transparent;
        --cp-card-bg: #ffffff;
        --cp-card-border: rgba(0,0,0,0.07);
        --cp-card-shadow: 0 10px 40px rgba(0,0,0,0.08);
        --cp-text-h: #12172b;
        --cp-text-sub: #6b7494;
        --cp-label: #7a84a0;
        --cp-input-bg: #f4f6fb;
        --cp-input-bg-f: #ffffff;
        --cp-input-border: #dde1ef;
        --cp-input-border-f: #2d5be3;
        --cp-input-shadow-f: rgba(45,91,227,0.12);
        --cp-input-text: #12172b;
        --cp-placeholder: #b0b8d4;
        --cp-icon: #8c95ae;
        --cp-icon-focus: #2d5be3;
        --cp-toggle: #8c95ae;
        --cp-toggle-hover: #2d5be3;
        --cp-divider: rgba(0,0,0,0.07);
        --cp-icon-wrap-bg: rgba(45,91,227,0.08);
        --cp-icon-wrap-clr: #2d5be3;
        --cp-btn-bg: #2d5be3;
        --cp-btn-hover: #1d46c9;
        --cp-btn-shadow: rgba(45,91,227,0.25);
        --cp-btn-back-bg: transparent;
        --cp-btn-back-bdr: #dde1ef;
        --cp-btn-back-clr: #6b7494;
        --cp-btn-back-hover: #f4f6fb;
        --cp-strength-track: #e4e8f5;
        --cp-alert-err-bg: rgba(239,68,68,0.07);
        --cp-alert-err-bdr: rgba(239,68,68,0.2);
        --cp-alert-err-clr: #b91c1c;
        --cp-alert-ok-bg: rgba(16,185,129,0.07);
        --cp-alert-ok-bdr: rgba(16,185,129,0.2);
        --cp-alert-ok-clr: #047857;
        --cp-tip-bg: rgba(45,91,227,0.06);
        --cp-tip-bdr: rgba(45,91,227,0.14);
        --cp-tip-clr: #3d5fb0;
    }

    [data-theme="dark"] {
        --cp-bg: transparent;
        --cp-card-bg: #161b27;
        --cp-card-border: rgba(255,255,255,0.06);
        --cp-card-shadow: 0 10px 40px rgba(0,0,0,0.3);
        --cp-text-h: #e8ecf8;
        --cp-text-sub: #7a88b0;
        --cp-label: #6b78a0;
        --cp-input-bg: #1c2333;
        --cp-input-bg-f: #202d44;
        --cp-input-border: rgba(255,255,255,0.08);
        --cp-input-border-f: #4f8ef7;
        --cp-input-shadow-f: rgba(79,142,247,0.15);
        --cp-input-text: #d8dff5;
        --cp-placeholder: #3d4a68;
        --cp-icon: #4a5880;
        --cp-icon-focus: #4f8ef7;
        --cp-toggle: #4a5880;
        --cp-toggle-hover: #4f8ef7;
        --cp-divider: rgba(255,255,255,0.07);
        --cp-icon-wrap-bg: rgba(79,142,247,0.12);
        --cp-icon-wrap-clr: #7fb3ff;
        --cp-btn-bg: #2d5be3;
        --cp-btn-hover: #4f8ef7;
        --cp-btn-shadow: rgba(45,91,227,0.25);
        --cp-btn-back-bg: transparent;
        --cp-btn-back-bdr: rgba(255,255,255,0.1);
        --cp-btn-back-clr: #7a88b0;
        --cp-btn-back-hover: rgba(255,255,255,0.05);
        --cp-strength-track: rgba(255,255,255,0.08);
        --cp-alert-err-bg: rgba(239,68,68,0.10);
        --cp-alert-err-bdr: rgba(239,68,68,0.25);
        --cp-alert-err-clr: #f87171;
        --cp-alert-ok-bg: rgba(52,211,153,0.08);
        --cp-alert-ok-bdr: rgba(52,211,153,0.25);
        --cp-alert-ok-clr: #34d399;
        --cp-tip-bg: rgba(79,142,247,0.08);
        --cp-tip-bdr: rgba(79,142,247,0.15);
        --cp-tip-clr: #7fb3ff;
    }

    /* ─── LAYOUT ────────────────────────────────────────────────────── */
    .cp-page {
        font-family: 'Inter', sans-serif;
        background: var(--cp-bg);
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem 1rem;
        transition: background 0.3s ease;
    }

    .cp-container {
        width: 100%;
        max-width: 420px; /* Đã thu nhỏ chiều ngang */
        animation: cpFadeUp 0.45s cubic-bezier(0.16,1,0.3,1) both;
    }

    @@keyframes cpFadeUp {
        from {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ─── CARD ──────────────────────────────────────────────────────── */
    .cp-card {
        background: var(--cp-card-bg);
        border: 1px solid var(--cp-card-border);
        border-radius: 16px;
        box-shadow: var(--cp-card-shadow);
        overflow: hidden;
        transition: background 0.3s ease, box-shadow 0.3s ease;
    }

    .cp-card-top-bar {
        height: 3px;
        background: linear-gradient(90deg, #1a3a8f 0%, #2d5be3 50%, #4f8ef7 100%);
    }

    .cp-card-inner {
        padding: 24px 28px 24px; /* Đã giảm padding để bớt khoảng trống */
    }

    /* ─── HEADER ────────────────────────────────────────────────────── */
    .cp-head {
        text-align: center;
        margin-bottom: 20px;
    }

    .cp-shield-wrap {
        width: 54px; /* Đã thu nhỏ icon */
        height: 54px;
        border-radius: 50%;
        background: var(--cp-icon-wrap-bg);
        color: var(--cp-icon-wrap-clr);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        margin: 0 auto 12px;
        position: relative;
    }

    .cp-title {
        font-family: 'Inter', sans-serif;
        font-size: 1.25rem; /* Đã thu nhỏ tiêu đề */
        font-weight: 700;
        color: var(--cp-text-h);
        margin: 0 0 6px;
        line-height: 1.2;
    }

    .cp-subtitle {
        font-size: 0.78rem;
        color: var(--cp-text-sub);
        line-height: 1.4;
        margin: 0;
    }

    /* ─── ALERTS ────────────────────────────────────────────────────── */
    .cp-alert {
        border-radius: 8px;
        padding: 10px 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.8rem;
        font-weight: 500;
        margin-bottom: 16px;
    }

    .cp-alert-error {
        background: var(--cp-alert-err-bg);
        border: 1px solid var(--cp-alert-err-bdr);
        color: var(--cp-alert-err-clr);
    }

    .cp-alert-success {
        background: var(--cp-alert-ok-bg);
        border: 1px solid var(--cp-alert-ok-bdr);
        color: var(--cp-alert-ok-clr);
    }

    /* ─── FORM FIELDS ───────────────────────────────────────────────── */
    .cp-field {
        margin-bottom: 14px; /* Thu gọn khoảng cách form */
    }

    .cp-label {
        display: block;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        color: var(--cp-label);
        margin-bottom: 6px;
    }

    .cp-input-wrap {
        display: flex;
        align-items: center;
        background: var(--cp-input-bg);
        border: 1px solid var(--cp-input-border);
        border-radius: 10px;
        overflow: hidden;
        transition: all 0.22s ease;
    }

        .cp-input-wrap:focus-within {
            background: var(--cp-input-bg-f);
            border-color: var(--cp-input-border-f);
            box-shadow: 0 0 0 3px var(--cp-input-shadow-f);
        }

    .cp-icon {
        padding: 0 12px;
        color: var(--cp-icon);
        font-size: 13px;
    }

    .cp-input-wrap:focus-within .cp-icon {
        color: var(--cp-icon-focus);
    }

    .cp-input {
        flex: 1;
        border: none;
        background: transparent;
        padding: 10px 8px 10px 0; /* Thu gọn form nhập */
        font-size: 0.85rem;
        font-family: 'Inter', sans-serif;
        color: var(--cp-input-text);
        outline: none;
        min-width: 0;
        letter-spacing: 1px;
    }

        .cp-input::placeholder {
            color: var(--cp-placeholder);
            letter-spacing: 2px;
        }

    .cp-toggle-btn {
        padding: 0 12px;
        border: none;
        background: transparent;
        color: var(--cp-toggle);
        font-size: 13px;
        cursor: pointer;
    }

        .cp-toggle-btn:hover {
            color: var(--cp-toggle-hover);
        }

    /* ─── PASSWORD STRENGTH ─────────────────────────────────────────── */
    .cp-strength {
        margin-top: 6px;
    }

    .cp-strength-track {
        height: 3px;
        border-radius: 3px;
        background: var(--cp-strength-track);
        overflow: hidden;
    }

    .cp-strength-fill {
        height: 100%;
        border-radius: 3px;
        width: 0%;
        transition: width 0.4s ease, background 0.4s ease;
    }

    .cp-strength-text {
        font-size: 10px;
        margin-top: 4px;
        font-weight: 600;
    }

    /* ─── TIP BOX ───────────────────────────────────────────────────── */
    .cp-tip {
        background: var(--cp-tip-bg);
        border: 1px solid var(--cp-tip-bdr);
        border-radius: 8px;
        padding: 10px 14px;
        display: flex;
        align-items: flex-start;
        gap: 8px;
        margin-bottom: 18px;
        font-size: 0.75rem;
        color: var(--cp-tip-clr);
        line-height: 1.5;
    }

        .cp-tip i {
            margin-top: 2px;
            flex-shrink: 0;
        }

    /* ─── DIVIDER ───────────────────────────────────────────────────── */
    .cp-sep {
        height: 1px;
        background: var(--cp-divider);
        margin: 18px 0;
    }

    /* ─── BUTTONS ───────────────────────────────────────────────────── */
    .cp-btn-primary {
        width: 100%;
        padding: 11px 16px;
        border: none;
        border-radius: 10px;
        background: var(--cp-btn-bg);
        color: #fff;
        font-size: 0.85rem;
        font-weight: 700;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        margin-bottom: 8px;
        transition: all 0.2s ease;
    }

        .cp-btn-primary:hover {
            background: var(--cp-btn-hover);
            transform: translateY(-1px);
        }

    .cp-btn-back {
        width: 100%;
        padding: 10px 16px;
        border: 1.5px solid var(--cp-btn-back-bdr);
        border-radius: 10px;
        background: var(--cp-btn-back-bg);
        color: var(--cp-btn-back-clr);
        font-size: 0.82rem;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-decoration: none;
        transition: all 0.2s ease;
    }

        .cp-btn-back:hover {
            background: var(--cp-btn-back-hover);
            color: var(--cp-btn-back-clr);
        }
</style>

<div class="cp-page">
    <div class="cp-container">
        <div class="cp-card">
            <div class="cp-card-top-bar"></div>
            <div class="cp-card-inner">

                <div class="cp-head">
                    <div class="cp-shield-wrap">
                        <i class="fa-solid fa-shield-halved"></i>
                    </div>
                    <h1 class="cp-title">Đổi mật khẩu</h1>
                    <p class="cp-subtitle">Bảo vệ tài khoản bằng mật khẩu mạnh. Không chia sẻ với ai.</p>
                </div>

                @if (TempData["Success"] != null)
                {
                    <div class="cp-alert cp-alert-success">
                        <i class="fa-solid fa-circle-check"></i>
                        <span>@TempData["Success"]</span>
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="cp-alert cp-alert-error">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        <span>@TempData["Error"]</span>
                    </div>
                }

                <div class="cp-tip">
                    <i class="fa-solid fa-circle-info"></i>
                    <span>Mật khẩu mạnh nên có ít nhất <strong>8 ký tự</strong>, bao gồm chữ, số và ký tự đặc biệt.</span>
                </div>

                <form asp-action="ChangePassword" method="post" id="cpForm">

                    <div class="cp-field">
                        <label class="cp-label">Mật khẩu hiện tại</label>
                        <div class="cp-input-wrap">
                            <span class="cp-icon"><i class="fa-solid fa-key"></i></span>
                            <input type="password" name="MatKhauCu" id="passOld" class="cp-input" placeholder="••••••" required autocomplete="current-password" />
                            <button type="button" class="cp-toggle-btn" onclick="togglePass('passOld', this)" aria-label="Hiện/ẩn">
                                <i class="fa-regular fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="cp-field">
                        <label class="cp-label">Mật khẩu mới</label>
                        <div class="cp-input-wrap">
                            <span class="cp-icon"><i class="fa-solid fa-lock"></i></span>
                            <input type="password" name="MatKhauMoi" id="passNew" class="cp-input" placeholder="••••••••" required autocomplete="new-password"
                                   oninput="checkStrength(this.value)" />
                            <button type="button" class="cp-toggle-btn" onclick="togglePass('passNew', this)" aria-label="Hiện/ẩn">
                                <i class="fa-regular fa-eye"></i>
                            </button>
                        </div>
                        <div class="cp-strength" id="strengthBox" style="display:none;">
                            <div class="cp-strength-track">
                                <div class="cp-strength-fill" id="strengthFill"></div>
                            </div>
                            <div class="cp-strength-text" id="strengthText"></div>
                        </div>
                    </div>

                    <div class="cp-field" style="margin-bottom:0;">
                        <label class="cp-label">Xác nhận mật khẩu mới</label>
                        <div class="cp-input-wrap" id="confirmWrap">
                            <span class="cp-icon"><i class="fa-solid fa-check-double"></i></span>
                            <input type="password" name="XacNhanMatKhau" id="passConfirm" class="cp-input" placeholder="••••••••" required autocomplete="new-password"
                                   oninput="checkMatch()" />
                            <button type="button" class="cp-toggle-btn" onclick="togglePass('passConfirm', this)" aria-label="Hiện/ẩn">
                                <i class="fa-regular fa-eye"></i>
                            </button>
                        </div>
                        <div id="matchHint" style="font-size:10px;margin-top:5px;font-weight:600;display:none;"></div>
                    </div>

                    <div class="cp-sep"></div>

                    <button type="submit" class="cp-btn-primary">
                        <i class="fa-solid fa-shield-check"></i>
                        Xác nhận đổi mật khẩu
                    </button>
                    <a asp-action="Index" class="cp-btn-back">
                        <i class="fa-solid fa-arrow-left"></i>
                        Hủy bỏ & quay lại
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function togglePass(inputId, btn) {
        const input = document.getElementById(inputId);
        const icon = btn.querySelector('i');
        const isHidden = input.type === 'password';
        input.type = isHidden ? 'text' : 'password';
        icon.classList.toggle('fa-eye', !isHidden);
        icon.classList.toggle('fa-eye-slash', isHidden);
    }

    function checkStrength(val) {
        const box = document.getElementById('strengthBox');
        const fill = document.getElementById('strengthFill');
        const text = document.getElementById('strengthText');

        if (!val) { box.style.display = 'none'; return; }
        box.style.display = 'block';

        let score = 0;
        if (val.length >= 8)              score++;
        if (/[A-Z]/.test(val))            score++;
        if (/[0-9]/.test(val))            score++;
        if (/[^A-Za-z0-9]/.test(val))    score++;

        const levels = [
            { pct: '20%', color: '#ef4444', label: 'Rất yếu' },
            { pct: '45%', color: '#f97316', label: 'Yếu' },
            { pct: '65%', color: '#eab308', label: 'Trung bình' },
            { pct: '85%', color: '#22c55e', label: 'Mạnh' },
            { pct: '100%', color: '#10b981', label: 'Rất mạnh' },
        ];
        const lv = levels[Math.min(score, 4)];
        fill.style.width = lv.pct;
        fill.style.background = lv.color;
        text.textContent = lv.label;
        text.style.color = lv.color;

        checkMatch();
    }

    function checkMatch() {
        const np = document.getElementById('passNew').value;
        const cp = document.getElementById('passConfirm').value;
        const hint = document.getElementById('matchHint');
        const wrap = document.getElementById('confirmWrap');

        if (!cp) { hint.style.display = 'none'; wrap.style.borderColor = ''; return; }
        hint.style.display = 'block';
        if (np === cp) {
            hint.textContent = '✓ Mật khẩu khớp';
            hint.style.color = '#22c55e';
            wrap.style.borderColor = '#22c55e';
        } else {
            hint.textContent = '✗ Mật khẩu chưa khớp';
            hint.style.color = '#ef4444';
            wrap.style.borderColor = '#ef4444';
        }
    }
</script>